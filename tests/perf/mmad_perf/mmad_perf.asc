/*!
 * \file mmad_perf.asc
 * \brief Mmad（Cube 矩阵乘）性能测试示例
 *

 * 测试场景编号说明：
 * 场景 1-4：  适用于 Atlas A3/A2 训练/推理平台（dav-2201 架构）
 * 场景 11-15：适用于 Ascend 950PR/950DT 平台（dav-3510 架构）
 *
 * 场景 1： Mmad b8  - int8_t  * int8_t  -> int32_t
 * 场景 2： Mmad b16 - half    * half     -> float
 * 场景 3： Mmad b32 - float   * float    -> float
 * 场景 4： MmadWithSparse b8 - int8_t * int8_t -> int32_t（4:2 结构化稀疏，仅 dav-2201，步骤 3 实现）
 *
 * 场景 11：Mmad b8  - int8_t  * int8_t  -> int32_t
 * 场景 12：Mmad b16 - half    * half     -> float
 * 场景 13：Mmad b32 - float   * float    -> float
 * 场景 14：MmadMx mxfp8 - fp8_e4m3fn_t（scale fp8_e8m0_t）-> float（仅 dav-3510，步骤 4 实现）
 * 场景 15：MmadMx mxfp4 - fp4x2_e2m1_t（scale fp8_e8m0_t）-> float（仅 dav-3510，步骤 4 实现）
 */
#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif
#include "acl/acl.h"
#include "kernel_operator.h"
#include <cstdio>
#include <cstdlib>

constexpr uint32_t BLOCK_CUBE = 16;
constexpr uint64_t ADDR_0 = 0;
// sparse 场景 L0B / 索引矩阵在 L1 上的地址
constexpr uint32_t SPARSE_C0_SIZE = 32;
constexpr uint64_t SPARSE_B1_ADDR = 128 * 1024;
constexpr uint64_t SPARSE_IDX_B1_ADDR = 256 * 1024;
// mx 场景常量
constexpr uint32_t SCALE_BASE_FACTOR = 64;
constexpr uint32_t SCALE_EVEN_NUMBER = 2;
// mx 场景各 buffer 在 L1 上的地址
constexpr uint64_t MX_A1_ADDR = 0;
constexpr uint64_t MX_SCALE_A1_ADDR = 128 * 1024;
constexpr uint64_t MX_B1_ADDR = 192 * 1024;
constexpr uint64_t MX_SCALE_B1_ADDR = 320 * 1024;

template <class T, class U>
class KernelMmadPerf {
public:
    __aicore__ inline KernelMmadPerf(uint32_t m, uint32_t k, uint32_t n)
    {
        mSize = m;
        kSize = k;
        nSize = n;

        // c0Size 为 K 方向一个分形的元素数，随数据类型位宽变化：
        // b8（1 字节）=32，b16（2 字节）=16，b32（4 字节）=8，即固定为 32 字节 / sizeof(U)。
        c0Size = 32 / sizeof(U);

        // L0A：A 矩阵 [M, K]，按分形对齐
        aSizeAlignL0 = CeilAlign(mSize, BLOCK_CUBE) * CeilAlign(kSize, c0Size);
        // L0B：B 矩阵 [K, N]，按分形对齐
        bSizeAlignL0 = CeilAlign(kSize, c0Size) * CeilAlign(nSize, BLOCK_CUBE);
        // L0C：C 矩阵 [M, N]，按 16x16 分形对齐
        cSizeAlignL0 = CeilAlign(mSize, BLOCK_CUBE) * CeilAlign(nSize, BLOCK_CUBE);
    }

    __aicore__ inline void Process()
    {
        // 直接在 L0A/L0B/L0C 声明 tensor，数据不初始化
        AscendC::LocalTensor<U> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlignL0);
        AscendC::LocalTensor<U> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlignL0);
        AscendC::LocalTensor<T> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlignL0);

        AscendC::PipeBarrier<PIPE_ALL>();

        AscendC::MmadParams mmadParams;
        mmadParams.m = mSize;
        mmadParams.n = nSize;
        mmadParams.k = kSize;
        mmadParams.cmatrixInitVal = true; // C 矩阵初始化为 0，C = A * B

        AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);

        AscendC::PipeBarrier<PIPE_ALL>();
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

private:
    uint32_t mSize, kSize, nSize;
    uint32_t c0Size;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
};

// 稀疏 Mmad 性能测试（4:2 结构化稀疏，b8：int8 * int8 -> int32，仅 dav-2201）。
class KernelMmadSparsePerf {
public:
    __aicore__ inline KernelMmadSparsePerf(uint32_t m, uint32_t k, uint32_t n)
    {
        mSize = m;
        kSize = k;
        nSize = n;

        // A：[M, K] int8；B：稀疏稠密化后为 [K/2, N] int8；C：[M, N] int32
        aSizeAlignL0 = CeilAlign(mSize, BLOCK_CUBE) * CeilAlign(kSize, SPARSE_C0_SIZE);
        bSizeAlignL1 = CeilAlign(kSize, SPARSE_C0_SIZE) * CeilAlign(nSize, BLOCK_CUBE);
        bSizeAlignL0 = bSizeAlignL1;
        cSizeAlignL0 = CeilAlign(mSize, BLOCK_CUBE) * CeilAlign(nSize, BLOCK_CUBE);
    }

    __aicore__ inline void Process()
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 2201)
        AscendC::LocalTensor<int8_t> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlignL0);
        AscendC::LocalTensor<int8_t> b1Local(AscendC::TPosition::B1, SPARSE_B1_ADDR, bSizeAlignL1);
        AscendC::LocalTensor<uint8_t> idxB1Local(AscendC::TPosition::B1, SPARSE_IDX_B1_ADDR, bSizeAlignL1 / 4);
        AscendC::LocalTensor<int8_t> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlignL0);
        AscendC::LocalTensor<int32_t> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlignL0);

        AscendC::PipeBarrier<PIPE_ALL>();

        // 最小前置：将 B + 索引矩阵稠密化加载到 L0B 与内置索引 buffer
        uint32_t nBlocks = CeilDiv(nSize, BLOCK_CUBE);
        uint32_t kBlocks = CeilDiv(kSize, SPARSE_C0_SIZE);
        AscendC::LoadData2DParams loadDataParams;
        loadDataParams.repeatTimes = kBlocks * nBlocks / 2;
        loadDataParams.srcStride = 0;
        loadDataParams.ifTranspose = false;
        AscendC::LoadDataWithSparse(b2Local, b1Local, idxB1Local, loadDataParams);

        AscendC::PipeBarrier<PIPE_ALL>();

        AscendC::MmadParams mmadParams;
        mmadParams.m = mSize;
        mmadParams.n = nSize;
        mmadParams.k = kSize;
        mmadParams.cmatrixInitVal = true; // C 矩阵初始化为 0，C = A * B

        AscendC::MmadWithSparse(co1Local, a2Local, b2Local, mmadParams);

        AscendC::PipeBarrier<PIPE_ALL>();
#endif
    }

private:
    // 向上整除
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }
    // 向上对齐
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

private:
    uint32_t mSize, kSize, nSize;
    uint32_t aSizeAlignL0, bSizeAlignL1, bSizeAlignL0, cSizeAlignL0;
};

// MX（MicroScaling）量化 Mmad 性能测试（仅 dav-3510）。
template <class TA, class TB>
class KernelMmadMxPerf {
public:
    __aicore__ inline KernelMmadMxPerf(uint32_t m, uint32_t k, uint32_t n)
    {
        mSize = m;
        kSize = k;
        nSize = n;

        // fp4 两元素打包成 1 字节，分形 K 方向为 64、packedK 减半；fp8 不打包，分形 K 方向为 32。
        if constexpr (AscendC::IsSameType<TA, fp4x2_e1m2_t>::value || AscendC::IsSameType<TA, fp4x2_e2m1_t>::value) {
            fractalShape1 = 64;
            packedK = CeilDiv(k, 2);
        } else {
            fractalShape1 = 32;
            packedK = k;
        }
        scaleK = CeilDiv(k, SCALE_BASE_FACTOR) * SCALE_EVEN_NUMBER;
        alignK = CeilAlign(k, SCALE_BASE_FACTOR);

        // A：L1/L0 排布 Nz
        mAlignL1 = CeilAlign(m, BLOCK_CUBE);
        aSizeAlignL1 = mAlignL1 * alignK;
        aSizeAlignL0 = mAlignL1 * alignK;
        // B：L1 Nz，L0 Zn
        nAlignL1 = CeilAlign(n, BLOCK_CUBE);
        bSizeAlignL1 = nAlignL1 * alignK;
        bSizeAlignL0 = alignK * nAlignL1;
        // scaleA：Zz；scaleB：Nn
        scaleMAlignL1 = CeilAlign(m, BLOCK_CUBE);
        scaleASizeAlignL1 = scaleMAlignL1 * scaleK;
        scaleNAlignL1 = CeilAlign(n, BLOCK_CUBE);
        scaleBSizeAlignL1 = scaleK * scaleNAlignL1;
        // C：[M, N] float，Nz
        cSizeAlignL0 = mAlignL1 * nAlignL1;
    }

    __aicore__ inline void Process()
    {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
        AscendC::LocalTensor<TA> a1Local(AscendC::TPosition::A1, MX_A1_ADDR, aSizeAlignL1);
        AscendC::LocalTensor<fp8_e8m0_t> scaleA1Local(AscendC::TPosition::A1, MX_SCALE_A1_ADDR, scaleASizeAlignL1);
        AscendC::LocalTensor<TB> b1Local(AscendC::TPosition::B1, MX_B1_ADDR, bSizeAlignL1);
        AscendC::LocalTensor<fp8_e8m0_t> scaleB1Local(AscendC::TPosition::B1, MX_SCALE_B1_ADDR, scaleBSizeAlignL1);
        AscendC::LocalTensor<TA> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlignL0);
        AscendC::LocalTensor<TB> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlignL0);
        AscendC::LocalTensor<float> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlignL0);

        AscendC::PipeBarrier<PIPE_ALL>();

        SplitMx(a2Local, a1Local, scaleA1Local, mAlignL1, scaleMAlignL1);
        SplitMx(b2Local, b1Local, scaleB1Local, nAlignL1, scaleNAlignL1);

        AscendC::PipeBarrier<PIPE_ALL>();

        AscendC::MmadParams mmadParams;
        mmadParams.m = mSize;
        mmadParams.n = nSize;
        mmadParams.k = alignK;
        mmadParams.cmatrixInitVal = true;

        AscendC::MmadMx(co1Local, a2Local, b2Local, mmadParams);

        AscendC::PipeBarrier<PIPE_ALL>();
#endif
    }

private:
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }
    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
    // 一次 LoadData 同时将矩阵搬入 L0A/L0B、scale 矩阵搬入 L0A_MX/L0B_MX
    template <class T>
    __aicore__ inline void SplitMx(
        AscendC::LocalTensor<T> dst, AscendC::LocalTensor<T> src, AscendC::LocalTensor<fp8_e8m0_t> scaleLocal,
        uint32_t mnAlignL1, uint32_t scaleMnAlignL1)
    {
        AscendC::LoadData2DParamsV2 loadDataParams;
        loadDataParams.sid = 0;
        loadDataParams.mStartPosition = 0;
        loadDataParams.kStartPosition = 0;
        loadDataParams.mStep = CeilDiv(mnAlignL1, BLOCK_CUBE);
        loadDataParams.kStep = CeilDiv(alignK, fractalShape1);
        loadDataParams.srcStride = CeilDiv(mnAlignL1, BLOCK_CUBE);
        loadDataParams.dstStride = CeilDiv(mnAlignL1, BLOCK_CUBE);
        loadDataParams.ifTranspose = false;

        AscendC::LoadData2DMxParams loadMxDataParams;
        loadMxDataParams.xStartPosition = 0;
        loadMxDataParams.yStartPosition = 0;
        loadMxDataParams.xStep = CeilDiv(scaleMnAlignL1, BLOCK_CUBE);
        loadMxDataParams.yStep = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.srcStride = scaleK / SCALE_EVEN_NUMBER;
        loadMxDataParams.dstStride = scaleK / SCALE_EVEN_NUMBER;

        AscendC::LoadData(dst, src, scaleLocal, loadDataParams, loadMxDataParams);
    }
#endif

private:
    uint32_t mSize, kSize, nSize;
    uint32_t fractalShape1 = 32;
    uint32_t packedK = 0, scaleK = 0, alignK = 0;
    uint32_t mAlignL1 = 0, nAlignL1 = 0, scaleMAlignL1 = 0, scaleNAlignL1 = 0;
    uint32_t aSizeAlignL1, bSizeAlignL1, scaleASizeAlignL1, scaleBSizeAlignL1;
    uint32_t aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
};

__global__ __cube__ void mmad_perf_custom(
    __gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c, uint32_t scenario, uint32_t m, uint32_t k, uint32_t n)
{
    AscendC::InitSocState();
    // 普通 Mmad 场景：按场景号选择数据类型
    // b8：场景 1 / 11
    if (scenario == 1 || scenario == 11) {
        KernelMmadPerf<int32_t, int8_t> op(m, k, n);
        op.Process();
    } else if (scenario == 2 || scenario == 12) {
        // b16：场景 2 / 12
        KernelMmadPerf<float, half> op(m, k, n);
        op.Process();
    } else if (scenario == 3 || scenario == 13) {
        // b32：场景 3 / 13
        KernelMmadPerf<float, float> op(m, k, n);
        op.Process();
    } else if (scenario == 4) {
        // sparse b8：场景 4（仅 dav-2201）
        KernelMmadSparsePerf op(m, k, n);
        op.Process();
    } else if (scenario == 14) {
        // mxfp8：场景 14（仅 dav-3510）
        KernelMmadMxPerf<fp8_e4m3fn_t, fp8_e4m3fn_t> op(m, k, n);
        op.Process();
    } else if (scenario == 15) {
        // mxfp4：场景 15（仅 dav-3510）
        KernelMmadMxPerf<fp4x2_e2m1_t, fp4x2_e2m1_t> op(m, k, n);
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    if (argc != 5) {
        std::printf("Usage: %s SCENARIO_NUM M K N\n", argv[0]);
        return 1;
    }

    uint32_t scenario = static_cast<uint32_t>(std::strtoul(argv[1], nullptr, 10));
    uint32_t m = static_cast<uint32_t>(std::strtoul(argv[2], nullptr, 10));
    uint32_t k = static_cast<uint32_t>(std::strtoul(argv[3], nullptr, 10));
    uint32_t n = static_cast<uint32_t>(std::strtoul(argv[4], nullptr, 10));

    if (m == 0 || k == 0 || n == 0) {
        std::printf("M, K and N must be positive integers.\n");
        return 1;
    }

    size_t aFileSize = static_cast<size_t>(m) * k * sizeof(float);
    size_t bFileSize = static_cast<size_t>(k) * n * sizeof(float);
    size_t cFileSize = static_cast<size_t>(m) * n * sizeof(float);

    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aDevice = nullptr;
    uint8_t* bDevice = nullptr;
    uint8_t* cDevice = nullptr;
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    mmad_perf_custom<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, cDevice, scenario, m, k, n);
    aclrtSynchronizeStream(stream);

    aclrtFree(aDevice);
    aclrtFree(bDevice);
    aclrtFree(cDevice);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
