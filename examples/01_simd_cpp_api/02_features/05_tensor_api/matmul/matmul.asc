#include <cstdint>
#include <iostream>
#include <vector>
#include <algorithm>
#include <iterator>
#include "acl/acl.h"
#include "include/experimental/tensor_api/tensor.h"
#include "include/basic_api/kernel_operator_dump_tensor_intf.h"
#include "include/basic_api/kernel_operator_block_sync_intf.h"
#include "data_utils.h"

constexpr AscendC::Te::LoadDataTrait LOAD_DATA_B_TRAIT{true};

struct LoadData2BTrait {
    using TraitType = AscendC::Te::LoadDataTrait;
    static constexpr const TraitType value = LOAD_DATA_B_TRAIT;
};

// 自定义FixpipeTrait，使能relu激活
// 用于控制量化场景下的舍入模式，仅针对float量化为hifloat8_t场景生效，默认值为RoundMode::DEFAULT
constexpr AscendC::Te::RoundMode roundModeIn = AscendC::Te::RoundMode::DEFAULT;
// 是否使能ReLU的开关
constexpr bool enableReluIn = false;
// 输出到GM场景下，是否使能通道拆分的功能。仅在目的操作数和源操作数都为float，且目的操作数数据格式为NZ时才能使能通道拆分。
constexpr bool enableChannelSplitIn = false;
// 用于输出到UB场景下双目标模式控制，默认值为DualDstMode::DUAL_DST_DISABLE（即不启用双目标模式控制）
constexpr AscendC::Te::DualDstMode dualDstCtlIn = AscendC::Te::DualDstMode::DUAL_DST_DISABLE;

constexpr AscendC::Te::FixpipeTrait fixpipeTrait = {roundModeIn, enableReluIn, enableChannelSplitIn, dualDstCtlIn};
struct FixpipeTraitCustom {
    using TraitType = AscendC::Te::FixpipeTrait;
    static constexpr const TraitType value = fixpipeTrait;
};

// matmul_config

template <typename A_TYPE, typename B_TYPE, typename C_TYPE, typename BIAS_TYPE, const MatmulConfig& config = MATMUL_CONFIG>
__aicore__ void matmul_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t *biasGM, 
                            __gm__ uint64_t* quantGM, __gm__ uint8_t* z)
{
    using namespace AscendC::Te;
    constexpr uint32_t m = config.m;
    constexpr uint32_t n = config.n;
    constexpr uint32_t k = config.k;

    constexpr uint32_t singleCoreM = config.singleCoreM;
    constexpr uint32_t singleCoreN = config.singleCoreN;
    constexpr uint32_t singleCoreK = config.singleCoreK;

    constexpr uint32_t baseM = config.baseM;
    constexpr uint32_t baseN = config.baseN;
    constexpr uint32_t baseK = config.baseK;

    constexpr uint32_t stepM = config.stepM;
    constexpr uint32_t stepN = config.stepN;
    constexpr uint32_t stepKa = config.stepKa;
    constexpr uint32_t stepKb = config.stepKb;

    constexpr uint32_t isTransposeA = config.isTransposeA;
    constexpr uint32_t isTransposeB = config.isTransposeB;
    constexpr uint32_t isBias = config.isBias;

    auto gmPtrA = MakeGMmemPtr(reinterpret_cast<__gm__ A_TYPE *>(x));
    auto gmPtrB = MakeGMmemPtr(reinterpret_cast<__gm__ B_TYPE *>(y));
    auto gmPtrC = MakeGMmemPtr(reinterpret_cast<__gm__ C_TYPE *>(z));

    auto gmA = MakeTensor(gmPtrA, MakeNDLayout<A_TYPE>(m, k));
    auto gmB = MakeTensor(gmPtrB, MakeNDLayout<B_TYPE>(k, n));
    auto gmC = MakeTensor(gmPtrC, MakeNDLayout<C_TYPE>(m, n));

    uint32_t mIter = m / singleCoreM;
    uint32_t mIterIdx = get_block_idx() % mIter;
    uint32_t nIterIdx = get_block_idx() / mIter;

    auto shapeA = MakeShape(singleCoreM, singleCoreK);
    auto globalA = gmA(MakeCoord(mIterIdx * singleCoreM, 0), shapeA);

    auto shapeB = MakeShape(singleCoreK, singleCoreN);
    auto globalB = gmB(MakeCoord(0, nIterIdx * singleCoreN), shapeB);

    auto shapeC = MakeShape(singleCoreM, singleCoreN);
    auto globalC = gmC(MakeCoord(mIterIdx * singleCoreM, nIterIdx * singleCoreN), shapeC);

    auto l1ALayout = MakeNzLayout<A_TYPE>(baseM * stepM, baseK * stepKa);
    auto l1BLayout = MakeNzLayout<B_TYPE>(baseK * stepKb, baseN * stepN);

    auto l0CLayout = MakeL0CLayout(baseM, baseN);

    size_t l1ASize = baseM * stepM * baseK * stepKa;
    size_t l1BSize = baseN * stepN * baseK * stepKb;

    __cbuf__ A_TYPE l1ABuf[baseM * stepM * baseK * stepKa];
    __cbuf__ B_TYPE l1BBuf[baseK * stepKb * baseN * stepN];
    __ca__ A_TYPE l0ABuf[baseM * baseK];
    __cb__ B_TYPE l0BBuf[baseK * baseN];
    __cc__ C_TYPE l0CBuf[baseM * baseN];

    auto l1APtr = MakeL1memPtr(l1ABuf);
    auto l1BPtr = MakeL1memPtr(l1BBuf);
    auto l0APtr = MakeL0AmemPtr(l0ABuf);
    auto l0BPtr = MakeL0BmemPtr(l0BBuf);
    auto l0CPtr = MakeL0CmemPtr(l0CBuf);

    auto l1ATensor = MakeTensor(l1APtr, l1ALayout);
    auto l1BTensor = MakeTensor(l1BPtr, l1BLayout);

    auto l0CTensor = MakeTensor(l0CPtr, l0CLayout);

    constexpr uint32_t mLoop = (singleCoreM + baseM - 1) / baseM;
    constexpr uint32_t nLoop = (singleCoreN + baseN - 1) / baseN;
    constexpr uint32_t kLoop = (singleCoreK + baseK - 1) / baseK;

    AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
    AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
    AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);

    for (uint32_t i = 0; i < mLoop; i++) {
        uint16_t tileM = (i + 1 == mLoop && singleCoreM % baseM != 0) ? singleCoreM % baseM : baseM;
        for (uint32_t j = 0; j < nLoop; j++) {
            uint16_t tileN = (j + 1 == nLoop && singleCoreN % baseN != 0) ? singleCoreN % baseN : baseN;
            for (uint32_t kIter = 0; kIter < kLoop; kIter++) {
                uint16_t tileK = (kIter + 1 == kLoop && singleCoreK % baseK != 0) ? singleCoreK % baseK : baseK;
                auto l0ALayout = MakeNzLayout<A_TYPE>(tileM, tileK);
                auto l0BLayout = MakeZnLayout<B_TYPE>(tileK, tileN);
                auto l0ATensor = MakeTensor(l0APtr, l0ALayout);
                auto l0BTensor = MakeTensor(l0BPtr, l0BLayout);
                if (kIter % stepKa == 0) {
                    AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                    // GM -> L1A
                    Copy(CopyAtom<CopyTraits<CopyGM2L1, DataCopyTraitDefault>>{}, l1ATensor, globalA,
                        MakeCoord(i * baseM, kIter * baseK));
                    // GM -> L1B
                    Copy(CopyAtom<CopyTraits<CopyGM2L1, DataCopyTraitDefault>>{}, l1BTensor, globalB,
                        MakeCoord(kIter * baseK, j * baseN));
                    AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
                    AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);
                }
                AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
                // L1A -> L0A
                Copy(CopyAtom<CopyTraits<CopyL12L0, LoadDataTraitDefault>>{}, l0ATensor, l1ATensor,
                    MakeCoord(0, kIter % stepKa * baseK));
                // L1B -> L0B
                Copy(CopyAtom<CopyTraits<CopyL12L0, LoadData2BTrait>>{}, l0BTensor, l1BTensor,
                    MakeCoord(kIter % stepKb * baseK, 0));
                if ((kIter + 1) % stepKa == 0) {
                    AscendC::SetFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
                }
                AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
                AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);

                if (kIter % stepKa == 0) {
                    AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
                }

                // mmad
                MmadParams para;
                para.m = tileM;
                para.n = tileN;
                para.k = tileK;
                if (kIter == 0) {
                    para.cmatrixInitVal = true;
                    Mad(MmadAtom<MmadTraits<MmadOperation, MmadTraitDefault>>{}, l0CTensor, l0ATensor, l0BTensor, para);
                } else {
                    para.cmatrixInitVal = false;
                    Mad(MmadAtom<MmadTraits<MmadOperation, MmadTraitDefault>>{}, l0CTensor, l0ATensor, l0BTensor, para);
                }
                if (kIter == kLoop - 1) {
                    AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
                }
                AscendC::SetFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
            }
            AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
            FixpipeParams fixpipeParams;
            fixpipeParams.unitFlag = 0;
            // L0C -> GM
            Copy(CopyAtom<CopyTraits<CopyL0C2GM, FixpipeTraitCustom>>{}, globalC, l0CTensor,
                MakeCoord(i * baseM, j * baseN), fixpipeParams);
            AscendC::SetFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
        }
    }

    AscendC::WaitFlag<AscendC::HardEvent::M_MTE1>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::MTE1_MTE2>(EVENT_ID0);
    AscendC::WaitFlag<AscendC::HardEvent::FIX_M>(EVENT_ID0);
}

template <typename A_TYPE, typename B_TYPE, typename C_TYPE, typename BIAS_TYPE, const MatmulConfig& config = MATMUL_CONFIG>
__cube__ __global__ __aicore__ void tensor_api_custom(__gm__ uint8_t* aGM, __gm__ uint8_t* bGM, __gm__ uint8_t *biasGM, 
                                            __gm__ uint64_t* quantGM, __gm__ uint8_t* cGM) {
    matmul_custom<A_TYPE, B_TYPE, C_TYPE, BIAS_TYPE, config>(aGM, bGM, biasGM, quantGM, cGM);
}

int32_t main(int32_t argc, char* argv[]) {
    if (argc != 6) {
        fprintf(stderr, "Error: Invalid number of arguments.\n");
        return -1;
    }
    const char *input_x = argv[1];
    const char *input_y = argv[2];
    const char *input_bias = argv[3];
    const char *input_quant = argv[4];
    const char *output = argv[5];

    // insert_code

    size_t aFileSize = m * k * sizeof(A_TYPE);
    size_t bFileSize = k * n * sizeof(B_TYPE);
    size_t cFileSize = m * n * sizeof(C_TYPE);
    constexpr uint32_t blockDim = 1;
    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *aHost;
    uint8_t *aDevice;
    aclrtMallocHost((void **)(&aHost), aFileSize);
    aclrtMalloc((void **)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile(input_x, aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    
    uint8_t *bHost;
    uint8_t *bDevice;
    aclrtMallocHost((void **)(&bHost), bFileSize);
    aclrtMalloc((void **)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile(input_y, bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *cHost;
    uint8_t *cDevice;
    aclrtMallocHost((void **)(&cHost), cFileSize);
    aclrtMalloc((void **)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t *biasHost;
    uint8_t *biasDevice;
    size_t biasFileSize = n * sizeof(BIAS_TYPE);
    aclrtMallocHost((void **)(&biasHost), biasFileSize);
    aclrtMalloc((void **)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile(input_bias, biasFileSize, biasHost, biasFileSize);
    aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t *quantHost;
    uint64_t *quantDevice;
    size_t quantFileSize = n * sizeof(uint64_t);
    aclrtMallocHost((void **)(&quantHost), quantFileSize);
    aclrtMalloc((void **)&quantDevice, quantFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile(input_quant, quantFileSize, quantHost, quantFileSize);
    aclrtMemcpy(quantDevice, quantFileSize, quantHost, quantFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    tensor_api_custom<A_TYPE, B_TYPE, C_TYPE, BIAS_TYPE>
                <<<blockDim, nullptr, stream>>>(aDevice, bDevice, biasDevice, quantDevice, cDevice);

    aclrtSynchronizeStream(stream);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile(output, cHost, cFileSize);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtFree(biasDevice);
    aclrtFreeHost(biasHost);
    aclrtFree(quantDevice);
    aclrtFreeHost(quantHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}