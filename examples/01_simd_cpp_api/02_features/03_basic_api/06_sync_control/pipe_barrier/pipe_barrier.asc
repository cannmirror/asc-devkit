/* !
 * \file pipe_barrier.asc
 * \brief 基于PipeBarrier实现核内多流水同步，涵盖搬入(PIPE_MTE2)、计算(PIPE_V)、搬出(PIPE_MTE3)全流程同步控制
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

/**
 * @brief 基于PipeBarrier实现核内多流水同步的Kernel类
 * 
 * 本样例展示了完整的数据处理流程中的多流水同步控制：
 * 1. 搬入阶段：使用PipeBarrier<PIPE_MTE2>处理地址重叠
 * 2. 多流水同步：使用SetFlag/WaitFlag进行MTE2->V同步
 * 3. 计算阶段：使用PipeBarrier<PIPE_V>隔离Add和Mul操作
 * 4. 多流水同步：使用SetFlag/WaitFlag进行V->MTE3同步
 * 5. 搬出阶段：使用PipeBarrier<PIPE_MTE3>处理搬出顺序
 * 
 * 输出数据布局：
 * - output[0:256]: Add结果 dst = src0 + src1
 * - output[256:512]: Mul结果 dst2 = dst * src0 = (src0 + src1) * src0
 */
class KernelPipeBarrier{
public:
    __aicore__ inline KernelPipeBarrier() {}
    __aicore__ inline void Init(__gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* src2Gm,
                                __gm__ uint8_t* dstGm)
    {
        src0Global.SetGlobalBuffer((__gm__ float*)src0Gm, srcDataSize);
        src1Global.SetGlobalBuffer((__gm__ float*)src1Gm, srcDataSize);
        src2Global.SetGlobalBuffer((__gm__ float*)src2Gm, srcDataSize);
        dstGlobal.SetGlobalBuffer((__gm__ float*)dstGm, totalDataSize);
    }
    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<float> src0Local(AscendC::TPosition::VECCALC, src0Addr, srcDataSize);
        AscendC::LocalTensor<float> src1Local(AscendC::TPosition::VECCALC, src1Addr, srcDataSize);
        AscendC::LocalTensor<float> src2Local(AscendC::TPosition::VECCALC, src2Addr, srcDataSize);
        AscendC::LocalTensor<float> dstLocal(AscendC::TPosition::VECCALC, dstAddr, srcDataSize);
        AscendC::LocalTensor<float> dst2Local(AscendC::TPosition::VECCALC, dst2Addr, srcDataSize);

        // ===================== 搬入阶段 (PIPE_MTE2) =====================
        // src1和src2在UB上分配的地址区间有重叠，需要通过PipeBarrier保证搬入顺序
        AscendC::DataCopy(src0Local, src0Global, srcDataSize);
        // 先搬入src2，src2的地址区间与src1有重叠部分
        AscendC::DataCopy(src2Local, src2Global, srcDataSize);
        // 阻塞MTE2搬入流水，确保src2搬入完成后再搬入src1
        // 防止src1的数据覆盖src2在重叠区间的值
        AscendC::PipeBarrier<PIPE_MTE2>();
        AscendC::DataCopy(src1Local, src1Global, srcDataSize);

        // ===================== 多流水同步 (MTE2 -> V) =====================
        // 确保所有数据搬入完成后，才能开始向量计算
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // ===================== 计算阶段 (PIPE_V) =====================
        // 执行Add计算：dst = src0 + src1
        AscendC::Add(dstLocal, src0Local, src1Local, srcDataSize);
        // 阻塞PIPE_V流水，确保Add计算完成后再执行Mul
        // Add的输出dstLocal是Mul的输入，存在数据依赖
        AscendC::PipeBarrier<PIPE_V>();
        // 执行Mul计算：dst2 = dst * src0 = (src0 + src1) * src0
        // 使用Add的中间结果dstLocal继续计算，形成计算流水链
        AscendC::Mul(dst2Local, dstLocal, src0Local, srcDataSize);

        // ===================== 多流水同步 (V -> MTE3) =====================
        // 确保所有向量计算完成后，才能开始数据搬出
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // ===================== 搬出阶段 (PIPE_MTE3) =====================
        // 搬出dst结果到output[0:256]
        AscendC::DataCopy(dstGlobal[0], dstLocal, srcDataSize);
        // 阻塞PIPE_MTE3搬出流水，确保dst搬出完成后再搬出dst2
        AscendC::PipeBarrier<PIPE_MTE3>();
        // 搬出dst2结果到output[256:512]
        AscendC::DataCopy(dstGlobal[srcDataSize], dst2Local, srcDataSize);
    }
private:
    // UB地址分配：src0、src1、src2、dst、dst2
    // src1和src2存在128个元素的地址重叠区间
    static constexpr uint32_t src0Addr = 0;
    static constexpr uint32_t src1Addr = 256 * sizeof(float);
    static constexpr uint32_t src2Addr = (256 + 128) * sizeof(float);
    static constexpr uint32_t dstAddr = (256 * 3) * sizeof(float);
    static constexpr uint32_t dst2Addr = (256 * 4) * sizeof(float);
    
    AscendC::GlobalTensor<float> src0Global, src1Global, src2Global;
    AscendC::GlobalTensor<float> dstGlobal;
    uint32_t srcDataSize = 256;
    uint32_t totalDataSize = 512;  // 两个输出合并：dst(256) + dst2(256)
};

__global__ __vector__ void pipe_barrier_custom(GM_ADDR src0, GM_ADDR src1, GM_ADDR src2, GM_ADDR dst) 
{
    AscendC::InitSocState();
    KernelPipeBarrier op;
    op.Init(src0, src1, src2, dst);
    op.Process();
}

int32_t main(int32_t argc, char* argv[]) 
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 256 * sizeof(float);
    size_t outputByteSize = 512 * sizeof(float);  // 合并输出：256*2

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *src0Host, *src1Host, *src2Host, *dstHost;
    uint8_t *src0Device, *src1Device, *src2Device, *dstDevice;

    aclrtMallocHost((void **)(&src0Host), inputByteSize);
    aclrtMallocHost((void **)(&src1Host), inputByteSize);
    aclrtMallocHost((void **)(&src2Host), inputByteSize);
    aclrtMallocHost((void **)(&dstHost), outputByteSize);
    aclrtMalloc((void **)&src0Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&src1Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&src2Device, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&dstDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_src0.bin", inputByteSize, src0Host, inputByteSize);
    ReadFile("./input/input_src1.bin", inputByteSize, src1Host, inputByteSize);
    ReadFile("./input/input_src2.bin", inputByteSize, src2Host, inputByteSize);

    aclrtMemcpy(src0Device, inputByteSize, src0Host, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src1Device, inputByteSize, src1Host, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(src2Device, inputByteSize, src2Host, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    pipe_barrier_custom<<<numBlocks, nullptr, stream>>>(src0Device, src1Device, src2Device, dstDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(dstHost, outputByteSize, dstDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", dstHost, outputByteSize);

    aclrtFree(src0Device);
    aclrtFree(src1Device);
    aclrtFree(src2Device);
    aclrtFree(dstDevice);
    aclrtFreeHost(src0Host);
    aclrtFreeHost(src1Host);
    aclrtFreeHost(src2Host);
    aclrtFreeHost(dstHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}