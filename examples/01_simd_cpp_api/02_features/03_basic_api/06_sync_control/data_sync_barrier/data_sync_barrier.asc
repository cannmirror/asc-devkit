/* !
 * \file data_sync_barrier.asc
 * \brief DataSyncBarrier接口样例，演示核内标量单元流水（PIPE_S）的同步操作
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t TOTAL_LENGTH = 8;

/**
 * @brief DataSyncBarrier操作的Kernel类
 * 
 * DataSyncBarrier用于核内标量单元流水（PIPE_S）的同步，确保标量操作完成后再执行后续操作。
 * 本样例演示SetValue后调用DataSyncBarrier确保数据写入完成，再执行GetValue读取。
 */
template <typename T>
class KernelDataSyncBarrier {
public:
    __aicore__ inline KernelDataSyncBarrier() {}
    __aicore__ inline void Init(GM_ADDR tensorGm, GM_ADDR inputGm, GM_ADDR dstGm, AscendC::TPipe *pipeIn)
    {
        pipe = pipeIn;
        tensorGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(tensorGm));
        inputGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(inputGm));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(dstGm));

        pipe->InitBuffer(inQueue, 1, TOTAL_LENGTH * sizeof(T));
        pipe->InitBuffer(outQueue, 1, TOTAL_LENGTH * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        // SetValue: 对Global Tensor写入标量值
        tensorGlobal.SetValue(3, 1.145616);

        // DataSyncBarrier: 核内标量单元流水同步，确保SetValue写入完成
        // 支持三种模式：ALL(DDR+UB)、DDR、UB
        AscendC::DataSyncBarrier<AscendC::MemDsbT::ALL>();

        // GetValue: 从Global Tensor读取标量值（需确保SetValue已完成）
        T scalarValue = tensorGlobal.GetValue(3);
        
        // CopyIn: 将输入数据从GM搬到UB
        AscendC::LocalTensor<T> inputLocal = inQueue.AllocTensor<T>();
        AscendC::DataCopy(inputLocal, inputGlobal, TOTAL_LENGTH);
        inQueue.EnQue(inputLocal);
        
        // Compute: 在UB上执行Adds
        AscendC::LocalTensor<T> inputLocalDeQue = inQueue.DeQue<T>();
        AscendC::LocalTensor<T> outputLocal = outQueue.AllocTensor<T>();
        AscendC::Adds(outputLocal, inputLocalDeQue, scalarValue, TOTAL_LENGTH);
        outQueue.EnQue<T>(outputLocal);
        inQueue.FreeTensor(inputLocalDeQue);
        
        // CopyOut: 将结果从UB搬到GM
        AscendC::LocalTensor<T> outputLocalDeQue = outQueue.DeQue<T>();
        AscendC::DataCopy(dstGlobal, outputLocalDeQue, TOTAL_LENGTH);
        outQueue.FreeTensor(outputLocalDeQue);
    }

private:
    AscendC::GlobalTensor<T> tensorGlobal;
    AscendC::GlobalTensor<T> inputGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue;
};

extern "C" __global__ __vector__ void kernel_data_sync_barrier(GM_ADDR tensorGm, GM_ADDR inputGm, GM_ADDR dstGm)
{
    AscendC::TPipe pipe;
    KernelDataSyncBarrier<float> op;
    op.Init(tensorGm, inputGm, dstGm, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[]) 
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = TOTAL_LENGTH * sizeof(float);
    size_t outputByteSize = inputByteSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *inputHost, *zHost;
    uint8_t *tensorDevice, *inputDevice, *zDevice;

    aclrtMallocHost((void**)(&inputHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&tensorDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&inputDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, inputHost, inputByteSize);

    aclrtMemcpy(inputDevice, inputByteSize, inputHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_data_sync_barrier<<<numBlocks, nullptr, stream>>>(tensorDevice, inputDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(tensorDevice);
    aclrtFree(inputDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(inputHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}