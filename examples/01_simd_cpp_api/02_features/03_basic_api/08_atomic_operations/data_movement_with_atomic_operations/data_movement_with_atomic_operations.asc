/* !
 * \file data_movement_with_atomic_operations.asc
 * \brief 本样例基于 SetAtomicAdd/SetAtomicMax 原子操作接口，介绍数据从 VECOUT 向 GM 搬运时，原子累加和原子最大值比较的实现流程
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T, uint32_t SIZE>
class KernelSetAtomicAdd {
public:
    __aicore__ inline KernelSetAtomicAdd() {}
    __aicore__ inline void Init(GM_ADDR srcGm, GM_ADDR dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ T*)srcGm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(queueSrc, 1, SIZE * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = queueSrc.AllocTensor<T>();
        AscendC::DisableDmaAtomic();
        AscendC::DataCopy(srcLocal, srcGlobal, SIZE);
        queueSrc.EnQue(srcLocal);
        AscendC::SyncAll();
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> srcLocal = queueSrc.DeQue<T>();

        AscendC::SetAtomicAdd<T>();
        AscendC::DataCopy(dstGlobal, srcLocal, SIZE);

        AscendC::DisableDmaAtomic();

        queueSrc.FreeTensor(srcLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> queueSrc;
    AscendC::GlobalTensor<T> srcGlobal, dstGlobal;
};

template <typename T, uint32_t SIZE>
class KernelSetAtomicMaxMultiInput {
public:
    __aicore__ inline KernelSetAtomicMaxMultiInput() {}
    __aicore__ inline void Init(GM_ADDR srcGm0, GM_ADDR srcGm1, GM_ADDR srcGm2, GM_ADDR dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal[0].SetGlobalBuffer((__gm__ T*)srcGm0);
        srcGlobal[1].SetGlobalBuffer((__gm__ T*)srcGm1);
        srcGlobal[2].SetGlobalBuffer((__gm__ T*)srcGm2);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(queueSrc, 1, SIZE * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = queueSrc.AllocTensor<T>();
        AscendC::DisableDmaAtomic();

        AscendC::DataCopy(srcLocal, srcGlobal[AscendC::GetBlockIdx()], SIZE);
        queueSrc.EnQue(srcLocal);
        AscendC::SyncAll();
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> srcLocal = queueSrc.DeQue<T>();

        AscendC::SetAtomicMax<T>();
        AscendC::DataCopy(dstGlobal, srcLocal, SIZE);

        AscendC::DisableDmaAtomic();

        queueSrc.FreeTensor(srcLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> queueSrc;
    AscendC::GlobalTensor<T> srcGlobal[3];
    AscendC::GlobalTensor<T> dstGlobal;
};

template <uint32_t DATA_SIZE>
__global__ __vector__ void data_movement_with_atomic_operations_custom(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    if constexpr (scenarioNum == 1) {
        KernelSetAtomicAdd<half, DATA_SIZE> op;
        op.Init(x, y, &pipe);
        op.Process();
    } else {
        KernelSetAtomicMaxMultiInput<half, DATA_SIZE> op;
        op.Init(x, reinterpret_cast<GM_ADDR>(reinterpret_cast<uintptr_t>(x) + DATA_SIZE * sizeof(half)),
                reinterpret_cast<GM_ADDR>(reinterpret_cast<uintptr_t>(x) + 2 * DATA_SIZE * sizeof(half)), y, &pipe);
        op.Process();
    }
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 3;
    constexpr uint32_t DATA_SIZE = 256;
    size_t singleInputByteSize = DATA_SIZE * sizeof(half);
    size_t totalInputByteSize = singleInputByteSize;
    size_t outputByteSize = DATA_SIZE * sizeof(half);

    if constexpr (scenarioNum == 2) {
        totalInputByteSize = NUM_BLOCKS * singleInputByteSize;
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *outHost;
    uint8_t *xDevice, *outDevice;

    aclrtMallocHost((void**)(&xHost), totalInputByteSize);
    aclrtMallocHost((void**)(&outHost), singleInputByteSize);
    aclrtMalloc((void**)&xDevice, totalInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    if constexpr (scenarioNum == 1) {
        ReadFile("./input/input_x.bin", singleInputByteSize, xHost, singleInputByteSize);
    } else {
        for (uint32_t i = 0; i < NUM_BLOCKS; i++) {
            std::string inputFile = "./input/input_x" + std::to_string(i) + ".bin";
            ReadFile(inputFile.c_str(), singleInputByteSize, xHost + i * singleInputByteSize, singleInputByteSize);
        }
    }
    ReadFile("./input/input_y.bin", singleInputByteSize, outHost, singleInputByteSize);

    aclrtMemcpy(xDevice, totalInputByteSize, xHost, totalInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(outDevice, singleInputByteSize, outHost, singleInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    data_movement_with_atomic_operations_custom<DATA_SIZE><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, outDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(outDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(outHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
