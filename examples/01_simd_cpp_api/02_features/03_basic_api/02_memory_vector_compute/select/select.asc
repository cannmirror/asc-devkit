/* !
 * \file select.asc
 * \brief 基于Select接口完成多种场景下的数据选择功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

template <typename T, typename U, uint32_t INPUT_SIZE, uint32_t INPUT_Y_SIZE, uint32_t INPUT_SEL_SIZE>
class KernelSelect {
public:
    __aicore__ inline KernelSelect() {}
    __aicore__ inline void Init(
        __gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* selGm, __gm__ uint8_t* dstGm,
        AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        src0Global.SetGlobalBuffer((__gm__ T*)src0Gm);
        src1Global.SetGlobalBuffer((__gm__ T*)src1Gm);
        selMaskGlobal.SetGlobalBuffer((__gm__ U*)selGm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(inQueueSrc0, 1, INPUT_SIZE * sizeof(T));
        pipe->InitBuffer(inQueueSrc1, 1, INPUT_SIZE * sizeof(T));
        pipe->InitBuffer(inQueueSelMask, 1, INPUT_SEL_SIZE * sizeof(U));
        pipe->InitBuffer(outQueueDst, 1, INPUT_SIZE * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> src0Local = inQueueSrc0.AllocTensor<T>();
        AscendC::LocalTensor<T> src1Local = inQueueSrc1.AllocTensor<T>();
        AscendC::LocalTensor<U> selMaskLocal = inQueueSelMask.AllocTensor<U>();
        AscendC::DataCopy(src0Local, src0Global, INPUT_SIZE);
        AscendC::DataCopy(src1Local, src1Global, INPUT_Y_SIZE);
        if constexpr (SCENARIO_NUM == 1) {
            AscendC::DataCopyExtParams copyParams{1, INPUT_SEL_SIZE * sizeof(U), 0, 0, 0};
            AscendC::DataCopyPadExtParams<U> padParams;
            padParams.isPad = false;
            padParams.leftPadding = 0;
            padParams.rightPadding = 24; // 右侧补充24字节
            AscendC::SetPadValue((uint8_t)0);
            AscendC::DataCopyPad(selMaskLocal, selMaskGlobal, copyParams, padParams); // DataCopyPad提供非对齐搬运功能
        } else {
            AscendC::DataCopy(selMaskLocal, selMaskGlobal, INPUT_SEL_SIZE);
        }
        inQueueSrc0.EnQue(src0Local);
        inQueueSelMask.EnQue(selMaskLocal);
        inQueueSrc1.EnQue(src1Local);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> src0Local = inQueueSrc0.DeQue<T>();
        AscendC::LocalTensor<T> src1Local = inQueueSrc1.DeQue<T>();
        AscendC::LocalTensor<U> maskLocal = inQueueSelMask.DeQue<U>();
        AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();

        if constexpr (SCENARIO_NUM == 1 || SCENARIO_NUM == 3) {
            AscendC::SELMODE selMode =
                (SCENARIO_NUM == 1) ? AscendC::SELMODE::VSEL_CMPMASK_SPR : AscendC::SELMODE::VSEL_TENSOR_TENSOR_MODE;
            AscendC::Select(dstLocal, maskLocal, src0Local, src1Local, selMode, INPUT_SIZE);
        } else if constexpr (SCENARIO_NUM == 2) {
            int32_t eventID = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::MTE2_S));
            AscendC::SetFlag<AscendC::HardEvent::MTE2_S>(eventID);
            AscendC::WaitFlag<AscendC::HardEvent::MTE2_S>(eventID);
            T src1Scalar = src1Local.GetValue(0);

            eventID = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::S_V));
            AscendC::SetFlag<AscendC::HardEvent::S_V>(eventID);
            AscendC::WaitFlag<AscendC::HardEvent::S_V>(eventID);

            AscendC::Select(
                dstLocal, maskLocal, src0Local, src1Scalar, AscendC::SELMODE::VSEL_TENSOR_SCALAR_MODE, INPUT_SIZE);
        } else if constexpr (SCENARIO_NUM == 4) {
#if defined(__NPU_ARCH__) && (__NPU_ARCH__ == 3510)
            // 灵活标量位置，仅Ascend 950PR/Ascend 950DT产品支持
            static constexpr AscendC::BinaryConfig config = {1}; // 1表示标量在后，默认值；0表示标量在前
            AscendC::Select<AscendC::BinaryDefaultType, U, config>(
                dstLocal, maskLocal, src0Local, src1Local[0], AscendC::SELMODE::VSEL_TENSOR_SCALAR_MODE, INPUT_SIZE);
#endif
        }
        outQueueDst.EnQue<T>(dstLocal);
        inQueueSrc0.FreeTensor(src0Local);
        inQueueSrc1.FreeTensor(src1Local);
        inQueueSelMask.FreeTensor(maskLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, INPUT_SIZE);
        outQueueDst.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc0, inQueueSrc1, inQueueSelMask;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<T> src0Global, src1Global, dstGlobal;
    AscendC::GlobalTensor<U> selMaskGlobal;
};

template <typename T, typename U, uint32_t INPUT_SIZE, uint32_t INPUT_Y_SIZE, uint32_t INPUT_SEL_SIZE>
__global__ __vector__ void select_custom(GM_ADDR x, GM_ADDR y, GM_ADDR sel, GM_ADDR z)
{
    AscendC::TPipe pipe;
    KernelSelect<float, uint8_t, INPUT_SIZE, INPUT_Y_SIZE, INPUT_SEL_SIZE> op;
    op.Init(x, y, sel, z, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t NUM_BLOCKS = 1;

    size_t inputYByteSize, selByteSize;
    size_t inputByteSize = 256 * sizeof(float);
    size_t outputByteSize = inputByteSize;
    if constexpr (SCENARIO_NUM == 1) {
        inputYByteSize = 256 * sizeof(float);
        selByteSize = 8 * sizeof(uint8_t);
    } else if constexpr (SCENARIO_NUM == 2 || SCENARIO_NUM == 4) {
        inputYByteSize = 8 * sizeof(float);
        selByteSize = 32 * sizeof(uint8_t);
    } else if constexpr (SCENARIO_NUM == 3) {
        inputYByteSize = 256 * sizeof(float);
        selByteSize = 32 * sizeof(uint8_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost, *selHost;
    uint8_t *xDevice, *yDevice, *zDevice, *selDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), inputYByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMallocHost((void**)(&selHost), selByteSize);

    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, inputYByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&selDevice, selByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    ReadFile("./input/input_y.bin", inputYByteSize, yHost, inputYByteSize);
    ReadFile("./input/input_sel.bin", selByteSize, selHost, selByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, inputYByteSize, yHost, inputYByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(selDevice, selByteSize, selHost, selByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (SCENARIO_NUM == 1) {
        select_custom<float, uint8_t, 256, 256, 8>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 2 || SCENARIO_NUM == 4) {
        select_custom<float, uint8_t, 256, 8, 32>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    } else if constexpr (SCENARIO_NUM == 3) {
        select_custom<float, uint8_t, 256, 256, 32>
            <<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, selDevice, zDevice);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFree(selDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtFreeHost(selHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
