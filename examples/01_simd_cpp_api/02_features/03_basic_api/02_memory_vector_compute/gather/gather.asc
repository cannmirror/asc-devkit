/* !
 * \file gather.asc
 * \brief 基于GatherMask、Gather、Gatherb实现从源操作数中选取元素写入目的操作数，支持多种场景
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1：内置固定模式
// 场景2：用户自定义模式
// 场景3：张量偏移模式
// 场景4：DataBlock偏移模式
constexpr uint32_t NUM_BLOCKS = 1;
constexpr size_t INPUT_SIZE = (scenarioNum == 1 || scenarioNum == 2) ? 256 : 128;
constexpr size_t INPUT_Y_SIZE = (scenarioNum == 2) ? 32 : ((scenarioNum == 3) ? 128 : 8);
constexpr size_t OUTPUT_SIZE = (scenarioNum == 1 || scenarioNum == 2) ? 256 : 128;
constexpr int32_t DEPTH = 1;

template <typename T>
class KernelGather {
public:
    __aicore__ inline KernelGather() {}
    __aicore__ inline void Init(
        __gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        src0Global.SetGlobalBuffer((__gm__ T*)src0Gm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(inQueueSrc0, DEPTH, INPUT_SIZE * sizeof(T));

        if constexpr (scenarioNum == 2 || scenarioNum == 3 || scenarioNum == 4) {
            src1Global.SetGlobalBuffer((__gm__ uint32_t*)src1Gm);
            pipe->InitBuffer(inQueueSrc1, DEPTH, INPUT_Y_SIZE * sizeof(uint32_t));
            pipe->InitBuffer(outQueueDst, DEPTH, OUTPUT_SIZE * sizeof(T));
        }
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> src0Local = inQueueSrc0.AllocTensor<T>();
        AscendC::DataCopy(src0Local, src0Global, INPUT_SIZE);
        inQueueSrc0.EnQue(src0Local);

        if constexpr (scenarioNum == 2 || scenarioNum == 3 || scenarioNum == 4) {
            AscendC::LocalTensor<uint32_t> src1Local = inQueueSrc1.AllocTensor<uint32_t>();
            AscendC::DataCopy(src1Local, src1Global, INPUT_Y_SIZE);
            inQueueSrc1.EnQue(src1Local);
        }
    }
    __aicore__ inline void Compute()
    {
        uint32_t mask;
        uint64_t rsvdCnt = 0; // 用于保存筛选后保留下来的元素个数
        if constexpr (scenarioNum == 1) {
            AscendC::LocalTensor<T> src0Local = inQueueSrc0.DeQue<T>();

            mask = 0;                // normal模式下mask建议设置为0
            uint8_t src1Pattern = 2; // 内置固定模式，取值范围为[1,7]
            // reduceMode = false; 使用normal模式
            // src0BlockStride = 1; 单次迭代内数据间隔1个Block，即数据连续读取和写入
            // repeatTimes = 4; 重复迭代4次
            // src0RepeatStride = 8; 源操作数迭代间数据间隔8个datablock
            // src1RepeatStride = 0; 
            AscendC::GatherMask(src0Local, src0Local, src1Pattern, false, mask, {1, 4, 8, 0}, rsvdCnt);

            inQueueSrc0.EnQue<T>(src0Local);
        } else {
            AscendC::LocalTensor<T> src0Local = inQueueSrc0.DeQue<T>();
            AscendC::LocalTensor<uint32_t> src1Local = inQueueSrc1.DeQue<uint32_t>();
            AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();
            if constexpr (scenarioNum == 2) {
                AscendC::Duplicate(dstLocal, static_cast<T>(0), OUTPUT_SIZE);

                mask = 70;
                // reduceMode = true;    使用Counter模式
                // src0BlockStride = 1;  单次迭代内数据间隔1个datablock，即数据连续读取和写入
                // repeatTimes = 2;      Counter模式时，仅在部分产品型号下会生效
                // src0RepeatStride = 4; 源操作数迭代间数据间隔4个datablock
                // src1RepeatStride = 0; src1迭代间数据间隔0个datablock，即原位置读取
                AscendC::GatherMask(dstLocal, src0Local, src1Local, true, mask, {1, 2, 4, 0}, rsvdCnt);
            } else if constexpr (scenarioNum == 3) {
                src0Local.SetSize(INPUT_Y_SIZE);
                AscendC::Gather(dstLocal, src0Local, src1Local, (uint32_t)0, INPUT_Y_SIZE);
            } else if constexpr (scenarioNum == 4) {
                AscendC::GatherRepeatParams params{1, 8};
                uint8_t repeatTime = INPUT_SIZE * sizeof(T) / 256; // 重复迭代次数
                AscendC::Gatherb<T>(dstLocal, src0Local, src1Local, repeatTime, params);
            }
            inQueueSrc0.FreeTensor(src0Local);
            inQueueSrc1.FreeTensor(src1Local);
            outQueueDst.EnQue(dstLocal);
        }
    }
    
    __aicore__ inline void CopyOut()
    {
        if constexpr (scenarioNum == 1) {
            AscendC::LocalTensor<T> dstLocal = inQueueSrc0.DeQue<T>();
            AscendC::DataCopy(dstGlobal, dstLocal, OUTPUT_SIZE);
            inQueueSrc0.FreeTensor(dstLocal);
        } else {
            AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
            AscendC::DataCopy(dstGlobal, dstLocal, OUTPUT_SIZE);
            outQueueDst.FreeTensor(dstLocal);
        } 
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, DEPTH> inQueueSrc0, inQueueSrc1;
    AscendC::TQue<AscendC::TPosition::VECOUT, DEPTH> outQueueDst;
    AscendC::GlobalTensor<T> src0Global, dstGlobal;
    AscendC::GlobalTensor<uint32_t> src1Global;
};

template <typename T>
__global__ __vector__ void gather_custom(GM_ADDR x, GM_ADDR y, GM_ADDR z)
{
    AscendC::TPipe pipe;
    KernelGather<T> op;
    op.Init(x, y, z, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    size_t inputByteSize, inputYByteSize, outputByteSize;
    if constexpr (scenarioNum == 1 || scenarioNum == 2) {
        inputByteSize = INPUT_SIZE * sizeof(uint32_t);
        inputYByteSize = INPUT_Y_SIZE * sizeof(uint32_t);
        outputByteSize = OUTPUT_SIZE * sizeof(uint32_t);
    } else if constexpr (scenarioNum == 3 || scenarioNum == 4) {
        inputByteSize = INPUT_SIZE * sizeof(uint16_t);
        inputYByteSize = INPUT_Y_SIZE * sizeof(uint32_t);
        outputByteSize = OUTPUT_SIZE * sizeof(uint16_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (scenarioNum == 1) {
        gather_custom<uint32_t><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, nullptr, zDevice);
    } else {
        aclrtMallocHost((void**)(&yHost), inputYByteSize);
        aclrtMalloc((void**)&yDevice, inputYByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/input_y.bin", inputYByteSize, yHost, inputYByteSize);
        aclrtMemcpy(yDevice, inputYByteSize, yHost, inputYByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        if constexpr (scenarioNum == 2) {
            gather_custom<uint32_t><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
        } else if constexpr (scenarioNum == 3 || scenarioNum == 4) {
            gather_custom<uint16_t><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
        }
    }
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    if constexpr (scenarioNum == 2 || scenarioNum == 3 || scenarioNum == 4) {
        aclrtFree(yDevice);
        aclrtFreeHost(yHost);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
