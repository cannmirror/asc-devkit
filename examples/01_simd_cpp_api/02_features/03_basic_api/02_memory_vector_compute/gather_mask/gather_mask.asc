/* !
 * \file gather_mask.asc
 * \brief 基于GatherMask实现从源操作数中选取元素写入目的操作数，支持内置固定模式和用户自定义模式两种场景
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1:内置固定模式，通过src1Pattern选择对应的二进制作为掩码，来获取数据
// 场景2:用户自定义模式，通过用户输入的src1Local对应的二进制作为掩码，来获取数据
constexpr uint32_t NUM_BLOCKS = 1;
constexpr size_t INPUT_SIZE = (scenarioNum == 1) ? 128 : 256;
constexpr size_t INPUT_Y_SIZE = (scenarioNum == 1) ? 0 : 32;
constexpr size_t OUTPUT_SIZE = (scenarioNum == 1) ? 128 : 256;

template<typename T>
class KernelGatherMask {
public:
    __aicore__ inline KernelGatherMask () {}
    __aicore__ inline void Init(__gm__ uint8_t* src0Gm, __gm__ uint8_t* src1Gm, __gm__ uint8_t* dstGm,
                                AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        src0Global.SetGlobalBuffer((__gm__ T*)src0Gm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(inQueueSrc0, 1, INPUT_SIZE * sizeof(T));
        pipe->InitBuffer(outQueueDst, 1, OUTPUT_SIZE * sizeof(T));

        if constexpr (scenarioNum == 2) {
            src1Global.SetGlobalBuffer((__gm__ T*)src1Gm);
            pipe->InitBuffer(inQueueSrc1, 1, INPUT_Y_SIZE * sizeof(T));
        }
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }
private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> src0Local = inQueueSrc0.AllocTensor<T>();
        AscendC::DataCopy(src0Local, src0Global, INPUT_SIZE);
        inQueueSrc0.EnQue(src0Local);
        
        if constexpr (scenarioNum == 2) {
            AscendC::LocalTensor<T> src1Local = inQueueSrc1.AllocTensor<T>();
            AscendC::DataCopy(src1Local, src1Global, INPUT_Y_SIZE);
            inQueueSrc1.EnQue(src1Local);
        }
    }
    __aicore__ inline void Compute()
    {
        uint32_t mask;
        uint64_t rsvdCnt = 0; // 用于保存筛选后保留下来的元素个数
        if constexpr (scenarioNum == 1) {
            AscendC::LocalTensor<T> src0Local = inQueueSrc0.DeQue<T>();
            AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();
            AscendC::Duplicate(dstLocal, (T)0, OUTPUT_SIZE);
    
            mask = 0; // normal模式下mask建议设置为0
            uint8_t src1Pattern = 2; // 内置固定模式，取值范围为[1,7]
            // reduceMode = false; 使用normal模式
            // src0BlockStride = 1; 单次迭代内数据间隔1个Block，即数据连续读取和写入
            // repeatTimes = 1;重复迭代一次
            // src0RepeatStride = 0;重复一次，故设置为0
            // src1RepeatStride = 0;重复一次，故设置为0
            AscendC::GatherMask(dstLocal, src0Local, src1Pattern, false, mask, { 1, 1, 0, 0 }, rsvdCnt);
    
            outQueueDst.EnQue<T>(dstLocal);
            inQueueSrc0.FreeTensor(src0Local);
        } else if constexpr (scenarioNum == 2) {
            AscendC::LocalTensor<T> src0Local = inQueueSrc0.DeQue<T>();
            AscendC::LocalTensor<T> src1Local = inQueueSrc1.DeQue<T>();
            AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();
            AscendC::Duplicate(dstLocal, static_cast<T>(0), OUTPUT_SIZE);

            mask = 70;
            // reduceMode = true;    使用Counter模式
            // src0BlockStride = 1;  单次迭代内数据间隔1个datablock，即数据连续读取和写入
            // repeatTimes = 2;      Counter模式时，仅在部分产品型号下会生效
            // src0RepeatStride = 4; 源操作数迭代间数据间隔4个datablock
            // src1RepeatStride = 0; src1迭代间数据间隔0个datablock，即原位置读取
            AscendC::GatherMask (dstLocal, src0Local, src1Local, true, mask, { 1, 2, 4, 0 }, rsvdCnt);

            outQueueDst.EnQue<T>(dstLocal);
            inQueueSrc0.FreeTensor(src0Local);
            inQueueSrc1.FreeTensor(src1Local);
        }
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, OUTPUT_SIZE);
        outQueueDst.FreeTensor(dstLocal);
    }
private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc0, inQueueSrc1;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<T> src0Global, src1Global, dstGlobal;
};

template <typename T>
__global__ __vector__ void gather_mask_custom(GM_ADDR x, GM_ADDR y, GM_ADDR z) 
{
    AscendC::TPipe pipe;
    KernelGatherMask<T> op;
    op.Init(x, y, z, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[]) 
{
    size_t inputByteSize, inputYByteSize, outputByteSize;
    if constexpr (scenarioNum == 1) {
        inputByteSize = INPUT_SIZE * sizeof(uint16_t);
        inputYByteSize = INPUT_Y_SIZE * sizeof(uint16_t);
        outputByteSize = OUTPUT_SIZE * sizeof(uint16_t);
    } else if constexpr (scenarioNum == 2) {
        inputByteSize = INPUT_SIZE * sizeof(uint32_t);
        inputYByteSize = INPUT_Y_SIZE * sizeof(uint32_t);
        outputByteSize = OUTPUT_SIZE * sizeof(uint32_t);
    }

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);
    

    if constexpr (scenarioNum == 1) {
        gather_mask_custom<uint16_t><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, nullptr, zDevice);
    } else if constexpr (scenarioNum == 2) {
        aclrtMallocHost((void **)(&yHost), inputYByteSize);
        aclrtMalloc((void **)&yDevice, inputYByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/input_y.bin", inputYByteSize, yHost, inputYByteSize);
        aclrtMemcpy(yDevice, inputYByteSize, yHost, inputYByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);
        gather_mask_custom<uint32_t><<<NUM_BLOCKS, nullptr, stream>>>(xDevice, yDevice, zDevice);
    }
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    if constexpr (scenarioNum == 2) {
        aclrtFree(yDevice);
        aclrtFreeHost(yHost);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
