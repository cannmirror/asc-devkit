/* !
 * \file block_reduce_min_max_sum.asc
 * \brief 演示BlockReduce类接口在多场景下的使用方法，支持通过编译参数切换BlockReduceMax、BlockReduceMin、BlockReduceSum场景，对每个datablock内所有元素进行归约运算（求最大值、最小值或求和）
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1：BlockReduceMax，输入[1, 128]，输出[1, 64]，每个datablock内求最大值
// 场景2：BlockReduceMin，输入[1, 128]，输出[1, 64]，每个datablock内求最小值
// 场景3：BlockReduceSum，输入[1, 128]，输出[1, 64]，每个datablock内求和
// 说明：128个元素=8个datablock，每个datablock输出1个归约结果，共8个有效结果存放在输出tensor前8个位置
constexpr uint32_t SRC_TOTAL_LENGTH = 128;
constexpr uint32_t DST_TOTAL_LENGTH = 64;

/**
 * @brief 归约样例的Kernel类，实现BlockReduceMax/Min/Sum功能，对每个datablock内所有元素进行归约运算
 */
class KernelReduce {
public:
    __aicore__ inline KernelReduce() {}
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ half*)src);
        dstGlobal.SetGlobalBuffer((__gm__ half*)dstGm);
        pipe->InitBuffer(inQueueSrc, 1, SRC_TOTAL_LENGTH * sizeof(half));
        pipe->InitBuffer(outQueueDst, 1, DST_TOTAL_LENGTH * sizeof(half));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }
private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.AllocTensor<half>();
        AscendC::DataCopy(srcLocal, srcGlobal, SRC_TOTAL_LENGTH);
        inQueueSrc.EnQue(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.DeQue<half>();
        AscendC::LocalTensor<half> dstLocal = outQueueDst.AllocTensor<half>();
        half zero(0);
        AscendC::Duplicate(dstLocal, zero, DST_TOTAL_LENGTH);
        int32_t mask = 256 / sizeof(half);
        int32_t repeat = 1;

        if constexpr (scenarioNum == 1) {
            // 场景1：BlockReduceMax，对每个datablock内所有元素求最大值
            // repeat = 1, 128 elements one repeat, 128 elements total
            // srcBlkStride = 1, no gap between blocks in one repeat
            // dstRepStride = 1, srcRepStride = 8, no gap between repeats
            AscendC::BlockReduceMax<half>(dstLocal, srcLocal, repeat, mask, 1, 1, 8);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：BlockReduceMin，对每个datablock内所有元素求最小值
            // repeat = 1, 128 elements one repeat, 128 elements total
            // srcBlkStride = 1, no gap between blocks in one repeat
            // dstRepStride = 1, srcRepStride = 8, no gap between repeats
            AscendC::BlockReduceMin<half>(dstLocal, srcLocal, repeat, mask, 1, 1, 8);
        } else if constexpr (scenarioNum == 3) {
            // 场景3：BlockReduceSum，对每个datablock内所有元素求和
            // repeat = 1, 128 elements one repeat, 128 elements total
            // srcBlkStride = 1, no gap between blocks in one repeat
            // dstRepStride = 1, srcRepStride = 8, no gap between repeats
            AscendC::BlockReduceSum<half>(dstLocal, srcLocal, repeat, mask, 1, 1, 8);
        }

        outQueueDst.EnQue<half>(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<half> dstLocal = outQueueDst.DeQue<half>();
        AscendC::DataCopy(dstGlobal, dstLocal, DST_TOTAL_LENGTH);
        outQueueDst.FreeTensor(dstLocal);
    }
private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<half> srcGlobal, dstGlobal;
};

__global__ __vector__ void block_reduce_custom(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    KernelReduce op;
    op.Init(x, y, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = SRC_TOTAL_LENGTH * sizeof(half);
    size_t outputByteSize = DST_TOTAL_LENGTH * sizeof(half);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&yHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    block_reduce_custom<<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
