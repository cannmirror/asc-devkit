/* !
 * \file data_copy_pad.asc
 * \brief 演示使用DataCopyPad和SetPadValue实现非32字节对齐数据搬运及填充功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

/**
 * @brief DataCopyPad样例的Kernel类，实现非32字节对齐数据搬运及填充功能
 */
class KernelDataCopyPad {
public:
    __aicore__ inline KernelDataCopyPad() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
    {
        srcGlobal.SetGlobalBuffer((__gm__ half *)srcGm, kDataSize);
        dstGlobal.SetGlobalBuffer((__gm__ half *)dstGm, kDataSize);
    }

    __aicore__ inline void Process()
    {
        AscendC::LocalTensor<half> srcLocal(AscendC::TPosition::VECIN, srcAddr, kDataSize);
        AscendC::LocalTensor<half> dstLocal(AscendC::TPosition::VECOUT, dstAddr, kDataSize);

        AscendC::DataCopyExtParams copyInParams{1, 20 * sizeof(half), 0, 0, 0};
        AscendC::DataCopyPadExtParams<half> padParams;
        padParams.isPad = false;
        padParams.leftPadding = 0;
        padParams.rightPadding = 12;
        AscendC::SetPadValue((half)1);
        AscendC::DataCopyPad(srcLocal, srcGlobal, copyInParams, padParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        AscendC::Adds(dstLocal, srcLocal, scalar, kDataSize);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopyExtParams copyOutParams{1, 32 * sizeof(half), 0, 0, 0};
        AscendC::DataCopyPad(dstGlobal, dstLocal, copyOutParams);
    }

private:
    const uint32_t kDataSize = 32;
    uint64_t srcAddr = 0;
    uint64_t dstAddr = static_cast<uint64_t>(kDataSize) * sizeof(half);
    AscendC::GlobalTensor<half> srcGlobal;
    AscendC::GlobalTensor<half> dstGlobal;
    half scalar = 0;
};

__global__ __vector__ void data_copy_pad_custom(GM_ADDR x, GM_ADDR z)
{
    AscendC::InitSocState();
    KernelDataCopyPad op;
    op.Init(x, z);
    op.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = 32 * sizeof(half);
    size_t outputByteSize = inputByteSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    data_copy_pad_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    size_t inputByteSize2 = 32 * 32 * sizeof(half);
    size_t outputByteSize2 = inputByteSize2;

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
