/* !
 * \file cast_tensor_api.asc
 * \brief 基于 Tensor API 的 Transform<Inst::Cast, Trait> 实现数据类型转换
 */

#include <cstdint>
#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <algorithm>
#include "acl/acl.h"
#include "data_utils.h"
#include "tensor_api/tensor.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "include/utils/debug/asc_dump.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// ===================== Cast Trait 定义 =====================

template <typename RoundMode, typename SatMode, typename IndexPos>
struct CastTrait {
    using roundMode = RoundMode;
    using satMode   = SatMode;
    using indexPos  = IndexPos;
};

// 场景1 trait: half -> int32_t, floor 舍入 (RD), 不饱和
using CastTraitF16S32 = CastTrait<
    AscendC::Te::CastRoundMode::RD,
    AscendC::Te::CastSatMode::NoSat,
    AscendC::Std::ignore_t>;

// 场景2 trait: float -> int16_t, round 舍入 (RN), 饱和
using CastTraitF32S16 = CastTrait<
    AscendC::Te::CastRoundMode::RN,
    AscendC::Te::CastSatMode::Sat,
    AscendC::Std::ignore_t>;

// 场景3 trait: int8_t -> int32_t, floor 舍入 (RD), 不饱和, 4:1 扩展, PartP0
using CastTraitS8S32 = CastTrait<
    AscendC::Te::CastRoundMode::RD,
    AscendC::Te::CastSatMode::NoSat,
    AscendC::Te::CastIndexPos::PartP0>;

// 场景4 trait: int32_t -> uint8_t, floor 舍入 (RD), 饱和, 4:1 收缩, PartP0
using CastTraitS32U8 = CastTrait<
    AscendC::Std::ignore_t,
    AscendC::Te::CastSatMode::Sat,
    AscendC::Te::CastIndexPos::PartP0>;

// 场景5 trait: bfloat16_t -> float, 1:2 扩宽, Even
using CastTraitBf162F32 = CastTrait<
    AscendC::Std::ignore_t,
    AscendC::Std::ignore_t,
    AscendC::Te::CastIndexPos::Even>;

// 场景6 trait: float -> bfloat16_t, round 舍入 (RN), 不饱和, 2:1 收缩, Even
using CastTraitF322Bf16 = CastTrait<
    AscendC::Te::CastRoundMode::RN,
    AscendC::Te::CastSatMode::NoSat,
    AscendC::Te::CastIndexPos::Even>;

// ===================== Kernel =====================
template <typename SrcT, typename DstT>
class Kernel{
public:
    __aicore__ inline void process(__gm__ SrcT* x, __gm__ DstT* y, int32_t row, int32_t col)
    {
        using namespace AscendC::Te;
        auto xGm = MakeTensor(
            MakeMemPtr<Location::GM>(x),
            MakeFrameLayout<NDExtLayoutPtn>(row, col));
        auto yGm = MakeTensor(
            MakeMemPtr<Location::GM>(y),
            MakeFrameLayout<NDExtLayoutPtn>(row, col));

        // 2. UB addr offset
        uint32_t ubInputXOffset = 0;
        uint32_t ubInputYOffset = row * col * sizeof(SrcT);

        auto xUb = MakeTensor(
            MakeMemPtr<Location::UB, SrcT>(ubInputXOffset),
            MakeFrameLayout<NDExtLayoutPtn>(row, col));
        auto yUb = MakeTensor(
            MakeMemPtr<Location::UB, DstT>(ubInputYOffset),
            MakeFrameLayout<NDExtLayoutPtn>(row, col));

        // 3. CopyIn: GM -> UB
        auto copyInAtom = MakeCopy(CopyGM2UB{});
        Copy(copyInAtom, xUb, xGm);

        asc_dump_ubuf(xUb.Data().Get(), 1, 256);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // 4. Compute: Cast via Transform
        if constexpr (scenarioNum == 1) {
            // half -> int32_t: floor 舍入, 不饱和
            Transform<Inst::Cast, CastTraitF16S32>(yUb, xUb);
        } else if constexpr (scenarioNum == 2) {
            // float -> int16_t: round 舍入, 饱和
            Transform<Inst::Cast, CastTraitF32S16>(yUb, xUb);
        } else if constexpr (scenarioNum == 3) {
            // int8_t -> int32_t: floor 舍入, 不饱和, 4:1 扩展
            Transform<Inst::Cast, CastTraitS8S32>(yUb, xUb);
        } else if constexpr (scenarioNum == 4) {
            // int32_t -> uint8_t: floor 舍入, 饱和, 4:1 收缩
            Transform<Inst::Cast, CastTraitS32U8>(yUb, xUb);
        } else if constexpr (scenarioNum == 5) {
            // bfloat16_t -> float: 1:2 扩宽
            Transform<Inst::Cast, CastTraitBf162F32>(yUb, xUb);
        } else {
            // float -> bfloat16_t: round 舍入, 不饱和, 2:1 收缩
            Transform<Inst::Cast, CastTraitF322Bf16>(yUb, xUb);
        }

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        asc_dump_ubuf(yUb.Data().Get(), 1, 256);
        // 5. CopyOut: UB -> GM
        auto copyOutAtom = MakeCopy(CopyUB2GM{});
        Copy(copyOutAtom, yGm, yUb);
        
    }
};


template <typename SrcT, typename DstT>
__global__ __vector__ void cast_tensor_api(__gm__ uint8_t* x, __gm__ uint8_t* y, uint32_t row, uint32_t col)
{
        // half -> int32_t: floor 舍入, 不饱和
    Kernel<SrcT, DstT> kernel;
    kernel.process(reinterpret_cast<__gm__ SrcT*>(x), reinterpret_cast<__gm__ DstT*>(y), row, col);
}

// ===================== Host 端 =====================

template <typename DstT>
static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        aclrtFreeHost(goldenData);
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    if constexpr (std::is_same_v<DstT, bfloat16_t>) {
        // bfloat16_t 在 host CPU 端构造被删除，用 uint16_t bit pattern 比较
        const auto* outPtr = static_cast<const uint16_t*>(outputData);
        const auto* goldPtr = static_cast<const uint16_t*>(goldenData);
        for (size_t i = 0; i < outSize / sizeof(uint16_t); i++) {
            if (outPtr[i] != goldPtr[i]) {
                if (wrongNum < 100) {
                    printf("Mismatch[%zu]: output=0x%04x, golden=0x%04x\n",
                           i, outPtr[i], goldPtr[i]);
                }
                wrongNum++;
            }
        }
    } else {
        for (size_t i = 0; i < outSize / sizeof(DstT); i++) {
            DstT a = (reinterpret_cast<const DstT*>(outputData))[i];
            DstT b = (reinterpret_cast<const DstT*>(goldenData))[i];
            float ae = std::abs(static_cast<float>(a - b));
            float re = (std::abs(static_cast<float>(b)) > EPS)
                       ? ae / std::abs(static_cast<float>(b)) : ae;
            if (ae > EPS && re > EPS) {
                if (wrongNum < 100) {
                    printf("Mismatch[%zu]: output=%f, golden=%f\n", i,
                           static_cast<double>(static_cast<float>(a)),
                           static_cast<double>(static_cast<float>(b)));
                }
                wrongNum++;
            }
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}


int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t ROW = 16;
    constexpr uint32_t col = 16;
    constexpr uint32_t totalLength = ROW * col;
    size_t inputByteSize;
    size_t outputByteSize;

    if constexpr (scenarioNum == 1) {
        inputByteSize  = totalLength * sizeof(half);
        outputByteSize = totalLength * sizeof(int32_t);
    } else if constexpr (scenarioNum == 2) {
        inputByteSize  = totalLength * sizeof(float);
        outputByteSize = totalLength * sizeof(int16_t);
    } else if constexpr (scenarioNum == 3) {
        inputByteSize  = totalLength * sizeof(int8_t);
        outputByteSize = totalLength * sizeof(int32_t);
    } else if constexpr (scenarioNum == 4) {
        inputByteSize  = totalLength * sizeof(int32_t);
        outputByteSize = totalLength * sizeof(uint8_t);
    } else if constexpr (scenarioNum == 5) {
        inputByteSize  = totalLength * sizeof(bfloat16_t);
        outputByteSize = totalLength * sizeof(float);
    } else if constexpr (scenarioNum == 6) {
        inputByteSize  = totalLength * sizeof(float);
        outputByteSize = totalLength * sizeof(bfloat16_t);
    } else {
        printf("[Error] SCENARIO_NUM must be 1, 2, 3, 4, 5, or 6.\n");
        return 0;
    }

    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;
    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);
    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if constexpr (scenarioNum == 1) {
        cast_tensor_api<half, int32_t><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    } else if constexpr (scenarioNum == 2) {
        cast_tensor_api<float, int16_t><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    } else if constexpr (scenarioNum == 3) {
        cast_tensor_api<int8_t, int32_t><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    } else if constexpr (scenarioNum == 4) {
        cast_tensor_api<int32_t, uint8_t><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    } else if constexpr (scenarioNum == 5) {
        cast_tensor_api<bfloat16_t, float><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    } else {
        cast_tensor_api<float, bfloat16_t><<<numBlocks, 0, stream>>>(xDevice, yDevice, ROW, col);
    }

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    bool goldenResult;
    if constexpr (scenarioNum == 1) {
        goldenResult = CompareResult<int32_t>(yHost, outputByteSize);
    } else if constexpr (scenarioNum == 2) {
        goldenResult = CompareResult<int16_t>(yHost, outputByteSize);
    } else if constexpr (scenarioNum == 3) {
        goldenResult = CompareResult<int32_t>(yHost, outputByteSize);
    } else if constexpr (scenarioNum == 4) {
        goldenResult = CompareResult<uint8_t>(yHost, outputByteSize);
    } else if constexpr (scenarioNum == 5) {
        goldenResult = CompareResult<float>(yHost, outputByteSize);
    } else {
        goldenResult = CompareResult<bfloat16_t>(yHost, outputByteSize);
    }
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
