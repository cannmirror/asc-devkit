/* !
 * \file axpy_half_half_tensor_api.asc
 * \brief 基于 Tensor API 的 Transform<Inst::Axpy> 实现 axpy(half->half) 计算
 */

#include <cstdint>
#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <algorithm>
#include "acl/acl.h"
#include "data_utils.h"
#include "tensor_api/tensor.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "include/utils/debug/asc_dump.h"


constexpr uint32_t TOTAL_LENGTH = 512;

// ===================== Kernel =====================
class KernelAxpy {
public:
    __aicore__ inline void Process(__gm__ half* srcGm, __gm__ half* dstGm)
    {
        using namespace AscendC::Te;

        // 1. 创建 GM Tensor
        auto srcGmTensor = MakeTensor(
            MakeMemPtr<Location::GM>(srcGm),
            MakeFrameLayout<NDExtLayoutPtn>(_16{}, _32{}));
        auto dstGmTensor = MakeTensor(
            MakeMemPtr<Location::GM>(dstGm),
            MakeFrameLayout<NDExtLayoutPtn>(_16{}, _32{}));

        // 2. 创建 UB Tensor (计算偏移量)
        uint32_t ubInputOffset = 0;
        uint32_t ubOutputOffset = TOTAL_LENGTH * sizeof(half);

        auto srcUbTensor = MakeTensor(
            MakeMemPtr<Location::UB, half>(ubInputOffset),
            MakeFrameLayout<NDExtLayoutPtn>(_16{}, _32{}));
        auto dstUbTensor = MakeTensor(
            MakeMemPtr<Location::UB, half>(ubOutputOffset),
            MakeFrameLayout<NDExtLayoutPtn>(_16{}, _32{}));

        // 3. CopyIn: GM -> UB
        auto copyInAtom = MakeCopy(CopyGM2UB{});
        Copy(copyInAtom, srcUbTensor, srcGmTensor);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // 先将 dst 清零
        Transform<Inst::MulScalar>(dstUbTensor, dstUbTensor, (half)0.0);
        // 4. Compute: Axpy 计算 dst = src * 2.0 + dst
        Transform<Inst::Axpy>(dstUbTensor, srcUbTensor, (half)2.0);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // 5. CopyOut: UB -> GM
        auto copyOutAtom = MakeCopy(CopyUB2GM{});
        Copy(copyOutAtom, dstGmTensor, dstUbTensor);
    }
};

__global__ __vector__ void kernel_axpy_half_half_tensor_api(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
{
    KernelAxpy op;
    op.Process(reinterpret_cast<__gm__ half*>(srcGm), reinterpret_cast<__gm__ half*>(dstGm));
}

static bool CheckAcl(aclError ret, const char* apiName)
{
    if (ret != ACL_SUCCESS) {
        ERROR_LOG("%s failed, errorCode = %d", apiName, static_cast<int32_t>(ret));
        return false;
    }
    return true;
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 8;
    size_t inputByteSize = 4 * 128 * sizeof(uint16_t);
    size_t outputByteSize = 4 * 128 * sizeof(uint16_t);

    int32_t retCode = -1;
    bool aclInited = false;
    bool deviceSet = false;
    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    uint8_t* xHost = nullptr;
    uint8_t* outHost = nullptr;
    uint8_t* xDevice = nullptr;
    uint8_t* outDevice = nullptr;

    if (!CheckAcl(aclInit(nullptr), "aclInit")) {
        return retCode;
    }
    aclInited = true;

    if (!CheckAcl(aclrtSetDevice(deviceId), "aclrtSetDevice")) {
        goto cleanup;
    }
    deviceSet = true;

    if (!CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        goto cleanup;
    }

    if (!CheckAcl(aclrtMallocHost((void**)(&xHost), inputByteSize), "aclrtMallocHost xHost")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtMallocHost((void**)(&outHost), outputByteSize), "aclrtMallocHost outHost")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST),
        "aclrtMalloc xDevice")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtMalloc((void**)&outDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST),
        "aclrtMalloc outDevice")) {
        goto cleanup;
    }

    if (!ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize)) {
        ERROR_LOG("Read input_x.bin failed");
        goto cleanup;
    }
    if (!CheckAcl(aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE),
        "aclrtMemcpy xHost to xDevice")) {
        goto cleanup;
    }

    kernel_axpy_half_half_tensor_api<<<numBlocks, nullptr, stream>>>(xDevice, outDevice);
    if (!CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream")) {
        goto cleanup;
    }

    if (!CheckAcl(aclrtMemcpy(outHost, outputByteSize, outDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST),
        "aclrtMemcpy outDevice to outHost")) {
        goto cleanup;
    }
    if (!WriteFile("./output/output.bin", outHost, outputByteSize)) {
        ERROR_LOG("Write output.bin failed");
        goto cleanup;
    }

    retCode = 0;

cleanup:
    if (outDevice != nullptr && !CheckAcl(aclrtFree(outDevice), "aclrtFree outDevice")) {
        retCode = -1;
    }
    if (xDevice != nullptr && !CheckAcl(aclrtFree(xDevice), "aclrtFree xDevice")) {
        retCode = -1;
    }
    if (outHost != nullptr && !CheckAcl(aclrtFreeHost(outHost), "aclrtFreeHost outHost")) {
        retCode = -1;
    }
    if (xHost != nullptr && !CheckAcl(aclrtFreeHost(xHost), "aclrtFreeHost xHost")) {
        retCode = -1;
    }
    if (stream != nullptr && !CheckAcl(aclrtDestroyStream(stream), "aclrtDestroyStream")) {
        retCode = -1;
    }
    if (deviceSet && !CheckAcl(aclrtResetDevice(deviceId), "aclrtResetDevice")) {
        retCode = -1;
    }
    if (aclInited && !CheckAcl(aclFinalize(), "aclFinalize")) {
        retCode = -1;
    }

    return retCode;
}
