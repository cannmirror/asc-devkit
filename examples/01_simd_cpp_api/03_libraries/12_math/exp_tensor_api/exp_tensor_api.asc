/* !
 * \file exp_tensor_api.asc
 * \brief 基于 Tensor API 的 Transform<Inst::Exp> 实现按元素取自然指数
 */

#include <cstdint>
#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <algorithm>
#include "acl/acl.h"
#include "data_utils.h"
#include "tensor_api/tensor.h"
#include "basic_api/kernel_operator_block_sync_intf.h"
#include "include/utils/debug/asc_dump.h"


constexpr uint32_t TOTAL_LENGTH = 8192;

// ===================== Kernel =====================
template <typename T>
class KernelExp {
public:
    __aicore__ inline void Process(__gm__ T* srcGm, __gm__ T* dstGm)
    {
        using namespace AscendC::Te;

        // 1. 创建 GM Tensor
        auto srcGmTensor = MakeTensor(
            MakeMemPtr<Location::GM>(srcGm),
            MakeFrameLayout<NDExtLayoutPtn>(_64{}, _128{}));
        auto dstGmTensor = MakeTensor(
            MakeMemPtr<Location::GM>(dstGm),
            MakeFrameLayout<NDExtLayoutPtn>(_64{}, _128{}));

        // 2. 创建 UB Tensor
        uint32_t ubInputOffset = 0;
        uint32_t ubOutputOffset = TOTAL_LENGTH * sizeof(T);

        auto srcUbTensor = MakeTensor(
            MakeMemPtr<Location::UB, T>(ubInputOffset),
            MakeFrameLayout<NDExtLayoutPtn>(_64{}, _128{}));
        auto dstUbTensor = MakeTensor(
            MakeMemPtr<Location::UB, T>(ubOutputOffset),
            MakeFrameLayout<NDExtLayoutPtn>(_64{}, _128{}));

        // 3. CopyIn: GM -> UB
        auto copyInAtom = MakeCopy(CopyGM2UB{});
        Copy(copyInAtom, srcUbTensor, srcGmTensor);

        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // 4. Compute: Exp via Transform
        Transform<Inst::Exp>(dstUbTensor, srcUbTensor);

        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // 5. CopyOut: UB -> GM
        auto copyOutAtom = MakeCopy(CopyUB2GM{});
        Copy(copyOutAtom, dstGmTensor, dstUbTensor);
    }
};

template <typename T>
__global__ __vector__ void exp_tensor_api_custom(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm)
{
    KernelExp<T> op;
    op.Process(reinterpret_cast<__gm__ T*>(srcGm), reinterpret_cast<__gm__ T*>(dstGm));
}

// ===================== Host 端 =====================

static bool CheckAcl(aclError ret, const char* apiName)
{
    if (ret != ACL_SUCCESS) {
        ERROR_LOG("%s failed, errorCode = %d", apiName, static_cast<int32_t>(ret));
        return false;
    }
    return true;
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData = nullptr;
    if (!CheckAcl(aclrtMallocHost((void**)(&goldenData), outSize), "aclrtMallocHost goldenData")) {
        return false;
    }
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        (void)CheckAcl(aclrtFreeHost(goldenData), "aclrtFreeHost goldenData");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float absB = std::abs(b);
        float re = (absB > EPS) ? (ae / absB) : ae;
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    bool freeRet = CheckAcl(aclrtFreeHost(goldenData), "aclrtFreeHost goldenData");
    if (wrongNum != 0) {
        return false;
    } else if (!freeRet) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    size_t param1FileSize = TOTAL_LENGTH * sizeof(float);
    size_t param2FileSize = TOTAL_LENGTH * sizeof(float);
    uint32_t numBlocks = 1;

    int32_t retCode = -1;
    bool aclInited = false;
    bool deviceSet = false;
    aclrtContext context = nullptr;
    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    uint8_t* param1Host = nullptr;
    uint8_t* param1Device = nullptr;
    uint8_t* param2Host = nullptr;
    uint8_t* param2Device = nullptr;
    bool goldenResult = true;

    if (!CheckAcl(aclInit(nullptr), "aclInit")) {
        return retCode;
    }
    aclInited = true;

    if (!CheckAcl(aclrtSetDevice(deviceId), "aclrtSetDevice")) {
        goto cleanup;
    }
    deviceSet = true;

    if (!CheckAcl(aclrtCreateContext(&context, deviceId), "aclrtCreateContext")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        goto cleanup;
    }

    if (!CheckAcl(aclrtMallocHost((void**)(&param1Host), param1FileSize), "aclrtMallocHost param1Host")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtMalloc((void**)&param1Device, param1FileSize, ACL_MEM_MALLOC_HUGE_FIRST),
        "aclrtMalloc param1Device")) {
        goto cleanup;
    }
    if (!ReadFile("./input/input_x.bin", param1FileSize, param1Host, param1FileSize)) {
        ERROR_LOG("Read input_x.bin failed");
        goto cleanup;
    }
    if (!CheckAcl(aclrtMemcpy(param1Device, param1FileSize, param1Host, param1FileSize,
        ACL_MEMCPY_HOST_TO_DEVICE), "aclrtMemcpy param1Host to param1Device")) {
        goto cleanup;
    }

    if (!CheckAcl(aclrtMallocHost((void**)(&param2Host), param2FileSize), "aclrtMallocHost param2Host")) {
        goto cleanup;
    }
    if (!CheckAcl(aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST),
        "aclrtMalloc param2Device")) {
        goto cleanup;
    }

    exp_tensor_api_custom<float><<<numBlocks, nullptr, stream>>>(param1Device, param2Device);
    if (!CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream")) {
        goto cleanup;
    }

    if (!CheckAcl(aclrtMemcpy(param2Host, param2FileSize, param2Device, param2FileSize,
        ACL_MEMCPY_DEVICE_TO_HOST), "aclrtMemcpy param2Device to param2Host")) {
        goto cleanup;
    }
    if (!WriteFile("./output/output.bin", param2Host, param2FileSize)) {
        ERROR_LOG("Write output.bin failed");
        goto cleanup;
    }

    goldenResult = CompareResult(param2Host, param2FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    retCode = goldenResult ? 0 : -1;

cleanup:
    if (param2Device != nullptr && !CheckAcl(aclrtFree(param2Device), "aclrtFree param2Device")) {
        retCode = -1;
    }
    if (param1Device != nullptr && !CheckAcl(aclrtFree(param1Device), "aclrtFree param1Device")) {
        retCode = -1;
    }
    if (param2Host != nullptr && !CheckAcl(aclrtFreeHost(param2Host), "aclrtFreeHost param2Host")) {
        retCode = -1;
    }
    if (param1Host != nullptr && !CheckAcl(aclrtFreeHost(param1Host), "aclrtFreeHost param1Host")) {
        retCode = -1;
    }
    if (stream != nullptr && !CheckAcl(aclrtDestroyStream(stream), "aclrtDestroyStream")) {
        retCode = -1;
    }
    if (context != nullptr && !CheckAcl(aclrtDestroyContext(context), "aclrtDestroyContext")) {
        retCode = -1;
    }
    if (deviceSet && !CheckAcl(aclrtResetDevice(deviceId), "aclrtResetDevice")) {
        retCode = -1;
    }
    if (aclInited && !CheckAcl(aclFinalize(), "aclFinalize")) {
        retCode = -1;
    }

    return retCode;
}
