/**
 * @file softmaxflashv3.asc
 * @brief 基于SoftmaxFlashV3高阶API实现FlashAttention V3中的Softmax变体计算
 *
 * SoftmaxFlashV3 是 FlashAttention V3 中使用的 Softmax 变体，相比 FlashV2：
 *   - 支持传入预计算的最大值(inMax)、指数和(inSum)、均值(inMean)
 *   - 通过 isInner 模板参数控制是否使用内部共享临时缓冲区
 *   - 分核计算逻辑：将 height 维度按 baseM 切分为多个块，每块独立计算
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"
#include "tiling/tiling_api.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

// ============================================================================
// Tiling 定义
// ============================================================================

namespace optiling {
BEGIN_TILING_DATA_DEF(SoftmaxFlashV3CustomTilingData)
TILING_DATA_FIELD_DEF(uint32_t, height);
TILING_DATA_FIELD_DEF(uint32_t, width);
TILING_DATA_FIELD_DEF(uint32_t, elementNumPerBlk1);
TILING_DATA_FIELD_DEF(uint32_t, elementNumPerBlk2);
TILING_DATA_FIELD_DEF(uint32_t, loopCnt);
TILING_DATA_FIELD_DEF(uint32_t, splitMeanCnt);
TILING_DATA_FIELD_DEF(float, alpha);
TILING_DATA_FIELD_DEF(uint32_t, tmpBufSize);
TILING_DATA_FIELD_DEF(uint32_t, coreRowNum);
TILING_DATA_FIELD_DEF(uint32_t, tailCoreRowNum);
TILING_DATA_FIELD_DEF(uint32_t, usedNumBlocks);
END_TILING_DATA_DEF;

REGISTER_TILING_DATA_CLASS(SoftmaxFlashV3Custom, SoftmaxFlashV3CustomTilingData)
} // namespace optiling

namespace SoftmaxFlashV3CustomTiling {

/**
 * @brief 计算SoftmaxFlashV3算子的Tiling参数
 *
 * 采用"平均分配法"将输入 Tensor 的行均匀分配给多个 Core。
 */
void ComputeTiling(
    const uint32_t height, const uint32_t width, const uint32_t loopCnt, const uint32_t splitMeanCnt, const float alpha,
    const uint32_t coreNum, optiling::SoftmaxFlashV3CustomTilingData& tiling)
{
    tiling.set_height(height);
    tiling.set_width(width);
    tiling.set_elementNumPerBlk1(32 / sizeof(float));
    tiling.set_elementNumPerBlk2(32 / sizeof(half));
    tiling.set_loopCnt(loopCnt);
    tiling.set_splitMeanCnt(splitMeanCnt);
    tiling.set_alpha(alpha);

    // 平均分配法分核
    auto alignedRowNum = (height + coreNum - 1) / coreNum * coreNum;
    auto coreRowNum = alignedRowNum / coreNum;
    auto tailCoreRowNum = height % coreRowNum;
    auto usedNumBlocks = height / coreRowNum;

    tiling.set_coreRowNum(coreRowNum);
    tiling.set_tailCoreRowNum(tailCoreRowNum);
    tiling.set_usedNumBlocks(usedNumBlocks);

    // 获取 SoftMaxFlashV3 所需的最小临时缓冲区大小
    ge::Shape softmaxComputeShape({coreRowNum, width});
    uint32_t maxValue = 0;
    uint32_t minValue = 0;
    AscendC::GetSoftMaxFlashV3MaxMinTmpSize(
        softmaxComputeShape, sizeof(half), sizeof(float), maxValue, minValue, false, false);
    tiling.set_tmpBufSize(minValue);
}
} // namespace SoftmaxFlashV3CustomTiling

/**
 * @brief 生成Tiling数据并序列化到buffer
 */
void GenerateTiling(
    const uint32_t height, const uint32_t width, const uint32_t loopCnt, const uint32_t splitMeanCnt, const float alpha,
    const uint32_t coreNum, const uint32_t tilingSize, uint8_t* tilingBuffer)
{
    optiling::SoftmaxFlashV3CustomTilingData tiling;
    SoftmaxFlashV3CustomTiling::ComputeTiling(height, width, loopCnt, splitMeanCnt, alpha, coreNum, tiling);
    tiling.SaveToBuffer(tilingBuffer, tilingSize);
}

namespace AscendC {

/**
 * @brief Device端Tiling数据结构
 */
struct SoftmaxFlashV3VecTiling {
    uint32_t height = 0;
    uint32_t width = 0;
    uint32_t elementNumPerBlk1 = 0;
    uint32_t elementNumPerBlk2 = 0;
    uint32_t loopCnt = 0;
    uint32_t splitMeanCnt = 0;
    float alpha = 0;
    uint32_t tmpBufSize = 0;
    uint32_t coreRowNum = 0;
    uint32_t tailCoreRowNum = 0;
    uint32_t usedNumBlocks = 0;
};

/**
 * @brief SoftmaxFlashV3算子的Kernel实现类
 *
 * 模板参数: T=输入输出类型(half), U=中间计算类型(float)
 * 计算流程: CopyIn -> Compute -> CopyOut
 */
template <typename T, typename U>
class KernelSoftmaxFlash {
public:
    __aicore__ inline KernelSoftmaxFlash() {}

    __aicore__ inline void InitTiling(const SoftmaxFlashV3VecTiling& tilingData)
    {
        height = tilingData.height;
        width = tilingData.width;
        elementNumPerBlk1 = tilingData.elementNumPerBlk1;
        elementNumPerBlk2 = tilingData.elementNumPerBlk2;
        loopCnt = tilingData.loopCnt;
        splitMeanCnt = tilingData.splitMeanCnt;
        alpha = tilingData.alpha;
        this->tmpBufSize = tilingData.tmpBufSize;
        coreRowNum = tilingData.coreRowNum;
        tailCoreRowNum = tilingData.tailCoreRowNum;
        usedNumBlocks = tilingData.usedNumBlocks;
    }

    /**
     * @brief 初始化 Kernel 参数
     */
    __aicore__ inline void Init(
        GM_ADDR srcGm, GM_ADDR inMaxGm, GM_ADDR inSumGm, GM_ADDR inMeanGm, GM_ADDR dstGm,
        const SoftmaxFlashV3VecTiling& tilingData, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        InitTiling(tilingData);

        // 分核逻辑：计算每个 Core 处理的数据偏移
        uint32_t blockLength = coreRowNum * width;
        uint32_t msLength = coreRowNum * elementNumPerBlk1;
        uint32_t offset1 = blockLength * AscendC::GetBlockIdx();
        uint32_t offset2 = msLength * AscendC::GetBlockIdx();

        // 绑定Global Memory缓冲区
        srcGlobal.SetGlobalBuffer((__gm__ T*)srcGm + offset1, blockLength);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm + offset1, blockLength);
        maxGlobal.SetGlobalBuffer((__gm__ U*)inMaxGm + offset2, msLength);
        sumGlobal.SetGlobalBuffer((__gm__ U*)inSumGm + offset2, msLength);
        meanGlobal.SetGlobalBuffer((__gm__ U*)inMeanGm + offset2, msLength);

        // 分配Local Memory缓冲区
        pipe->InitBuffer(inQueueSrc, 1, coreRowNum * width * sizeof(T));
        pipe->InitBuffer(maxQueue, 1, coreRowNum * elementNumPerBlk1 * sizeof(U));
        pipe->InitBuffer(sumQueue, 1, coreRowNum * elementNumPerBlk1 * sizeof(U));
        pipe->InitBuffer(meanQueue, 1, coreRowNum * elementNumPerBlk1 * sizeof(U));
        pipe->InitBuffer(expMaxQueue, 1, coreRowNum * elementNumPerBlk2 * sizeof(T));
        pipe->InitBuffer(outQueueDst, 1, coreRowNum * width * sizeof(T));
        if (this->tmpBufSize > 0) {
            pipe->InitBuffer(tmpQueue, this->tmpBufSize);
        }
    }

    /**
     * @brief 执行计算流程
     *
     * 分核逻辑：
     * - 超出实际使用范围的 Core 直接返回
     * - Tail Core（最后一个 Core）处理剩余行数
     */
    __aicore__ inline void Process()
    {
        // 分核逻辑：超出实际使用范围的 Core 直接返回
        if (AscendC::GetBlockIdx() > usedNumBlocks) {
            return;
        }

        // 分核逻辑：Tail Core 使用 tailCoreRowNum 处理剩余行
        uint32_t processRowNum = coreRowNum;
        if (AscendC::GetBlockIdx() == usedNumBlocks && tailCoreRowNum > 0) {
            processRowNum = tailCoreRowNum;
        }

        CopyIn(processRowNum);
        Compute(processRowNum);
        CopyOut(processRowNum);
    }

private:
    /**
     * @brief 将输入数据从全局内存搬运到本地内存
     */
    __aicore__ inline void CopyIn(uint32_t rowNum)
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.AllocTensor<T>();
        AscendC::LocalTensor<U> insumLocal = sumQueue.AllocTensor<U>();
        AscendC::LocalTensor<U> inmaxLocal = maxQueue.AllocTensor<U>();
        AscendC::LocalTensor<U> inmeanLocal = meanQueue.AllocTensor<U>();

        AscendC::DataCopy(srcLocal, srcGlobal, rowNum * width);
        AscendC::DataCopy(insumLocal, sumGlobal, rowNum * elementNumPerBlk1);
        AscendC::DataCopy(inmaxLocal, maxGlobal, rowNum * elementNumPerBlk1);
        AscendC::DataCopy(inmeanLocal, meanGlobal, rowNum * elementNumPerBlk1);

        inQueueSrc.EnQue(srcLocal);
        sumQueue.EnQue(insumLocal);
        maxQueue.EnQue(inmaxLocal);
        meanQueue.EnQue(inmeanLocal);
    }

    /**
     * @brief 执行 SoftmaxFlashV3 核心计算
     *
     * 按 baseM 切分 height 维度，每块独立计算 Softmax。
     */
    __aicore__ inline void Compute(uint32_t rowNum)
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.DeQue<T>();
        AscendC::LocalTensor<U> insumLocal = sumQueue.DeQue<U>();
        AscendC::LocalTensor<U> inmaxLocal = maxQueue.DeQue<U>();
        AscendC::LocalTensor<U> inmeanLocal = meanQueue.DeQue<U>();
        AscendC::LocalTensor<T> expMaxTensor = expMaxQueue.AllocTensor<T>();
        AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();

        // 设置 ShapeInfo
        const uint32_t shapeDim = 2;
        uint32_t array[2] = {rowNum, width};
        srcLocal.SetShapeInfo(ShapeInfo(shapeDim, array));
        array[1] = elementNumPerBlk1;
        insumLocal.SetShapeInfo(ShapeInfo(shapeDim, array));
        inmaxLocal.SetShapeInfo(ShapeInfo(shapeDim, array));
        inmeanLocal.SetShapeInfo(ShapeInfo(shapeDim, array));
        array[1] = elementNumPerBlk2;
        expMaxTensor.SetShapeInfo(ShapeInfo(shapeDim, array));

        AscendC::SoftMaxParams params = {rowNum, width, rowNum, width, loopCnt, splitMeanCnt, alpha};

        // 按 baseM 切分 height 维度，每块独立计算
        uint32_t baseM = 10 * 1024 / (8 * 5 + 1024 * 2 + 64);
        baseM = min(baseM, rowNum);
        if (baseM < rowNum && baseM > 8) {
            baseM = baseM / 8 * 8;
        }
        uint32_t last = rowNum / baseM;
        uint32_t tail = rowNum % baseM;

        SoftMaxTiling tilingData = {
            rowNum, width, rowNum * width, rowNum,  elementNumPerBlk1, rowNum * elementNumPerBlk1,
            baseM,  width, baseM * width,  baseM,   elementNumPerBlk1, baseM * elementNumPerBlk1,
            last,   tail,  tail * width,   tail * 8};

        // 调用 SoftmaxFlashV3 接口
        AscendC::LocalTensor<uint8_t> sharedTmpBuffer;
        if (this->tmpBufSize > 0) {
            sharedTmpBuffer = tmpQueue.Get<uint8_t>();
            AscendC::SoftmaxFlashV3<T, U, true>(
                dstLocal, inmeanLocal, insumLocal, inmaxLocal, srcLocal, expMaxTensor, inmeanLocal, insumLocal,
                inmaxLocal, sharedTmpBuffer, tilingData, params);
        } else {
            AscendC::SoftmaxFlashV3<T, U, true>(
                dstLocal, inmeanLocal, insumLocal, inmaxLocal, srcLocal, expMaxTensor, inmeanLocal, insumLocal,
                inmaxLocal, tilingData, params);
        }

        outQueueDst.EnQue<T>(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
        maxQueue.FreeTensor(inmaxLocal);
        sumQueue.FreeTensor(insumLocal);
        meanQueue.FreeTensor(inmeanLocal);
    }

    /**
     * @brief 将计算结果从本地内存搬运到全局内存
     */
    __aicore__ inline void CopyOut(uint32_t rowNum)
    {
        AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
        AscendC::DataCopy(dstGlobal, dstLocal, rowNum * width);
        outQueueDst.FreeTensor(dstLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> meanQueue;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> maxQueue;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> sumQueue;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> expMaxQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::TBuf<AscendC::TPosition::VECCALC> tmpQueue;

    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::GlobalTensor<U> meanGlobal;
    AscendC::GlobalTensor<U> maxGlobal;
    AscendC::GlobalTensor<U> sumGlobal;

    uint32_t elementNumPerBlk1 = 0;
    uint32_t elementNumPerBlk2 = 0;
    uint32_t width = 0;
    uint32_t height = 0;
    uint32_t loopCnt = 0;
    uint32_t splitMeanCnt = 0;
    float alpha = 0;
    uint32_t tmpBufSize = 0;
    uint32_t coreRowNum = 0;
    uint32_t tailCoreRowNum = 0;
    uint32_t usedNumBlocks = 0;
};
} // namespace AscendC

/**
 * @brief 从GM拷贝Tiling数据到Device端结构体
 */
__aicore__ inline void CopyTiling(AscendC::SoftmaxFlashV3VecTiling* tiling, GM_ADDR tilingGM)
{
    uint32_t* ptr = reinterpret_cast<uint32_t*>(tiling);
    auto tiling32 = reinterpret_cast<__gm__ uint32_t*>(tilingGM);
    for (int i = 0; i < sizeof(AscendC::SoftmaxFlashV3VecTiling) / sizeof(uint32_t); i++, ptr++) {
        *ptr = *(tiling32 + i);
    }
}

/**
 * @brief Kernel入口函数
 *
 * 模板参数: T=half, U=float
 */
__global__ __vector__ void softmaxflashv3_custom(
    GM_ADDR srcGm, GM_ADDR inMaxGm, GM_ADDR inSumGm, GM_ADDR inMeanGm, GM_ADDR dstGm, GM_ADDR tiling)
{
    AscendC::TPipe pipe;
    AscendC::SoftmaxFlashV3VecTiling tilingData;
    CopyTiling(&tilingData, tiling);
    AscendC::KernelSoftmaxFlash<half, float> op;
    op.Init(srcGm, inMaxGm, inSumGm, inMeanGm, dstGm, tilingData, &pipe);
    op.Process();
}

// ============================================================================
// Host 端
// ============================================================================

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;
    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }
    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }
    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        printf("wrongNum: %ld\n", wrongNum);
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    constexpr uint32_t height = 8;
    constexpr uint32_t width = 2048;
    constexpr uint32_t loopCnt = 2;
    constexpr uint32_t splitMeanCnt = 8;
    constexpr float alpha = 0.9375;

    size_t tilingFileSize = sizeof(AscendC::SoftmaxFlashV3VecTiling);
    size_t param2FileSize = height * width * sizeof(half);
    size_t param3FileSize = height * 8 * sizeof(float);
    size_t param4FileSize = height * 8 * sizeof(float);
    size_t param5FileSize = height * 8 * sizeof(float);
    size_t param6FileSize = height * width * sizeof(half);

    aclInit(nullptr);
    aclrtContext context;
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    // 分配Host/Device内存并拷贝Tiling数据
    uint8_t* tilingHost;
    uint8_t* tilingDevice;
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    GenerateTiling(height, width, loopCnt, splitMeanCnt, alpha, numBlocks, tilingFileSize, tilingHost);
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingHost, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配Host/Device内存并拷贝输入数据src
    uint8_t* param2Host;
    uint8_t* param2Device;
    aclrtMallocHost((void**)(&param2Host), param2FileSize);
    aclrtMalloc((void**)&param2Device, param2FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input.bin", param2FileSize, param2Host, param2FileSize);
    aclrtMemcpy(param2Device, param2FileSize, param2Host, param2FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配Host/Device内存并拷贝输入数据inputMax
    uint8_t* param3Host;
    uint8_t* param3Device;
    aclrtMallocHost((void**)(&param3Host), param3FileSize);
    aclrtMalloc((void**)&param3Device, param3FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/inputMax.bin", param3FileSize, param3Host, param3FileSize);
    aclrtMemcpy(param3Device, param3FileSize, param3Host, param3FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配Host/Device内存并拷贝输入数据inputSum
    uint8_t* param4Host;
    uint8_t* param4Device;
    aclrtMallocHost((void**)(&param4Host), param4FileSize);
    aclrtMalloc((void**)&param4Device, param4FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/inputSum.bin", param4FileSize, param4Host, param4FileSize);
    aclrtMemcpy(param4Device, param4FileSize, param4Host, param4FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配Host/Device内存并拷贝输入数据inputMean
    uint8_t* param5Host;
    uint8_t* param5Device;
    aclrtMallocHost((void**)(&param5Host), param5FileSize);
    aclrtMalloc((void**)&param5Device, param5FileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/inputMean.bin", param5FileSize, param5Host, param5FileSize);
    aclrtMemcpy(param5Device, param5FileSize, param5Host, param5FileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    // 分配输出数据的Host/Device内存
    uint8_t* param6Host;
    uint8_t* param6Device;
    aclrtMallocHost((void**)(&param6Host), param6FileSize);
    aclrtMalloc((void**)&param6Device, param6FileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    // 执行Kernel
    softmaxflashv3_custom<<<numBlocks, nullptr, stream>>>(
        param2Device, param3Device, param4Device, param5Device, param6Device, tilingDevice);
    aclrtSynchronizeStream(stream);

    // 释放输入和Tiling的Device/Host内存
    aclrtFree(tilingDevice);
    aclrtFreeHost(tilingHost);
    aclrtFree(param2Device);
    aclrtFreeHost(param2Host);
    aclrtFree(param3Device);
    aclrtFreeHost(param3Host);
    aclrtFree(param4Device);
    aclrtFreeHost(param4Host);
    aclrtFree(param5Device);
    aclrtFreeHost(param5Host);

    // 拷贝输出结果到Host并写入文件
    aclrtMemcpy(param6Host, param6FileSize, param6Device, param6FileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/golden_output_output.bin", param6Host, param6FileSize);

    // 比较结果
    bool goldenResult = CompareResult(param6Host, param6FileSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    // 释放输出内存和ACL资源
    aclrtFree(param6Device);
    aclrtFreeHost(param6Host);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
