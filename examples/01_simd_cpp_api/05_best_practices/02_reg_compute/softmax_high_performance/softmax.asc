/* !
 * \file softmax.asc
 * \brief Softmax operator performance tuning sample (Case 0-5)
 *
 * Softmax formula:
 * Softmax(x_i) = e^(x_i - max) / sum(e^(x_j - max))
 * Shape: [128, 128], dtype: float
 */

#include <iostream>
#include <cstdint>

#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// ---- Common: fp32MinValue ---------------------------------------------------
namespace Custom {
union DataUnion {
    constexpr __aicore__ DataUnion() : f(0.0f) {}
    constexpr __aicore__ DataUnion(uint32_t val) : i(val) {}
    float f;
    uint32_t i;
};
constexpr DataUnion fp32MinValue(0x00800000u);
} // namespace Custom

namespace Custom {
template <typename T>
struct SoftmaxTiling {
    uint32_t aDim = 0;
    uint32_t lastADim = 0;
    uint32_t rDim = 0;
    uint32_t rDimAlign = 0;
    uint32_t loopCount = 0;
    uint32_t singleCoreLength = 0;
    uint32_t singleCoreAlignLength = 0;
    T tData;
};
} // namespace Custom

// ---- Common: Load/Store helpers (used by Case 2-5) -----------------------------
#if SCENARIO_NUM >= 2
template <typename T, typename U, typename V>
__simd_callee__ inline void LoadWithCastIfNeed(__ubuf__ T* srcAddr, U& dstReg, V& mask, uint32_t offset)
{
    if constexpr (AscendC::IsSameType<T, half>::value) {
        static constexpr AscendC::Reg::CastTrait layoutHalf2Float = {
            AscendC::Reg::RegLayout::ZERO, AscendC::Reg::SatMode::UNKNOWN, AscendC::Reg::MaskMergeMode::ZEROING,
            AscendC::RoundMode::UNKNOWN};
        AscendC::Reg::RegTensor<half> srcReg;
        AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(srcReg, srcAddr + offset);
        AscendC::Reg::Cast<float, T, layoutHalf2Float>(dstReg, srcReg, mask);
    } else {
        AscendC::Reg::LoadAlign(dstReg, srcAddr + offset);
    }
}

template <typename T, typename U, typename V>
__simd_callee__ inline void StoreWithCastIfNeed(__ubuf__ T* dstAddr, U& srcReg, V& mask, uint32_t offset)
{
    if constexpr (AscendC::IsSameType<T, half>::value) {
        static constexpr AscendC::Reg::CastTrait layoutFloat2Half = {
            AscendC::Reg::RegLayout::ZERO, AscendC::Reg::SatMode::NO_SAT, AscendC::Reg::MaskMergeMode::ZEROING,
            AscendC::RoundMode::CAST_RINT};
        AscendC::Reg::RegTensor<half> dstReg;
        AscendC::Reg::Cast<T, float, layoutFloat2Half>(dstReg, srcReg, mask);
        AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(dstAddr + offset, dstReg, mask);
    } else {
        AscendC::Reg::StoreAlign(dstAddr + offset, srcReg, mask);
    }
}
#endif

// ======================= Case 0: MemBase, single loop ============================
#if SCENARIO_NUM == 0
template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    for (uint32_t i = 0; i < aDim; i++) {
        if constexpr (AscendC::IsSameType<T, half>::value) {
            AscendC::Cast(sumTensor[i * rDimAlign], srcTensor[i * rDimAlign], AscendC::RoundMode::CAST_NONE, rDim);
            AscendC::ReduceMax(expTensor[i * rDimAlign], sumTensor[i * rDimAlign], sumTensor[i * rDimAlign], rDim);
        } else {
            AscendC::ReduceMax(expTensor[i * rDimAlign], srcTensor[i * rDimAlign], sumTensor[i * rDimAlign], rDim);
        }
        AscendC::Duplicate(expTensor[i * rDimAlign], expTensor[i * rDimAlign], rDim);
        if constexpr (AscendC::IsSameType<T, half>::value) {
            AscendC::Sub(expTensor[i * rDimAlign], sumTensor[i * rDimAlign], expTensor[i * rDimAlign], rDim);
        } else {
            AscendC::Sub(expTensor[i * rDimAlign], srcTensor[i * rDimAlign], expTensor[i * rDimAlign], rDim);
        }
        AscendC::Exp(expTensor[i * rDimAlign], expTensor[i * rDimAlign], rDim);
        AscendC::ReduceSum(
            sumTensor[i * rDimAlign], expTensor[i * rDimAlign],
            dstTensor[i * rDimAlign].template ReinterpretCast<float>(), rDim);
        AscendC::Duplicate(sumTensor[i * rDimAlign], sumTensor[i * rDimAlign], rDim);
        if constexpr (AscendC::IsSameType<T, half>::value) {
            AscendC::Div(expTensor[i * rDimAlign], expTensor[i * rDimAlign], sumTensor[i * rDimAlign], rDim);
            AscendC::Cast(dstTensor[i * rDimAlign], expTensor[i * rDimAlign], AscendC::RoundMode::CAST_FLOOR, rDim);
        } else {
            AscendC::Div(dstTensor[i * rDimAlign], expTensor[i * rDimAlign], sumTensor[i * rDimAlign], rDim);
        }
    }
}
#endif

// ======================= Case 1: RegBase, no fusion, redundant Ld/St/sync ========
#if SCENARIO_NUM == 1
template <typename T>
__simd_vf__ inline void CustomSoftmaxVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ float* expAddr, __ubuf__ float* sumAddr, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    // Phase 1: ReduceMax
    for (uint32_t i = 0; i < aDim; i++) {
        if constexpr (AscendC::IsSameType<T, half>::value) {
            // Cast:
            {
                constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
                uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
                uint32_t count = rDim;
                AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
                AscendC::Reg::MaskReg mask;
                AscendC::Reg::RegTensor<T> srcReg;
                AscendC::Reg::RegTensor<float> dstReg;
                for (uint16_t j = 0; j < repeatTimes; j++) {
                    mask = AscendC::Reg::UpdateMask<float>(count);
                    AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
                        srcReg, srcAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::Cast<float, T, AscendC::layoutZMrgZ>(dstReg, srcReg, mask);
                    AscendC::Reg::StoreAlign(sumAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
                }
                AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
            }
            // Reduce:
            {
                constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
                uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
                uint32_t count = rDim;
                AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
                AscendC::Reg::MaskReg maskOne = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::VL1>();
                AscendC::Reg::MaskReg mask;
                AscendC::Reg::RegTensor<float> srcReg;
                AscendC::Reg::RegTensor<float> maxReg;
                AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
                for (uint16_t j = 0; j < repeatTimes; j++) {
                    mask = AscendC::Reg::UpdateMask<float>(count);
                    AscendC::Reg::LoadAlign(srcReg, sumAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::Max(maxReg, maxReg, srcReg, maskFull);
                }
                AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
                AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_FIRST_ELEMENT_B32>(
                    expAddr + i * rDimAlign, maxReg, maskOne);
                AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
            }
        } else {
            // Reduce:
            {
                constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
                uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
                uint32_t count = rDim;
                AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
                AscendC::Reg::MaskReg maskOne = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::VL1>();
                AscendC::Reg::MaskReg mask;
                AscendC::Reg::RegTensor<float> srcReg;
                AscendC::Reg::RegTensor<float> maxReg;
                AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
                for (uint16_t j = 0; j < repeatTimes; j++) {
                    mask = AscendC::Reg::UpdateMask<float>(count);
                    AscendC::Reg::LoadAlign(srcReg, srcAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::Max(maxReg, maxReg, srcReg, maskFull);
                }
                AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
                AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_FIRST_ELEMENT_B32>(
                    expAddr + i * rDimAlign, maxReg, maskOne);
                AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
            }
        }
    }

    // Phase 2: Duplicate + Sub + Exp + ReduceSum
    for (uint32_t i = 0; i < aDim; i++) {
        // Duplicate
        {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> dstReg;
            AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign);
            AscendC::Reg::Duplicate(dstReg, srcReg, maskFull);
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::StoreAlign(expAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
        // Sub
        if constexpr (AscendC::IsSameType<T, half>::value) {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> dstReg;
            AscendC::Reg::RegTensor<float> maxReg;
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::RegTensor<T> srcOrigin;
                AscendC::Reg::LoadAlign<T, AscendC::Reg::LoadDist::DIST_UNPACK_B16>(
                    srcOrigin, srcAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Cast<float, T, AscendC::layoutZMrgZ>(srcReg, srcOrigin, mask);
                AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Sub(dstReg, srcReg, maxReg, mask);
                AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        } else {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> dstReg;
            AscendC::Reg::RegTensor<float> maxReg;
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::LoadAlign(srcReg, srcAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Sub(dstReg, srcReg, maxReg, mask);
                AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
        // Exp
        {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> dstReg;
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Exp(dstReg, srcReg, mask);
                AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
        // ReduceSum
        {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
            AscendC::Reg::MaskReg maskOne = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::VL1>();
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> sumReg;
            AscendC::Reg::Duplicate(sumReg, 0.0, maskFull);
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Add<float, AscendC::Reg::MaskMergeMode::MERGING>(sumReg, sumReg, srcReg, mask);
            }
            AscendC::Reg::ReduceSum(sumReg, sumReg, maskFull);
            AscendC::Reg::StoreAlign<float, AscendC::Reg::StoreDist::DIST_FIRST_ELEMENT_B32>(
                sumAddr + i * rDimAlign, sumReg, maskOne);
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
    }
    // Phase 3: Duplicate + Div
    for (uint32_t i = 0; i < aDim; i++) {
        // Duplicate
        {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> srcReg;
            AscendC::Reg::RegTensor<float> dstReg;
            AscendC::Reg::LoadAlign(srcReg, sumAddr + i * rDimAlign);
            AscendC::Reg::Duplicate(dstReg, srcReg, maskFull);
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::StoreAlign(sumAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
        if constexpr (AscendC::IsSameType<T, half>::value) {
            // Div
            {
                constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
                uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
                uint32_t count = rDim;
                AscendC::Reg::MaskReg mask;
                AscendC::Reg::RegTensor<float> maxReg;
                AscendC::Reg::RegTensor<float> sumReg;
                AscendC::Reg::RegTensor<float> divReg;
                for (uint16_t j = 0; j < repeatTimes; j++) {
                    mask = AscendC::Reg::UpdateMask<float>(count);
                    AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::LoadAlign(sumReg, sumAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::Div(divReg, maxReg, sumReg, mask);
                    AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, divReg, mask);
                }
                AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
            }
            // Cast
            {
                constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
                uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
                uint32_t count = rDim;
                AscendC::Reg::MaskReg mask;
                AscendC::Reg::RegTensor<float> srcReg;
                AscendC::Reg::RegTensor<T> dstReg;
                for (uint16_t j = 0; j < repeatTimes; j++) {
                    mask = AscendC::Reg::UpdateMask<float>(count);
                    AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                    AscendC::Reg::Cast<T, float, AscendC::LayoutZMrgZRndRSatNS>(dstReg, srcReg, mask);
                    AscendC::Reg::StoreAlign<T, AscendC::Reg::StoreDist::DIST_PACK_B32>(
                        dstAddr + i * rDimAlign + j * oneRepeatSize, dstReg, mask);
                }
                AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
            }
        } else {
            constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
            uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
            uint32_t count = rDim;
            AscendC::Reg::MaskReg mask;
            AscendC::Reg::RegTensor<float> maxReg;
            AscendC::Reg::RegTensor<float> sumReg;
            AscendC::Reg::RegTensor<float> divReg;
            for (uint16_t j = 0; j < repeatTimes; j++) {
                mask = AscendC::Reg::UpdateMask<float>(count);
                AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::LoadAlign(sumReg, sumAddr + i * rDimAlign + j * oneRepeatSize);
                AscendC::Reg::Div(divReg, maxReg, sumReg, mask);
                AscendC::Reg::StoreAlign<float>(dstAddr + i * rDimAlign + j * oneRepeatSize, divReg, mask);
            }
            AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_ALL, AscendC::Reg::MemType::VEC_ALL>();
        }
    }
}

template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(srcTensor.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(dstTensor.GetPhyAddr());
    __ubuf__ float* expAddr = reinterpret_cast<__ubuf__ float*>(expTensor.GetPhyAddr());
    __ubuf__ float* sumAddr = reinterpret_cast<__ubuf__ float*>(sumTensor.GetPhyAddr());

    CustomSoftmaxVF(yAddr, xAddr, expAddr, sumAddr, aDim, rDim, rDimAlign);
}
#endif

// ======================= Case 2: RegBase, UpdateMask, ExpSub, loop fusion ========
#if SCENARIO_NUM == 2
template <typename T>
__simd_vf__ inline void CustomSoftmaxVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ float* expAddr, __ubuf__ float* sumAddr, uint16_t aDim,
    uint16_t rDim, uint16_t rDimAlign)
{
    constexpr uint16_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
    AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::MaskReg mask;
    AscendC::Reg::RegTensor<float> srcReg;
    AscendC::Reg::RegTensor<float> maxReg;
    AscendC::Reg::RegTensor<float> expReg;
    AscendC::Reg::RegTensor<float> sumReg;
    AscendC::Reg::RegTensor<float> divReg;

    // Phase 1: ReduceMax + ExpSub (loop fusion:共享Load)
    for (uint16_t i = 0; i < aDim; i++) {
        uint32_t count1 = rDim;
        AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count1);
            LoadWithCastIfNeed(srcAddr, srcReg, mask, i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Max<float, AscendC::Reg::MaskMergeMode::MERGING>(maxReg, maxReg, srcReg, mask);
        }
        AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
        AscendC::Reg::Duplicate(maxReg, maxReg, maskFull);
        uint32_t count2 = rDim;

        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count2);
            LoadWithCastIfNeed(srcAddr, srcReg, mask, i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::ExpSub(expReg, srcReg, maxReg, mask);
            AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, expReg, mask);
        }
    }
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_LOAD, AscendC::Reg::MemType::VEC_STORE>();
    for (uint16_t i = 0; i < aDim; i++) {
        uint32_t count3 = rDim;
        AscendC::Reg::Duplicate(sumReg, 0.0, maskFull);
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count3);
            AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Add<float, AscendC::Reg::MaskMergeMode::MERGING>(sumReg, sumReg, srcReg, mask);
        }
        AscendC::Reg::ReduceSum(sumReg, sumReg, maskFull);
        AscendC::Reg::Duplicate(sumReg, sumReg, maskFull);
        uint32_t count4 = rDim;
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count4);
            AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Div(divReg, maxReg, sumReg, mask);
            StoreWithCastIfNeed(dstAddr, divReg, mask, i * rDimAlign + j * oneRepeatSize);
        }
    }
}

template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(srcTensor.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(dstTensor.GetPhyAddr());
    __ubuf__ float* expAddr = reinterpret_cast<__ubuf__ float*>(expTensor.GetPhyAddr());
    __ubuf__ float* sumAddr = reinterpret_cast<__ubuf__ float*>(sumTensor.GetPhyAddr());

    CustomSoftmaxVF(yAddr, xAddr, expAddr, sumAddr, aDim, rDim, rDimAlign);
}
#endif

// ======================= Case 3: RegBase, UpdateMask, outer loop unrolling =======
#if SCENARIO_NUM == 3
template <typename T>
__simd_vf__ inline void CustomSoftmaxVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ float* expAddr, __ubuf__ float* sumAddr, uint16_t aDim,
    uint16_t rDim, uint16_t rDimAlign)
{
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    uint16_t repeatTimes = AscendC::CeilDivision(rDim, oneRepeatSize);
    AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::MaskReg mask;
    AscendC::Reg::RegTensor<float> srcReg;
    AscendC::Reg::RegTensor<float> maxReg;
    AscendC::Reg::RegTensor<float> expReg;
    AscendC::Reg::RegTensor<float> sumReg;
    AscendC::Reg::RegTensor<float> divReg;

    AscendC::Reg::MaskReg mask1;
    AscendC::Reg::RegTensor<float> srcReg1;
    AscendC::Reg::RegTensor<float> maxReg1;
    AscendC::Reg::RegTensor<float> expReg1;
    AscendC::Reg::RegTensor<float> sumReg1;
    AscendC::Reg::RegTensor<float> divReg1;

    uint16_t halfA = aDim >> 1;

    // Phase 1: ReduceMax + ExpSub (outer loop unrolled: 2 rows/iter)
    for (uint16_t i = 0; i < halfA; i++) {
        uint32_t count = rDim;
        AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
        AscendC::Reg::Duplicate(maxReg1, Custom::fp32MinValue.f, maskFull);
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count);
            LoadWithCastIfNeed(srcAddr, srcReg, mask, i * rDimAlign + j * oneRepeatSize);
            LoadWithCastIfNeed(srcAddr, srcReg1, mask, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Max<float, AscendC::Reg::MaskMergeMode::MERGING>(maxReg, maxReg, srcReg, mask);
            AscendC::Reg::Max<float, AscendC::Reg::MaskMergeMode::MERGING>(maxReg1, maxReg1, srcReg1, mask);
        }
        AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
        AscendC::Reg::ReduceMax(maxReg1, maxReg1, maskFull);
        AscendC::Reg::Duplicate(maxReg, maxReg, maskFull);
        AscendC::Reg::Duplicate(maxReg1, maxReg1, maskFull);
        uint32_t count0 = rDim;

        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count0);
            LoadWithCastIfNeed(srcAddr, srcReg, mask, i * rDimAlign + j * oneRepeatSize);
            LoadWithCastIfNeed(srcAddr, srcReg1, mask, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::ExpSub(expReg, srcReg, maxReg, mask);
            AscendC::Reg::ExpSub(expReg1, srcReg1, maxReg1, mask);
            AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, expReg, mask);
            AscendC::Reg::StoreAlign<float>(
                expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign, expReg1, mask);
        }
    }
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_LOAD, AscendC::Reg::MemType::VEC_STORE>();
    for (uint16_t i = 0; i < halfA; i++) {
        uint32_t count1 = rDim;
        AscendC::Reg::Duplicate(sumReg, 0.0, maskFull);
        AscendC::Reg::Duplicate(sumReg1, 0.0, maskFull);
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count1);
            AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::LoadAlign(srcReg1, expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Add<float, AscendC::Reg::MaskMergeMode::MERGING>(sumReg, sumReg, srcReg, mask);
            AscendC::Reg::Add<float, AscendC::Reg::MaskMergeMode::MERGING>(sumReg1, sumReg1, srcReg1, mask);
        }
        AscendC::Reg::ReduceSum(sumReg, sumReg, maskFull);
        AscendC::Reg::ReduceSum(sumReg1, sumReg1, maskFull);
        AscendC::Reg::Duplicate(sumReg, sumReg, maskFull);
        AscendC::Reg::Duplicate(sumReg1, sumReg1, maskFull);
        uint32_t count2 = rDim;
        for (uint16_t j = 0; j < repeatTimes; j++) {
            mask = AscendC::Reg::UpdateMask<float>(count2);
            AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::LoadAlign(maxReg1, expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Div(divReg, maxReg, sumReg, mask);
            AscendC::Reg::Div(divReg1, maxReg1, sumReg1, mask);
            StoreWithCastIfNeed(dstAddr, divReg, mask, i * rDimAlign + j * oneRepeatSize);
            StoreWithCastIfNeed(dstAddr, divReg1, mask, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
        }
    }
}

template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(srcTensor.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(dstTensor.GetPhyAddr());
    __ubuf__ float* expAddr = reinterpret_cast<__ubuf__ float*>(expTensor.GetPhyAddr());
    __ubuf__ float* sumAddr = reinterpret_cast<__ubuf__ float*>(sumTensor.GetPhyAddr());

    CustomSoftmaxVF(yAddr, xAddr, expAddr, sumAddr, aDim, rDim, rDimAlign);
}
#endif

// ======================= Case 4: RegBase, main-tail block ========================
#if SCENARIO_NUM == 4
template <typename T>
__simd_vf__ inline void CustomSoftmaxVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ float* expAddr, __ubuf__ float* sumAddr, uint16_t aDim,
    uint16_t rDim, uint16_t rDimAlign, uint16_t tail, uint16_t repeatTimesMain, uint16_t hasTail)
{
    constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::MaskReg mask = maskFull;
    AscendC::Reg::RegTensor<float> srcReg;
    AscendC::Reg::RegTensor<float> maxReg;
    AscendC::Reg::RegTensor<float> expReg;
    AscendC::Reg::RegTensor<float> sumReg;
    AscendC::Reg::RegTensor<float> divReg;

    // Phase 1: ReduceMax + ExpSub (main-tail block mode)
    for (uint16_t i = 0; i < aDim; i++) {
        AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            LoadWithCastIfNeed(srcAddr, srcReg, maskFull, i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Max(maxReg, maxReg, srcReg, maskFull);
        }
        AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
        AscendC::Reg::Duplicate(maxReg, maxReg, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            LoadWithCastIfNeed(srcAddr, srcReg, maskFull, i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::ExpSub(expReg, srcReg, maxReg, maskFull);
            AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, expReg, maskFull);
        }
    }
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_LOAD, AscendC::Reg::MemType::VEC_STORE>();
    for (uint16_t i = 0; i < aDim; i++) {
        AscendC::Reg::Duplicate(sumReg, 0.0, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Add<float>(sumReg, sumReg, srcReg, maskFull);
        }
        AscendC::Reg::ReduceSum(sumReg, sumReg, maskFull);
        AscendC::Reg::Duplicate(sumReg, sumReg, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::Div(divReg, maxReg, sumReg, mask);
            StoreWithCastIfNeed(dstAddr, divReg, mask, i * rDimAlign + j * oneRepeatSize);
        }
    }
}

template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(srcTensor.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(dstTensor.GetPhyAddr());
    __ubuf__ float* expAddr = reinterpret_cast<__ubuf__ float*>(expTensor.GetPhyAddr());
    __ubuf__ float* sumAddr = reinterpret_cast<__ubuf__ float*>(sumTensor.GetPhyAddr());

    uint16_t tail = rDim % (256 / sizeof(float));
    uint16_t repeatTimesMain = rDim / (256 / sizeof(float));
    uint16_t hasTail = static_cast<uint16_t>(tail != 0);

    CustomSoftmaxVF(yAddr, xAddr, expAddr, sumAddr, aDim, rDim, rDimAlign, tail, repeatTimesMain, hasTail);
}
#endif

// ======================= Case 5: RegBase, main-tail + unroll + ExpSub ============
#if SCENARIO_NUM == 5
template <typename T>
__simd_vf__ inline void CustomSoftmaxVF(
    __ubuf__ T* dstAddr, __ubuf__ T* srcAddr, __ubuf__ float* expAddr, __ubuf__ float* sumAddr, uint16_t aDim,
    uint16_t rDim, uint16_t rDimAlign, uint16_t tail, uint16_t repeatTimesMain, uint16_t hasTail)
{
    constexpr uint16_t oneRepeatSize = AscendC::GetVecLen() / sizeof(float);
    AscendC::Reg::MaskReg maskFull = AscendC::Reg::CreateMask<T, AscendC::Reg::MaskPattern::ALL>();

    AscendC::Reg::MaskReg mask = maskFull;
    AscendC::Reg::RegTensor<float> srcReg;
    AscendC::Reg::RegTensor<float> maxReg;
    AscendC::Reg::RegTensor<float> expReg;
    AscendC::Reg::RegTensor<float> sumReg;
    AscendC::Reg::RegTensor<float> divReg;

    AscendC::Reg::RegTensor<float> srcReg1;
    AscendC::Reg::RegTensor<float> maxReg1;
    AscendC::Reg::RegTensor<float> expReg1;
    AscendC::Reg::RegTensor<float> sumReg1;
    AscendC::Reg::RegTensor<float> divReg1;

    uint16_t halfA = aDim >> 1;

    // Phase 1: ReduceMax + ExpSub (outer loop unrolled + main-tail)
    for (uint16_t i = 0; i < halfA; i++) {
        AscendC::Reg::Duplicate(maxReg, Custom::fp32MinValue.f, maskFull);
        AscendC::Reg::Duplicate(maxReg1, Custom::fp32MinValue.f, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            LoadWithCastIfNeed(srcAddr, srcReg, maskFull, i * rDimAlign + j * oneRepeatSize);
            LoadWithCastIfNeed(srcAddr, srcReg1, maskFull, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Max(maxReg, maxReg, srcReg, maskFull);
            AscendC::Reg::Max(maxReg1, maxReg1, srcReg1, maskFull);
        }
        AscendC::Reg::ReduceMax(maxReg, maxReg, maskFull);
        AscendC::Reg::ReduceMax(maxReg1, maxReg1, maskFull);
        AscendC::Reg::Duplicate(maxReg, maxReg, maskFull);
        AscendC::Reg::Duplicate(maxReg1, maxReg1, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            LoadWithCastIfNeed(srcAddr, srcReg, maskFull, i * rDimAlign + j * oneRepeatSize);
            LoadWithCastIfNeed(srcAddr, srcReg1, maskFull, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);

            AscendC::Reg::ExpSub(expReg, srcReg, maxReg, maskFull);
            AscendC::Reg::ExpSub(expReg1, srcReg1, maxReg1, maskFull);
            AscendC::Reg::StoreAlign<float>(expAddr + i * rDimAlign + j * oneRepeatSize, expReg, maskFull);
            AscendC::Reg::StoreAlign<float>(
                expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign, expReg1, maskFull);
        }
    }
    AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_LOAD, AscendC::Reg::MemType::VEC_STORE>();
    for (uint16_t i = 0; i < halfA; i++) {
        AscendC::Reg::Duplicate(sumReg, 0.0, maskFull);
        AscendC::Reg::Duplicate(sumReg1, 0.0, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            AscendC::Reg::LoadAlign(srcReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::LoadAlign(srcReg1, expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Add<float>(sumReg, sumReg, srcReg, maskFull);
            AscendC::Reg::Add<float>(sumReg1, sumReg1, srcReg1, maskFull);
        }
        AscendC::Reg::ReduceSum(sumReg, sumReg, maskFull);
        AscendC::Reg::ReduceSum(sumReg1, sumReg1, maskFull);
        AscendC::Reg::Duplicate(sumReg, sumReg, maskFull);
        AscendC::Reg::Duplicate(sumReg1, sumReg1, maskFull);
        for (uint16_t j = 0; j < repeatTimesMain; j++) {
            AscendC::Reg::LoadAlign(maxReg, expAddr + i * rDimAlign + j * oneRepeatSize);
            AscendC::Reg::LoadAlign(maxReg1, expAddr + i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
            AscendC::Reg::Div(divReg, maxReg, sumReg, maskFull);
            AscendC::Reg::Div(divReg1, maxReg1, sumReg1, maskFull);
            StoreWithCastIfNeed(dstAddr, divReg, maskFull, i * rDimAlign + j * oneRepeatSize);
            StoreWithCastIfNeed(dstAddr, divReg1, maskFull, i * rDimAlign + j * oneRepeatSize + halfA * rDimAlign);
        }
    }
}

template <typename T>
__aicore__ inline void CustomSoftmax(
    const AscendC::LocalTensor<T>& dstTensor, const AscendC::LocalTensor<T>& srcTensor,
    const AscendC::LocalTensor<float>& expTensor, const AscendC::LocalTensor<float>& sumTensor, uint32_t aDim,
    uint32_t rDim, uint32_t rDimAlign)
{
    __ubuf__ T* xAddr = reinterpret_cast<__ubuf__ T*>(srcTensor.GetPhyAddr());
    __ubuf__ T* yAddr = reinterpret_cast<__ubuf__ T*>(dstTensor.GetPhyAddr());
    __ubuf__ float* expAddr = reinterpret_cast<__ubuf__ float*>(expTensor.GetPhyAddr());
    __ubuf__ float* sumAddr = reinterpret_cast<__ubuf__ float*>(sumTensor.GetPhyAddr());

    uint16_t tail = rDim % (256 / sizeof(float));
    uint16_t repeatTimesMain = rDim / (256 / sizeof(float));
    uint16_t hasTail = static_cast<uint16_t>(tail != 0);

    CustomSoftmaxVF(yAddr, xAddr, expAddr, sumAddr, aDim, rDim, rDimAlign, tail, repeatTimesMain, hasTail);
}
#endif

template <typename T>
__global__ __vector__ void softmax_custom(__gm__ uint8_t* x, __gm__ uint8_t* y, Custom::SoftmaxTiling<T> tiling)
{
    AscendC::TPipe tPipe;
    AscendC::InitSocState();

    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    xGm.SetGlobalBuffer((__gm__ T*)x + AscendC::GetBlockIdx() * tiling.singleCoreLength, tiling.singleCoreLength);
    yGm.SetGlobalBuffer((__gm__ T*)y + AscendC::GetBlockIdx() * tiling.singleCoreLength, tiling.singleCoreLength);

    AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;

    AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(tiling.singleCoreAlignLength);
    AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(tiling.singleCoreAlignLength);

    AscendC::LocalTensor<float> expTensor = ubAllocator.Alloc<float>(tiling.singleCoreAlignLength);
    AscendC::LocalTensor<float> sumTensor;
    if constexpr (scenarioNum >= 0 && scenarioNum <= 2) {
        sumTensor = ubAllocator.Alloc<float>(tiling.singleCoreAlignLength);
    } else {
        sumTensor = ubAllocator.Alloc<float>(8);
    }

    AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
    for (uint32_t i = 0; i < tiling.loopCount; i++) {
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        for (uint32_t j = 0; j < tiling.aDim; j++) {
            AscendC::DataCopyPad(
                xLocal[j * tiling.rDimAlign], xGm[i * tiling.singleCoreLength + j * tiling.rDim],
                {1, static_cast<uint16_t>(tiling.rDim * sizeof(T)), 0, 0, 0},
                {true, 0, static_cast<uint8_t>(tiling.rDimAlign - tiling.rDim), 0});
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        CustomSoftmax(yLocal, xLocal, expTensor, sumTensor, tiling.aDim, tiling.rDim, tiling.rDimAlign);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        for (uint32_t j = 0; j < tiling.aDim; j++) {
            AscendC::DataCopyPad(
                yGm[i * tiling.singleCoreLength + j * tiling.rDim], yLocal[j * tiling.rDimAlign],
                {1, static_cast<uint16_t>(tiling.rDim * sizeof(T)), 0, 0, 0});
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
    }
    if (tiling.lastADim != 0) {
        AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
        for (uint32_t j = 0; j < tiling.lastADim; j++) {
            AscendC::DataCopyPad(
                xLocal[j * tiling.rDimAlign], xGm[tiling.loopCount * tiling.singleCoreLength + j * tiling.rDim],
                {1, static_cast<uint16_t>(tiling.rDim * sizeof(T)), 0, 0, 0},
                {true, 0, static_cast<uint8_t>(tiling.rDimAlign - tiling.rDim), 0});
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        CustomSoftmax(yLocal, xLocal, expTensor, sumTensor, tiling.lastADim, tiling.rDim, tiling.rDimAlign);
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        for (uint32_t j = 0; j < tiling.lastADim; j++) {
            AscendC::DataCopyPad(
                yGm[tiling.loopCount * tiling.singleCoreLength + j * tiling.rDim], yLocal[j * tiling.rDimAlign],
                {1, static_cast<uint16_t>(tiling.rDim * sizeof(T)), 0, 0, 0});
        }
        AscendC::SetFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);
    }
    AscendC::WaitFlag<AscendC::HardEvent::MTE3_MTE2>(EVENT_ID0);

    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    using DataType = float;

    constexpr uint32_t kDim = 1;
    constexpr uint32_t kHeight = 128;
    constexpr uint32_t kWidth = 128;
    constexpr uint32_t kTotalLen = kHeight * kWidth;
    size_t inputByteSize = kTotalLen * sizeof(DataType);

    std::cout << "[DEBUG] scenarioNum::" << scenarioNum << std::endl;
    // Shape [128, 128] fits entirely in UB on any NPU — use compile-time constants
    constexpr uint32_t singleCoreHeight = kHeight;
    constexpr uint32_t loopCount = 1;
    uint32_t lastCount = 0;
    uint32_t singleCoreLength = singleCoreHeight * kWidth;
    uint32_t alignUnit = 32 / sizeof(DataType);
    uint32_t widthAlign = (kWidth + alignUnit - 1) / alignUnit * alignUnit;
    uint32_t singleCoreAlignLength = singleCoreHeight * widthAlign;
    Custom::SoftmaxTiling<DataType> tiling = {
        singleCoreHeight, lastCount, kWidth, widthAlign, loopCount, singleCoreLength, singleCoreAlignLength};

    aclInit(nullptr);
    aclrtSetDevice(0);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* inputHost = nullptr;
    uint8_t* inputDevice = nullptr;
    aclrtMallocHost((void**)(&inputHost), inputByteSize);
    aclrtMalloc((void**)(&inputDevice), inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    size_t fileSize = 0;
    ReadFile("./input/input_x.bin", fileSize, inputHost, inputByteSize);
    aclrtMemcpy(inputDevice, inputByteSize, inputHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* outputHost = nullptr;
    uint8_t* outputDevice = nullptr;
    aclrtMallocHost((void**)(&outputHost), inputByteSize);
    aclrtMalloc((void**)(&outputDevice), inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    softmax_custom<<<kDim, 0, stream>>>(inputDevice, outputDevice, tiling);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(outputHost, inputByteSize, outputDevice, inputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", outputHost, inputByteSize);

    aclrtFree(inputDevice);
    aclrtFreeHost(inputHost);
    aclrtFree(outputDevice);
    aclrtFreeHost(outputHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();

    printf("Softmax operator completed.\n");
    return 0;
}
