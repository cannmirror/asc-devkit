/* !
 * \file matmul.asc
 * \brief Combined all matmul samples with switch-case selection
 */

#include "matmul.h"

__global__ __cube__ void matmul_custom(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c, GM_ADDR workspace,
                                       GM_ADDR tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;

    MatmulKernel<half, half, half, half> matmulKernel;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulKernel.matmulObj, &tiling);
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c, GM_ADDR workspace,
                                           GM_ADDR tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;

    MatmulKernel<half, half, half, half, true> matmulKernel;
    REGIST_MATMUL_OBJ(&pipe, GetSysWorkSpacePtr(), matmulKernel.matmulObj, &tiling);
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl_l2cache(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c, GM_ADDR workspace,
                                                   GM_ADDR tilingGm)
{
    TCubeTiling tiling;
    CopyTiling(&tiling, tilingGm);
    AscendC::TPipe pipe;
    MatmulKernel_L2Cache<half, half, half, half> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tiling);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl_l2cache_constant(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c,
                                                            GM_ADDR workspace, GM_ADDR tilingGm)
{
    AscendC::TPipe pipe;
    MatmulKernelMDL_L2Cache_constant<half, half, half, half, false> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tilingGm);
    matmulKernel.Process(&pipe);
}

__global__ __cube__ void matmul_custom_mdl_l2cache_constant_unitflag(GM_ADDR a, GM_ADDR b, GM_ADDR bias, GM_ADDR c,
                                                                     GM_ADDR workspace, GM_ADDR tilingGm)
{
    AscendC::TPipe pipe;
    MatmulKernelMDL_L2Cache_constant<half, half, half, half, true> matmulKernel;
    matmulKernel.Init(a, b, bias, c, tilingGm);
    matmulKernel.Process(&pipe);
}

template <bool isTiling>
void GenerateTiling_SingleCore(platform_ascendc::PlatformAscendC* ascendcPlatform, uint8_t* tilingBuf)
{
    optiling::TCubeTiling tilingData;
    matmul_tiling::MatmulApiTiling tilingApi(*ascendcPlatform);
    SetTilingTypes<matmul_tiling::MatmulApiTiling, isTiling>(tilingApi, tilingData);
    if constexpr (!isTiling) {
        tilingData.set_baseK(64);
    }
    SetL1(tilingData);
    uint32_t tcubeTilingSize = tilingData.GetDataSize();
    tilingData.SaveToBuffer(tilingBuf, tcubeTilingSize);
}
template <bool isSplit, bool isMDL, bool isL1Cache, bool isL2Cache>
void GenerateTiling_MultiCore(platform_ascendc::PlatformAscendC* ascendcPlatform, uint8_t* tilingBuf)
{
    optiling::TCubeTiling tilingData;
    matmul_tiling::MultiCoreMatmulTiling tilingApi(*ascendcPlatform);
    tilingApi.SetDim(ascendcPlatform->GetCoreNumAic());
    if constexpr (isSplit && !isL2Cache) {
        tilingApi.SetSingleShape(SINGLE_M_SPLIT, SINGLE_N_SPLIT, K);
    } else if constexpr (!isSplit && !isL2Cache) {
        tilingApi.SetSingleShape(SINGLE_M, SINGLE_N, K);
    } else {
        tilingApi.SetSingleShape(SINGLE_M_L2CACHE, SINGLE_N, K);
    }
    SetTilingTypes<matmul_tiling::MultiCoreMatmulTiling, true>(tilingApi, tilingData);

    if constexpr (!isMDL) {
        SetL1(tilingData);
    } else if constexpr (isMDL && isL1Cache) {
        tilingData.set_depthA1(TILING_DEPTHA1_PARAM);
        tilingData.set_stepKa(TILING_STEPKA_PARAM);
    }
    uint32_t tcubeTilingSize = tilingData.GetDataSize();
    tilingData.SaveToBuffer(tilingBuf, tcubeTilingSize);
}

int32_t main(int32_t argc, char* argv[])
{
    MatmulMode mode = MULTI_CORE_MDL_L1CACHE_L2CACHE;

    if (argc > 1) {
        mode = static_cast<MatmulMode>(atoi(argv[1]));
    }

    const char* modeName = "";
    bool useMDL = false;
    bool useL2Cache = false;
    bool useConstantTiling = false;
    bool useUnitFlag = false;
    uint32_t numBlocks = 1;
    uint32_t singleM = SINGLE_M;
    uint32_t singleN = SINGLE_N;
    uint32_t singleK = SINGLE_K;

    switch (mode) {
    case SINGLE_CORE_BASIC:
        modeName = "Single Core Basic";
        numBlocks = 1;
        break;
    case SINGLE_CORE_TILING:
        modeName = "Single Core Tiling";
        numBlocks = 1;
        break;
    case MULTI_CORE_SPLIT_2_12:
        modeName = "Multi Core Split 2 12";
        numBlocks = 24;
        break;
    case MULTI_CORE_SPLIT_4_6:
        modeName = "Multi Core Split 4 6";
        numBlocks = 24;
        break;
    case MULTI_CORE_MDL:
        modeName = "Multi Core MDL";
        useMDL = true;
        numBlocks = 24;
        break;
    case MULTI_CORE_MDL_L1CACHE:
        modeName = "Multi Core MDL L1Cache";
        useMDL = true;
        numBlocks = 24;
        break;
    case MULTI_CORE_MDL_L1CACHE_L2CACHE:
        modeName = "Multi Core MDL L1Cache L2Cache";
        useMDL = true;
        useL2Cache = true;
        numBlocks = 24;
        singleM = 1024;
        break;
    case MULTI_CORE_MDL_L1CACHE_L2CACHE_CONSTANT:
        modeName = "Multi Core MDL L1Cache L2Cache Constant Tiling";
        useMDL = true;
        useConstantTiling = true;
        useL2Cache = true;
        numBlocks = 24;
        singleM = 1024;
        break;
    case MULTI_CORE_MDL_L1CACHE_L2CACHE_CONSTANT_UNITFLAG:
        modeName = "Multi Core MDL L1Cache L2Cache Constant Tiling Unitflag";
        useMDL = true;
        useConstantTiling = true;
        useUnitFlag = true;
        useL2Cache = true;
        numBlocks = 24;
        singleM = 1024;
        break;
    default:
        std::cout << "Invalid mode: " << mode << std::endl;
        return -1;
    }

    std::cout << "Running mode: " << modeName << std::endl;

    auto ascendc = platform_ascendc::PlatformAscendCManager::GetInstance();

    size_t aFileSize = static_cast<size_t>(M * K) * sizeof(uint16_t);
    size_t bFileSize = static_cast<size_t>(K * N) * sizeof(uint16_t);
    size_t cFileSize = static_cast<size_t>(M * N) * sizeof(uint16_t);
    size_t biasFileSize = static_cast<size_t>(N) * sizeof(uint16_t);

    size_t tilingFileSize = useConstantTiling ? sizeof(MatmulProblemShape) : sizeof(TCubeTiling);
    uint8_t* tilingBuf = (uint8_t*)malloc(tilingFileSize);

    if (!useConstantTiling) {
        switch (mode) {
        case SINGLE_CORE_BASIC:
            GenerateTiling_SingleCore(ascendc, tilingBuf);
            break;
        case SINGLE_CORE_TILING:
            GenerateTiling_SingleCore<true>(ascendc, tilingBuf);
            break;
        case MULTI_CORE_SPLIT_2_12:
            GenerateTiling_MultiCore<true>(ascendc, tilingBuf);
            break;
        case MULTI_CORE_SPLIT_4_6:
            GenerateTiling_MultiCore(ascendc, tilingBuf);
            break;
        case MULTI_CORE_MDL:
            GenerateTiling_MultiCore<false, true>(ascendc, tilingBuf);
            break;
        case MULTI_CORE_MDL_L1CACHE:
            GenerateTiling_MultiCore<false, true, true>(ascendc, tilingBuf);
            break;
        case MULTI_CORE_MDL_L1CACHE_L2CACHE:
            GenerateTiling_MultiCore<false, true, true, true>(ascendc, tilingBuf);
            break;
        default:
            std::cout << "Invalid mode for tiling generation" << std::endl;
            return -1;
        }
    }

    size_t userWorkspaceSize = 0;
    size_t systemWorkspaceSize = static_cast<size_t>(ascendc->GetLibApiWorkSpaceSize());
    size_t workspaceSize = userWorkspaceSize + systemWorkspaceSize;

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    aclrtContext context;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* biasHost;
    uint8_t* biasDevice;
    if (IS_BIAS) {
        aclrtMallocHost((void**)(&biasHost), biasFileSize);
        aclrtMalloc((void**)&biasDevice, biasFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/bias_gm.bin", biasFileSize, biasHost, biasFileSize);
        aclrtMemcpy(biasDevice, biasFileSize, biasHost, biasFileSize, ACL_MEMCPY_HOST_TO_DEVICE);
    }

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* workspaceDevice;
    aclrtMalloc((void**)&workspaceDevice, workspaceSize, ACL_MEM_MALLOC_HUGE_FIRST);

    uint8_t* tilingHost;
    uint8_t* tilingDevice;
    aclrtMallocHost((void**)(&tilingHost), tilingFileSize);
    aclrtMalloc((void**)&tilingDevice, tilingFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    if (useConstantTiling) {
        const MatmulProblemShape shapes{numBlocks, M, N, K, singleM, singleN, singleK, 0};
        aclrtMemcpy(tilingHost, tilingFileSize, &shapes, tilingFileSize, ACL_MEMCPY_HOST_TO_HOST);
    } else {
        aclrtMemcpy(tilingHost, tilingFileSize, tilingBuf, tilingFileSize, ACL_MEMCPY_HOST_TO_HOST);
    }
    aclrtMemcpy(tilingDevice, tilingFileSize, tilingHost, tilingFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    if (useMDL) {
        if (useConstantTiling) {
            if (useUnitFlag) {
                matmul_custom_mdl_l2cache_constant_unitflag<<<numBlocks, nullptr, stream>>>(
                    aDevice, bDevice, biasDevice, cDevice, workspaceDevice, tilingDevice);
            } else {
                matmul_custom_mdl_l2cache_constant<<<numBlocks, nullptr, stream>>>(
                    aDevice, bDevice, biasDevice, cDevice, workspaceDevice, tilingDevice);
            }
        } else {
            if (useL2Cache) {
                matmul_custom_mdl_l2cache<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice,
                                                                          workspaceDevice, tilingDevice);
            } else {
                matmul_custom_mdl<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice,
                                                                  workspaceDevice, tilingDevice);
            }
        }
    } else {
        matmul_custom<<<numBlocks, nullptr, stream>>>(aDevice, bDevice, biasDevice, cDevice, workspaceDevice,
                                                      tilingDevice);
    }
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    if (IS_BIAS) {
        aclrtFree(biasDevice);
        aclrtFreeHost(biasHost);
    }
    aclrtFree(workspaceDevice);
    aclrtFree(tilingDevice);
    aclrtFreeHost(tilingHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    free(tilingBuf);
    return 0;
}