/* !
 * \file load_data_with_stride.asc
 * \brief 演示使用 LoadDataWithStride API 完成矩阵乘 Mmad 的数据准备
 *        本样例仅支持 Ascend 950PR/Ascend 950DT (dav-3510 架构)
 */

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif
#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;
constexpr uint32_t BLOCK_CUBE = 16;
constexpr uint64_t ADDR_0 = 0;

template <class T, class U, uint32_t m, uint32_t n, uint32_t k, bool isAtranspose>
class KernelLoadData {
public:
    __aicore__ inline KernelLoadData()
    {
        // 分形参数初始化：每个分形块为16x(c0Size)
        fractalShape[0] = 16;
        fractalShape[1] = 32 / sizeof(T);
        fractalSize = 16 * fractalShape[1];
        if constexpr (sizeof(T) == 2) {
            fractalNum = 1;
        } else {
            fractalNum = 2;
        }
        c0Size = fractalShape[1];

        if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
            if constexpr (!isAtranspose) {
                aSizeAlignL1 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
            } else {
                aSizeAlignL1 = CeilAlign(k, BLOCK_CUBE * fractalNum) * CeilAlign(m, c0Size);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE * fractalNum) * CeilAlign(k, c0Size);
            }
            bSizeAlignL1 = CeilAlign(k, BLOCK_CUBE * fractalNum) * CeilAlign(n, c0Size);
            bSizeAlignL0 = CeilAlign(k, c0Size) * CeilAlign(n, BLOCK_CUBE * fractalNum);
        } else if constexpr (AscendC::IsSameType<T, half>::value && AscendC::IsSameType<U, float>::value) {
            if constexpr (!isAtranspose) {
                aSizeAlignL1 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
            } else {
                aSizeAlignL1 = CeilAlign(k, BLOCK_CUBE) * CeilAlign(m, c0Size);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
            }
            bSizeAlignL1 = CeilAlign(k, BLOCK_CUBE) * CeilAlign(n, c0Size);
            bSizeAlignL0 = CeilAlign(k, c0Size) * CeilAlign(n, BLOCK_CUBE);
        } else if constexpr (AscendC::IsSameType<T, float>::value && AscendC::IsSameType<U, float>::value) {
            if constexpr (!isAtranspose) {
                aSizeAlignL1 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size);
            } else {
                aSizeAlignL1 = CeilAlign(k, BLOCK_CUBE) * CeilAlign(m, c0Size * fractalNum);
                aSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(k, c0Size * fractalNum);
            }
            bSizeAlignL1 = CeilAlign(k, BLOCK_CUBE) * CeilAlign(n, c0Size);
            bSizeAlignL0 = CeilAlign(k, BLOCK_CUBE) * CeilAlign(n, c0Size);
        }
        cSizeAlignL0 = CeilAlign(m, BLOCK_CUBE) * CeilAlign(n, BLOCK_CUBE);

        a1Addr = ADDR_0;
        b1Addr = a1Addr + aSizeAlignL1 * sizeof(T);
    }
    __aicore__ inline void Init(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
    {
        aGM.SetGlobalBuffer((__gm__ T*)a);
        bGM.SetGlobalBuffer((__gm__ T*)b);
        cGM.SetGlobalBuffer((__gm__ U*)c);
    }
    __aicore__ inline void Process()
    {
        // 定义L1缓冲区用于存储输入矩阵
        AscendC::LocalTensor<T> a1Local(AscendC::TPosition::A1, a1Addr, aSizeAlignL1);
        AscendC::LocalTensor<T> b1Local(AscendC::TPosition::B1, b1Addr, bSizeAlignL1);

        // GM到L1数据搬运
        CopyIn(a1Local, b1Local);

        // 定义L0缓冲区用于矩阵乘计算
        AscendC::LocalTensor<T> a2Local(AscendC::TPosition::A2, ADDR_0, aSizeAlignL0);
        if constexpr (!isAtranspose) {
            SplitALoadDataWithStride(a1Local, a2Local);
        } else {
            SplitATransposeLoadDataWithStride(a1Local, a2Local);
        }

        AscendC::LocalTensor<T> b2Local(AscendC::TPosition::B2, ADDR_0, bSizeAlignL0);
        // L1到L0B数据搬运：L0B通路自动转置，enTranspose参数无效
        SplitBLoadDataWithStride(b1Local, b2Local);

        // 定义CO1缓冲区用于存储结果矩阵
        AscendC::LocalTensor<U> co1Local(AscendC::TPosition::CO1, ADDR_0, cSizeAlignL0);
        // 执行矩阵乘计算
        Compute(a2Local, b2Local, co1Local);

        // CO1到GM数据搬运
        CopyOut(co1Local);
    }

private:
    __aicore__ inline uint32_t CeilDiv(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator;
    }

    __aicore__ inline uint32_t CeilAlign(uint32_t numerator, uint32_t denominator)
    {
        return (numerator + denominator - 1) / denominator * denominator;
    }

    __aicore__ inline void CopyIn(AscendC::LocalTensor<T>& a1Local, AscendC::LocalTensor<T>& b1Local)
    {
        // ND格式转Nz格式：将GM上的二维矩阵转为L1上的分形格式
        AscendC::Nd2NzParams nd2nzA1Params;
        if constexpr (!isAtranspose) {
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = m;
            nd2nzA1Params.dValue = k;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = k;
            nd2nzA1Params.dstNzC0Stride = CeilAlign(m, BLOCK_CUBE);
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
        } else {
            nd2nzA1Params.ndNum = 1;
            nd2nzA1Params.nValue = k;
            nd2nzA1Params.dValue = m;
            nd2nzA1Params.srcNdMatrixStride = 0;
            nd2nzA1Params.srcDValue = m;
            if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
                nd2nzA1Params.dstNzC0Stride = CeilAlign(k, BLOCK_CUBE * fractalNum);
            } else {
                nd2nzA1Params.dstNzC0Stride = CeilAlign(k, BLOCK_CUBE);
            }
            nd2nzA1Params.dstNzNStride = 1;
            nd2nzA1Params.dstNzMatrixStride = 0;
        }
        AscendC::DataCopy(a1Local, aGM, nd2nzA1Params);
        // 设置MTE2到MTE1事件标志，等待数据搬运完成
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        AscendC::Nd2NzParams nd2nzB1Params;
        nd2nzB1Params.ndNum = 1;
        nd2nzB1Params.nValue = k;
        nd2nzB1Params.dValue = n;
        nd2nzB1Params.srcNdMatrixStride = 0;
        nd2nzB1Params.srcDValue = n;
        if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
            nd2nzB1Params.dstNzC0Stride = CeilAlign(k, BLOCK_CUBE * fractalNum);
        } else {
            nd2nzB1Params.dstNzC0Stride = CeilAlign(k, BLOCK_CUBE);
        }
        nd2nzB1Params.dstNzNStride = 1;
        nd2nzB1Params.dstNzMatrixStride = 0;
        AscendC::DataCopy(b1Local, bGM, nd2nzB1Params);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);
    }

    __aicore__ inline void SplitALoadDataWithStride(AscendC::LocalTensor<T>& a1Local, AscendC::LocalTensor<T>& a2Local)
    {
        // 等待L1数据搬运完成
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // LoadData3DParamsV2: 描述L1到L0的数据搬运参数（2D数据搬运）
        // 当N=1, filterW/H=1, padding=0, strideW/H=1, dilation=1时，LoadDataWithStride可用于2D矩阵搬运
        AscendC::LoadData3DParamsV2<T> loadDataParams;
        loadDataParams.l1H = 1;                               // 源操作数height，2D数据搬运固定为1
        loadDataParams.l1W = CeilAlign(m, BLOCK_CUBE);        // 源操作数width，对应矩阵M维度
        loadDataParams.channelSize = CeilAlign(k, c0Size);    // 通道数，对应矩阵K维度
        loadDataParams.kExtension = CeilAlign(k, c0Size);     // 目的操作数width维度传输长度（K方向）
        loadDataParams.mExtension = CeilAlign(m, BLOCK_CUBE); // 目的操作数height维度传输长度（M方向）
        loadDataParams.strideW = 1;                           // 卷积核W方向滑动步长，2D数据搬运固定为1
        loadDataParams.strideH = 1;                           // 卷积核H方向滑动步长，2D数据搬运固定为1
        loadDataParams.filterW = 1;                           // 卷积核width，2D数据搬运固定为1
        loadDataParams.filterH = 1;                           // 卷积核height，2D数据搬运固定为1
        loadDataParams.dilationFilterW = 1;                   // 卷积核W方向膨胀系数
        loadDataParams.dilationFilterH = 1;                   // 卷积核H方向膨胀系数
        loadDataParams.filterSizeW = false;                   // 是否扩展filterW（true时+256）
        loadDataParams.filterSizeH = false;                   // 是否扩展filterH（true时+256）
        loadDataParams.enTranspose = false;                   // 是否转置，仅L0A通路且b8/b16/b32时有效
        loadDataParams.fMatrixCtrl = false; // 从左矩阵获取FeatureMap属性（当前仅支持false）

        // 调用LoadDataWithStride时，须调用此接口配置dstStride。
        AscendC::LoadDataRepeatParamWithStride repeatParams;
        repeatParams.dstStride = CeilDiv(CeilAlign(m, BLOCK_CUBE), BLOCK_CUBE); // 输出矩阵K轴方向的偏移
        AscendC::SetLoadDataRepeatWithStride(repeatParams);
        // 使用LoadDataWithStride接口搬运数据从L1到L0A
        AscendC::LoadDataWithStride(a2Local, a1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    }

    __aicore__ inline void SplitATransposeLoadDataWithStride(
        AscendC::LocalTensor<T>& a1Local, AscendC::LocalTensor<T>& a2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID0);

        // LoadData3DParamsV2: A矩阵转置场景参数配置
        // 转置场景下，除了每个分形自身转置，分形位置也会整体转置
        AscendC::LoadData3DParamsV2<T> loadDataParams;
        loadDataParams.l1H = 1;
        loadDataParams.l1W = CeilAlign(k, BLOCK_CUBE);        // 源操作数width，转置时为K维度
        loadDataParams.channelSize = CeilAlign(m, c0Size);    // 通道数，转置时为M维度
        loadDataParams.kExtension = CeilAlign(m, c0Size);     // 目的K方向传输长度
        loadDataParams.mExtension = CeilAlign(k, BLOCK_CUBE); // 目的M方向传输长度
        loadDataParams.strideW = 1;
        loadDataParams.strideH = 1;
        loadDataParams.filterW = 1;
        loadDataParams.filterH = 1;
        loadDataParams.dilationFilterW = 1;
        loadDataParams.dilationFilterH = 1;
        loadDataParams.filterSizeW = false;
        loadDataParams.filterSizeH = false;
        loadDataParams.enTranspose = true; // 启用转置，L0A通路且b8/b16/b32时有效
        loadDataParams.fMatrixCtrl = false;

        // 转置场景下，int8的L1中K维度按32对齐，l1W/mExtension须与CopyIn的dstNzC0Stride一致
        if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
            loadDataParams.l1W = CeilAlign(k, BLOCK_CUBE * fractalNum);
            loadDataParams.mExtension = CeilAlign(k, BLOCK_CUBE * fractalNum);
        }

        // 调用LoadDataWithStride时，须调用此接口配置dstStride。
        AscendC::LoadDataRepeatParamWithStride repeatParams;
        repeatParams.dstStride = CeilDiv(CeilAlign(m, c0Size), BLOCK_CUBE); // 转置场景步长按kExtension
        AscendC::SetLoadDataRepeatWithStride(repeatParams);
        AscendC::LoadDataWithStride(a2Local, a1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
    }

    __aicore__ inline void SplitBLoadDataWithStride(AscendC::LocalTensor<T>& b1Local, AscendC::LocalTensor<T>& b2Local)
    {
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_MTE1>(EVENT_ID1);

        // LoadData3DParamsV2: B矩阵搬运参数
        // L1->L0B通路自动转置，enTranspose参数无效，输出为Zn格式
        AscendC::LoadData3DParamsV2<T> loadDataParams;
        loadDataParams.l1H = 1;
        loadDataParams.l1W = CeilAlign(k, BLOCK_CUBE);        // 源操作数width，对应K维度
        loadDataParams.channelSize = CeilAlign(n, c0Size);    // 通道数，对应N维度
        loadDataParams.kExtension = CeilAlign(n, c0Size);     // 目的K方向传输长度（N维度）
        loadDataParams.mExtension = CeilAlign(k, BLOCK_CUBE); // 目的M方向传输长度（K维度）
        loadDataParams.strideW = 1;
        loadDataParams.strideH = 1;
        loadDataParams.filterW = 1;
        loadDataParams.filterH = 1;
        loadDataParams.dilationFilterW = 1;
        loadDataParams.dilationFilterH = 1;
        loadDataParams.filterSizeW = false;
        loadDataParams.filterSizeH = false;
        loadDataParams.enTranspose = true; // L0B通路自动转置，此参数无效
        loadDataParams.fMatrixCtrl = false;

        // 转置场景下，int8的L1中K维度按32对齐，l1W/mExtension须与CopyIn的dstNzC0Stride一致
        if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
            loadDataParams.l1W = CeilAlign(k, BLOCK_CUBE * fractalNum);
            loadDataParams.mExtension = CeilAlign(k, BLOCK_CUBE * fractalNum);
        }

        // 调用LoadDataWithStride时，须调用此接口配置dstStride。
        AscendC::LoadDataRepeatParamWithStride repeatParams;
        repeatParams.dstStride = CeilDiv(CeilAlign(n, c0Size), BLOCK_CUBE); // 目标步长（单位：16行分形）
        AscendC::SetLoadDataRepeatWithStride(repeatParams);
        AscendC::LoadDataWithStride(b2Local, b1Local, loadDataParams);
        AscendC::SetFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);
    }

    __aicore__ inline void Compute(
        AscendC::LocalTensor<T>& a2Local, AscendC::LocalTensor<T>& b2Local, AscendC::LocalTensor<U>& co1Local)
    {
        // 等待L0数据搬运完成
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE1_M>(EVENT_ID1);

        // 配置矩阵乘参数并执行Mmad
        AscendC::MmadParams mmadParams;
        mmadParams.m = m;
        if constexpr (AscendC::IsSameType<T, int8_t>::value && AscendC::IsSameType<U, int32_t>::value) {
            mmadParams.n = CeilAlign(n, BLOCK_CUBE * fractalNum);
        } else {
            mmadParams.n = n;
        }
        mmadParams.k = k;
        mmadParams.cmatrixInitVal = true;

        AscendC::Mmad(co1Local, a2Local, b2Local, mmadParams);
        AscendC::SetFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);
    }

    __aicore__ inline void CopyOut(AscendC::LocalTensor<U>& co1Local)
    {
        // 等待矩阵乘计算完成
        AscendC::WaitFlag<AscendC::HardEvent::M_FIX>(EVENT_ID0);

        // 使用Fixpipe将结果从CO1搬运到GM，dav-3510专用参数
        AscendC::FixpipeParamsArch3510<AscendC::CO2Layout::ROW_MAJOR> fixpipeParams;
        fixpipeParams.mSize = m;
        fixpipeParams.nSize = n;
        fixpipeParams.srcStride = CeilAlign(m, BLOCK_CUBE);
        fixpipeParams.dstStride = n;

        AscendC::Fixpipe(cGM, co1Local, fixpipeParams);
    }

private:
    AscendC::GlobalTensor<T> aGM;
    AscendC::GlobalTensor<T> bGM;
    AscendC::GlobalTensor<U> cGM;

    uint32_t c0Size, fractalSize, fractalNum;
    uint32_t aSizeAlignL1, bSizeAlignL1, aSizeAlignL0, bSizeAlignL0, cSizeAlignL0;
    uint16_t fractalShape[2] = {0, 0};

    uint64_t a1Addr, b1Addr;
};

template <uint32_t m, uint32_t n, uint32_t k>
__global__ __cube__ void load_data_custom(__gm__ uint8_t* a, __gm__ uint8_t* b, __gm__ uint8_t* c)
{
    AscendC::InitSocState();
    if constexpr (scenarioNum == 1) {
        KernelLoadData<int8_t, int32_t, m, n, k, false> op;
        op.Init(a, b, c);
        op.Process();
    } else if constexpr (scenarioNum == 2) {
        KernelLoadData<int8_t, int32_t, m, n, k, true> op;
        op.Init(a, b, c);
        op.Process();
    } else if constexpr (scenarioNum == 3) {
        KernelLoadData<half, float, m, n, k, false> op;
        op.Init(a, b, c);
        op.Process();
    } else if constexpr (scenarioNum == 4) {
        KernelLoadData<half, float, m, n, k, true> op;
        op.Init(a, b, c);
        op.Process();
    } else if constexpr (scenarioNum == 5) {
        KernelLoadData<float, float, m, n, k, false> op;
        op.Init(a, b, c);
        op.Process();
    } else if constexpr (scenarioNum == 6) {
        KernelLoadData<float, float, m, n, k, true> op;
        op.Init(a, b, c);
        op.Process();
    }
    AscendC::PipeBarrier<PIPE_ALL>();
}

int32_t main(int32_t argc, char* argv[])
{
    constexpr uint32_t M = 30;
    constexpr uint32_t N = 70;
    constexpr uint32_t K = 40;
    size_t aFileSize = 0;
    size_t bFileSize = 0;
    size_t cFileSize = 0;

    if constexpr (scenarioNum <= 2) {
        aFileSize = M * K * sizeof(int8_t);
        bFileSize = K * N * sizeof(int8_t);
        cFileSize = M * N * sizeof(int32_t);
    } else if constexpr (scenarioNum <= 4) {
        aFileSize = M * K * sizeof(half);
        bFileSize = K * N * sizeof(half);
        cFileSize = M * N * sizeof(float);
    } else {
        aFileSize = M * K * sizeof(float);
        bFileSize = K * N * sizeof(float);
        cFileSize = M * N * sizeof(float);
    }
    uint32_t numBlocks = 1;

    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t* aHost;
    uint8_t* aDevice;
    aclrtMallocHost((void**)(&aHost), aFileSize);
    aclrtMalloc((void**)&aDevice, aFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x1_gm.bin", aFileSize, aHost, aFileSize);
    aclrtMemcpy(aDevice, aFileSize, aHost, aFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* bHost;
    uint8_t* bDevice;
    aclrtMallocHost((void**)(&bHost), bFileSize);
    aclrtMalloc((void**)&bDevice, bFileSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/x2_gm.bin", bFileSize, bHost, bFileSize);
    aclrtMemcpy(bDevice, bFileSize, bHost, bFileSize, ACL_MEMCPY_HOST_TO_DEVICE);

    uint8_t* cHost;
    uint8_t* cDevice;
    aclrtMallocHost((void**)(&cHost), cFileSize);
    aclrtMalloc((void**)&cDevice, cFileSize, ACL_MEM_MALLOC_HUGE_FIRST);

    load_data_custom<M, N, K><<<numBlocks, 0, stream>>>(aDevice, bDevice, cDevice);
    aclrtSynchronizeStream(stream);

    // 将结果从Device拷贝到Host并写入文件
    aclrtMemcpy(cHost, cFileSize, cDevice, cFileSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", cHost, cFileSize);

    aclrtFree(aDevice);
    aclrtFreeHost(aHost);
    aclrtFree(bDevice);
    aclrtFreeHost(bHost);
    aclrtFree(cDevice);
    aclrtFreeHost(cHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}
