/* !
 * \file bank_conflict.asc
 * \brief SIMT UB subbank conflict sample.
 */

#include <cmath>
#include <cstdint>
#include <cstdio>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 0
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 4
#error "SCENARIO_NUM must be one of 0, 1, 2, 3, 4."
#endif

namespace {
constexpr uint32_t THREAD_COUNT = 32;
constexpr uint32_t REPEAT_TIMES = 100;
constexpr uint32_t UB_ELEMENT_COUNT = 4096;
constexpr uint32_t SAME_BANK_SUBBANK_STRIDE = 128;      // 128 float = 512B
constexpr uint32_t SAME_BANK_GROUP_SUBBANK_STRIDE = 64; // 64 float = 256B
} // namespace

inline const char* get_case_name(uint32_t scenario_num)
{
    switch (scenario_num) {
        case 0:
            return "same_address_merge";
        case 1:
            return "cross_bank_subbank_baseline";
        case 2:
            return "contiguous_float_access_merge";
        case 3:
            return "same_bank_same_subbank_different_rows";
        case 4:
            return "same_bank_group_same_subbank";
        default:
            return "unknown";
    }
}

__aicore__ inline uint32_t get_ub_index_device(uint32_t thread_id)
{
#if SCENARIO_NUM == 0
    // 所有线程读取完全相同的UB地址。
    return 0;
#elif SCENARIO_NUM == 1
    // 8B访问间隔使32个线程分散到8个bank group的4个subbank。
    return thread_id * 2;
#elif SCENARIO_NUM == 2
    // 连续float访问使相邻两个线程落在同一8B subbank范围内。
    return thread_id;
#elif SCENARIO_NUM == 3
    // 512B访问间隔使地址回到同一bank和同一subbank的不同行。
    return thread_id * SAME_BANK_SUBBANK_STRIDE;
#elif SCENARIO_NUM == 4
    // 256B访问间隔切换bank group内的bank编号，但保持subbank编号不变。
    return thread_id * SAME_BANK_GROUP_SUBBANK_STRIDE;
#else
    return thread_id;
#endif
}

inline uint32_t get_ub_index_host(uint32_t thread_id)
{
#if SCENARIO_NUM == 0
    return 0;
#elif SCENARIO_NUM == 1
    return thread_id * 2;
#elif SCENARIO_NUM == 2
    return thread_id;
#elif SCENARIO_NUM == 3
    return thread_id * SAME_BANK_SUBBANK_STRIDE;
#elif SCENARIO_NUM == 4
    return thread_id * SAME_BANK_GROUP_SUBBANK_STRIDE;
#else
    return thread_id;
#endif
}

inline float make_ub_value_host(uint32_t index) { return static_cast<float>(index) * 1.25f; }

__global__ __launch_bounds__(THREAD_COUNT) void bank_conflict_kernel(
    const float* input, float* output, uint64_t* cycle_output)
{
    __ubuf__ float ub[UB_ELEMENT_COUNT];

    uint32_t tid = threadIdx.x;
    for (uint32_t i = tid; i < UB_ELEMENT_COUNT; i += blockDim.x) {
        ub[i] = input[i];
    }

    uint32_t ub_index = get_ub_index_device(tid);
    // Keep every loop iteration as a real UB load for clock-based measurement.
    __ubuf__ volatile float* ub_ptr;
    ub_ptr = ub;
    float acc = 0.0f;

    uint64_t start = clock();
#pragma unroll
    for (uint32_t i = 0; i < REPEAT_TIMES; ++i) {
        acc += ub_ptr[ub_index];
    }
    uint64_t end = clock();

    output[tid] = acc;
    cycle_output[tid] = end - start;
}

uint32_t verify_result(const std::vector<float>& output)
{
    constexpr float rel_tolerance = 1e-4f;
    constexpr float abs_tolerance = 1e-2f;
    if (output.size() != THREAD_COUNT) {
        std::cout << "[Failed] Case accuracy verification failed!" << std::endl;
        return 1;
    }

    for (uint32_t thread_id = 0; thread_id < THREAD_COUNT; ++thread_id) {
        uint32_t ub_index = get_ub_index_host(thread_id);
        float golden = 0.0f;
        float value = make_ub_value_host(ub_index);
        for (uint32_t i = 0; i < REPEAT_TIMES; ++i) {
            golden += value;
        }
        float abs_err = std::fabs(output[thread_id] - golden);
        float golden_abs = std::fabs(golden);
        bool is_mismatch = abs_err > abs_tolerance;
        if (golden_abs > abs_tolerance) {
            float rel_err = abs_err / golden_abs;
            is_mismatch = is_mismatch && rel_err > rel_tolerance;
        }
        if (is_mismatch) {
            std::cout << "[Failed] Case accuracy verification failed!" << std::endl;
            std::cout << "thread: " << thread_id << ", output: " << output[thread_id] << ", golden: " << golden
                      << std::endl;
            return 1;
        }
    }

    std::cout << "[Success] Case accuracy verification passed." << std::endl;
    return 0;
}

std::vector<float> launch_kernel()
{
    constexpr size_t output_byte_size = THREAD_COUNT * sizeof(float);
    constexpr size_t cycle_byte_size = THREAD_COUNT * sizeof(uint64_t);

    int32_t device_id = 0;
    aclrtStream stream = nullptr;
    float* input_device = nullptr;
    float* output_device = nullptr;
    uint64_t* cycle_device = nullptr;
    float* output_host = nullptr;
    uint64_t* cycle_host = nullptr;
    std::vector<float> input_host(UB_ELEMENT_COUNT);
    for (uint32_t i = 0; i < UB_ELEMENT_COUNT; ++i) {
        input_host[i] = make_ub_value_host(i);
    }

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);

    aclrtMallocHost(reinterpret_cast<void**>(&output_host), output_byte_size);
    aclrtMallocHost(reinterpret_cast<void**>(&cycle_host), cycle_byte_size);
    aclrtMalloc(reinterpret_cast<void**>(&input_device), UB_ELEMENT_COUNT * sizeof(float), ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void**>(&output_device), output_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void**>(&cycle_device), cycle_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(
        input_device, UB_ELEMENT_COUNT * sizeof(float), input_host.data(), UB_ELEMENT_COUNT * sizeof(float),
        ACL_MEMCPY_HOST_TO_DEVICE);

    bank_conflict_kernel<<<1, THREAD_COUNT, 0, stream>>>(input_device, output_device, cycle_device);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(output_host, output_byte_size, output_device, output_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);
    aclrtMemcpy(cycle_host, cycle_byte_size, cycle_device, cycle_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    std::vector<float> output(output_host, output_host + THREAD_COUNT);
    const uint64_t* cycle_values = cycle_host;
    std::printf("Cycles per thread:");
    for (uint32_t thread_id = 0; thread_id < THREAD_COUNT; ++thread_id) {
        std::printf(" %lu", cycle_values[thread_id]);
    }
    std::printf("\n");

    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtFree(cycle_device);
    aclrtFreeHost(output_host);
    aclrtFreeHost(cycle_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        std::fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();
    return output;
}

int32_t main(int32_t argc, char** argv)
{
    constexpr uint32_t scenario_num = static_cast<uint32_t>(SCENARIO_NUM);
    std::printf("Usage: %s (compile-time SCENARIO_NUM=%u)\n", argv[0], scenario_num);
    std::printf("Running case %u: %s...\n", scenario_num, get_case_name(scenario_num));

    std::vector<float> output = launch_kernel();
    return verify_result(output);
}
