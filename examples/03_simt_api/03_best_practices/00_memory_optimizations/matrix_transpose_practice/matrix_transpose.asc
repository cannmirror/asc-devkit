#include <cmath>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"

#ifndef SCENARIO_NUM
#define SCENARIO_NUM 7
#endif

#if SCENARIO_NUM < 0 || SCENARIO_NUM > 7
#error "SCENARIO_NUM must be one of 0, 1, 2, 3, 4, 5, 6, 7."
#endif

namespace {
constexpr int TILE_DIM = 32;
constexpr int TILE_PAD = 2; // Case6/7的UB padding列数（32x34）
constexpr int TILE_PAD_STRIDE = TILE_DIM + TILE_PAD;
constexpr uint32_t THREADS_2048 = 2048;
constexpr uint32_t THREADS_1024 = 1024;

#if SCENARIO_NUM == 0
constexpr uint32_t THREADS_PER_BLOCK = THREADS_2048;
#elif SCENARIO_NUM == 1
constexpr uint32_t THREADS_PER_BLOCK = THREADS_1024;
#elif SCENARIO_NUM == 2
constexpr uint32_t THREADS_PER_BLOCK = THREADS_2048;
#elif SCENARIO_NUM == 3
constexpr uint32_t THREADS_PER_BLOCK = THREADS_2048;
constexpr int TILES_PER_BLOCK = 2; // 2048线程=2个32x32的tile
#elif SCENARIO_NUM == 4
constexpr uint32_t THREADS_PER_BLOCK = THREADS_2048;
constexpr int TILES_PER_BLOCK = 2; // 2048线程=2个32x32的tile
#elif SCENARIO_NUM == 5
constexpr uint32_t THREADS_PER_BLOCK = THREADS_1024;
#elif SCENARIO_NUM == 6
constexpr uint32_t THREADS_PER_BLOCK = THREADS_1024;
#else
constexpr uint32_t THREADS_PER_BLOCK = THREADS_1024;
#endif

struct LaunchConfig {
    uint32_t width;
    uint32_t height;
    uint32_t core_num;
    aclrtStream stream;
};

uint32_t verify_result(const std::vector<float>& output, const std::vector<float>& golden, float abs_tolerance = 1e-3f)
{
    if (output.size() != golden.size()) {
        printf("[Failed] Case accuracy verification failed!\n");
        return 1;
    }
    for (size_t i = 0; i < output.size(); ++i) {
        if (std::fabs(output[i] - golden[i]) > abs_tolerance) {
            printf("[Failed] Case accuracy verification failed!\n");
            return 1;
        }
    }
    printf("[Success] Case accuracy verification passed.\n");
    return 0;
}

const char* get_kernel_name(int32_t kernel_kind)
{
    switch (kernel_kind) {
        case 0:
            return "copy_2048";
        case 1:
            return "copy_1024";
        case 2:
            return "transpose_naive";
        case 3:
            return "transpose_ub_2tile_static";
        case 4:
            return "transpose_ub_2tile";
        case 5:
            return "transpose_ub";
        case 6:
            return "transpose_ub_pad";
        case 7:
            return "transpose_ub_pad_db";
        default:
            return "unknown";
    }
}

// kernel_kind==0为copy，返回输入本身；否则返回转置结果output(col,row)=input(row,col)。
std::vector<float> compute_golden(
    const std::vector<float>& input, const std::vector<uint32_t>& input_shape, int32_t kernel_kind)
{
    if (input_shape.size() != 2) {
        fprintf(stderr, "Input shape must be 2-D.\n");
        return {};
    }

    const uint32_t height = input_shape[0];
    const uint32_t width = input_shape[1];
    if (input.size() != static_cast<size_t>(height) * width) {
        fprintf(stderr, "Input data size does not match input shape.\n");
        return {};
    }

    if (kernel_kind == 0) {
        return input;
    }

    std::vector<float> output(input.size());
    for (uint32_t row = 0; row < height; ++row) {
        for (uint32_t col = 0; col < width; ++col) {
            output[static_cast<size_t>(col) * height + row] = input[static_cast<size_t>(row) * width + col];
        }
    }
    return output;
}

uint32_t get_vector_core_num(uint32_t device_id)
{
    int64_t core_num = 0;
    aclError ret = aclrtGetDeviceInfo(device_id, ACL_DEV_ATTR_VECTOR_CORE_NUM, &core_num);
    if (ret != ACL_SUCCESS) {
        return 0;
    }
    return static_cast<uint32_t>(core_num);
}
} // namespace

#if SCENARIO_NUM == 0 || SCENARIO_NUM == 1
__global__ __launch_bounds__(THREADS_PER_BLOCK) void copy_kernel(float* output, const float* input, uint32_t elements)
{
    uint32_t tid = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;
    for (uint32_t i = tid; i < elements; i += stride) {
        output[i] = input[i];
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t elements = config.width * config.height;
    dim3 grid(config.core_num, 1, 1);
    dim3 block(THREADS_PER_BLOCK, 1, 1);
    copy_kernel<<<grid, block, 0, config.stream>>>(output, input, elements);
}
#endif

#if SCENARIO_NUM == 2
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_naive_kernel(
    float* output, const float* input, uint32_t width, uint32_t height)
{
    uint32_t tid = blockIdx.x * blockDim.x + threadIdx.x;
    uint32_t stride = gridDim.x * blockDim.x;
    uint32_t total = width * height;
    for (uint32_t i = tid; i < total; i += stride) {
        uint32_t row = i / width;
        uint32_t col = i - row * width;
        // input(row,col) -> output(col,row)
        output[col * height + row] = input[i];
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    dim3 grid(config.core_num, 1, 1);
    dim3 block(THREADS_PER_BLOCK, 1, 1);
    transpose_naive_kernel<<<grid, block, 0, config.stream>>>(output, input, config.width, config.height);
}
#endif

#if SCENARIO_NUM == 3
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_ub_2tile_naive_kernel(
    float* output, const float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t local_tile = threadIdx.y >> 5; // 0或1，区分Thread Block内两个tile
    uint32_t ty = threadIdx.y & (TILE_DIM - 1);
    uint32_t tx = threadIdx.x;
    uint32_t tile_id = blockIdx.x * TILES_PER_BLOCK + local_tile;
    bool active = tile_id < total_tiles;

    if (active) {
        uint32_t tile_y = tile_id / tiles_x;
        uint32_t tile_x = tile_id - tile_y * tiles_x;
        uint32_t x_index = tile_x * TILE_DIM + tx;
        uint32_t y_index = tile_y * TILE_DIM + ty;
        tile[local_tile][ty][tx] = input[x_index + y_index * width];
    }
    asc_syncthreads();

    if (active) {
        uint32_t tile_y = tile_id / tiles_x;
        uint32_t tile_x = tile_id - tile_y * tiles_x;
        uint32_t x_index = tile_y * TILE_DIM + tx;
        uint32_t y_index = tile_x * TILE_DIM + ty;
        output[x_index + y_index * height] = tile[local_tile][tx][ty];
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    dim3 grid((total_tiles + TILES_PER_BLOCK - 1) / TILES_PER_BLOCK, 1, 1);
    dim3 block(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1);
    transpose_ub_2tile_naive_kernel<<<grid, block, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 4
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_ub_2tile_kernel(
    float* output, const float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float tile[TILES_PER_BLOCK][TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t local_tile = threadIdx.y >> 5; // 0或1，区分Thread Block内两个tile
    uint32_t ty = threadIdx.y & (TILE_DIM - 1);
    uint32_t tx = threadIdx.x;

    for (uint32_t tile_base = blockIdx.x * TILES_PER_BLOCK; tile_base < total_tiles;
         tile_base += gridDim.x * TILES_PER_BLOCK) {
        uint32_t tile_id = tile_base + local_tile;
        bool active = tile_id < total_tiles;
        if (active) {
            uint32_t tile_y = tile_id / tiles_x;
            uint32_t tile_x = tile_id - tile_y * tiles_x;
            uint32_t x_index = tile_x * TILE_DIM + tx;
            uint32_t y_index = tile_y * TILE_DIM + ty;
            tile[local_tile][ty][tx] = input[x_index + y_index * width];
        }
        asc_syncthreads();

        if (active) {
            uint32_t tile_y = tile_id / tiles_x;
            uint32_t tile_x = tile_id - tile_y * tiles_x;
            uint32_t x_index = tile_y * TILE_DIM + tx;
            uint32_t y_index = tile_x * TILE_DIM + ty;
            output[x_index + y_index * height] = tile[local_tile][tx][ty];
        }
        asc_syncthreads();
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    dim3 grid(config.core_num, 1, 1);
    dim3 block(TILE_DIM, TILE_DIM * TILES_PER_BLOCK, 1);
    transpose_ub_2tile_kernel<<<grid, block, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}

#endif

#if SCENARIO_NUM == 5
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_ub_kernel(
    float* output, const float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float tile[TILE_DIM][TILE_DIM];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t tx = threadIdx.x;
    uint32_t ty = threadIdx.y;
    uint32_t step = gridDim.x;

    for (uint32_t tile_id = blockIdx.x; tile_id < total_tiles; tile_id += step) {
        uint32_t tile_y = tile_id / tiles_x;
        uint32_t tile_x = tile_id - tile_y * tiles_x;
        uint32_t x_index = tile_x * TILE_DIM + tx;
        uint32_t y_index = tile_y * TILE_DIM + ty;
        tile[ty][tx] = input[x_index + y_index * width];
        asc_syncthreads();

        x_index = tile_y * TILE_DIM + tx;
        y_index = tile_x * TILE_DIM + ty;
        output[x_index + y_index * height] = tile[tx][ty];
        asc_syncthreads();
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    dim3 grid(config.core_num, 1, 1);
    dim3 block(TILE_DIM, TILE_DIM, 1);
    transpose_ub_kernel<<<grid, block, 0, config.stream>>>(output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 6
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_ub_pad_kernel(
    float* output, const float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float tile[TILE_DIM][TILE_PAD_STRIDE];
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t tx = threadIdx.x;
    uint32_t ty = threadIdx.y;
    uint32_t step = gridDim.x;

    for (uint32_t tile_id = blockIdx.x; tile_id < total_tiles; tile_id += step) {
        uint32_t tile_y = tile_id / tiles_x;
        uint32_t tile_x = tile_id - tile_y * tiles_x;
        uint32_t x_index = tile_x * TILE_DIM + tx;
        uint32_t y_index = tile_y * TILE_DIM + ty;
        tile[ty][tx] = input[x_index + y_index * width];
        asc_syncthreads();

        x_index = tile_y * TILE_DIM + tx;
        y_index = tile_x * TILE_DIM + ty;
        output[x_index + y_index * height] = tile[tx][ty];
        asc_syncthreads();
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    dim3 grid(config.core_num, 1, 1);
    dim3 block(TILE_DIM, TILE_DIM, 1);
    transpose_ub_pad_kernel<<<grid, block, 0, config.stream>>>(output, input, config.width, config.height, total_tiles);
}
#endif

#if SCENARIO_NUM == 7
__global__ __launch_bounds__(THREADS_PER_BLOCK) void transpose_ub_pad_db_kernel(
    float* output, const float* input, uint32_t width, uint32_t height, uint32_t total_tiles)
{
    __ubuf__ float tile[2][TILE_DIM][TILE_PAD_STRIDE]; // 双缓冲：轮换buffer，去除尾部同步
    uint32_t tiles_x = width / TILE_DIM;
    uint32_t tx = threadIdx.x;
    uint32_t ty = threadIdx.y;
    uint32_t cnt = 0;
    uint32_t step = gridDim.x;

    for (uint32_t tile_id = blockIdx.x; tile_id < total_tiles; tile_id += step) {
        uint32_t tile_y = tile_id / tiles_x;
        uint32_t tile_x = tile_id - tile_y * tiles_x;
        uint32_t x_index = tile_x * TILE_DIM + tx;
        uint32_t y_index = tile_y * TILE_DIM + ty;
        tile[cnt][ty][tx] = input[x_index + y_index * width];
        asc_syncthreads(); // 保留load后的同步

        x_index = tile_y * TILE_DIM + tx;
        y_index = tile_x * TILE_DIM + ty;
        output[x_index + y_index * height] = tile[cnt][tx][ty];

        cnt ^= 1; // 切换到下一份buffer
    }
}

void launch_case_kernel(float* output, const float* input, const LaunchConfig& config)
{
    uint32_t total_tiles = (config.width / TILE_DIM) * (config.height / TILE_DIM);
    dim3 grid(config.core_num, 1, 1);
    dim3 block(TILE_DIM, TILE_DIM, 1);
    transpose_ub_pad_db_kernel<<<grid, block, 0, config.stream>>>(
        output, input, config.width, config.height, total_tiles);
}
#endif

std::vector<float> run_case(const std::vector<float>& input_host, const std::vector<uint32_t>& input_shape)
{
    const size_t tensor_elem_count = input_host.size();
    const size_t tensor_byte_size = tensor_elem_count * sizeof(float);
    std::vector<float> output_host(tensor_elem_count, 0.0f);

    const uint32_t matrix_height = input_shape[0];
    const uint32_t matrix_width = input_shape[1];

    aclInit(nullptr);
    aclrtSetDevice(0);

    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    float* input_device = nullptr;
    float* output_device = nullptr;
    aclrtMalloc(reinterpret_cast<void**>(&input_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc(reinterpret_cast<void**>(&output_device), tensor_byte_size, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(input_device, tensor_byte_size, input_host.data(), tensor_byte_size, ACL_MEMCPY_HOST_TO_DEVICE);

    LaunchConfig launch_config = {
        matrix_width,
        matrix_height,
        get_vector_core_num(0),
        stream,
    };
    launch_case_kernel(output_device, input_device, launch_config);

    aclrtSynchronizeStream(stream);
    aclrtMemcpy(output_host.data(), tensor_byte_size, output_device, tensor_byte_size, ACL_MEMCPY_DEVICE_TO_HOST);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }
    aclrtFree(input_device);
    aclrtFree(output_device);
    aclrtDestroyStream(stream);
    aclrtResetDevice(0);
    aclFinalize();
    return output_host;
}

int main(int argc, char** argv)
{
    const uint32_t kernel_kind = static_cast<uint32_t>(SCENARIO_NUM);
    uint32_t matrix_size = 1024;
    if (argc > 1) {
        char* end = nullptr;
        unsigned long value = std::strtoul(argv[1], &end, 10);
        if (end != argv[1] && *end == '\0' && value > 0) {
            matrix_size = static_cast<uint32_t>(value);
        }
    }

    printf("Usage: %s [matrix_size] (compile-time SCENARIO_NUM=%u)\n", argv[0], kernel_kind);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));
    printf("Threads/Thread Block: %u\n", THREADS_PER_BLOCK);
    printf("Matrix shape: %u x %u\n", matrix_size, matrix_size);

    if (matrix_size - (matrix_size / TILE_DIM) * TILE_DIM != 0) {
        std::fprintf(stderr, "Matrix shape must be multiple of TILE_DIM=%d.\n", TILE_DIM);
        return EXIT_FAILURE;
    }

    const std::vector<uint32_t> input_shape = {matrix_size, matrix_size};
    const size_t tensor_elem_count = static_cast<size_t>(matrix_size) * matrix_size;
    std::vector<float> input(tensor_elem_count);
    for (size_t i = 0; i < tensor_elem_count; ++i) {
        input[i] = static_cast<float>(i * 1.25f);
    }

    // copy case（0/1）对照输入本身，transpose case（2-7）对照转置结果。
    const int32_t golden_kind = (kernel_kind <= 1) ? 0 : 1;
    auto golden = compute_golden(input, input_shape, golden_kind);
    auto output = run_case(input, input_shape);

    return verify_result(output, golden);
}
