#include <algorithm>
#include <iterator>
#include <set>
#include <random>
#include <iostream>
#include <vector>
#include "acl/acl.h"
#include "simt_api/asc_simt.h"
#ifndef SCENARIO_NUM
#define SCENARIO_NUM 1
#endif

#if SCENARIO_NUM < 1 || SCENARIO_NUM > 2
#error "SCENARIO_NUM must be one of 1, 2"
#endif

namespace {
constexpr uint32_t THREAD_COUNT = 1024;
constexpr uint32_t NUM_ROWS = 8192;
constexpr uint32_t NUM_COLS = 1024;
constexpr uint32_t MAX_NNZ_PER_ROW = 64;
} // namespace

enum KernelKind { USE_THREAD_PER_ROW = 1, USE_WARP_PER_ROW = 2 };

// Case 1: One thread processes one row (high divergence)
// Different rows have different nnz counts, causing threads in the same warp to execute
// different numbers of loop iterations, resulting in warp divergence.
__global__ void kernel_spmv_thread(
    float* values, uint32_t* col_idx, uint32_t* row_ptr, float* x, float* y, uint32_t num_rows)
{
    uint32_t row = blockIdx.x * blockDim.x + threadIdx.x;
    if (row >= num_rows)
        return;
    float sum = 0.0f;
    uint32_t row_start = row_ptr[row];
    uint32_t row_end = row_ptr[row + 1];
    for (uint32_t j = row_start; j < row_end; j++) {
        sum += values[j] * x[col_idx[j]];
    }
    y[row] = sum;
}

// Case 2: One warp cooperatively processes one row (low divergence)
// All lanes in a warp handle the same row with strided access, so they iterate
// the same number of times. asc_reduce_add is used for cross-lane reduction.
__global__ void kernel_spmv_warp(
    float* values, uint32_t* col_idx, uint32_t* row_ptr, float* x, float* y, uint32_t num_rows)
{
    uint32_t lane_id = laneid();
    uint32_t global_warp_id = (blockIdx.x * blockDim.x + threadIdx.x) / warpSize;
    uint32_t num_warps = (blockDim.x / warpSize) * gridDim.x;

    for (uint32_t row = global_warp_id; row < num_rows; row += num_warps) {
        float sum = 0.0f;
        uint32_t row_start = row_ptr[row];
        uint32_t row_end = row_ptr[row + 1];
        for (uint32_t j = row_start + lane_id; j < row_end; j += warpSize) {
            sum += values[j] * x[col_idx[j]];
        }
        sum = asc_reduce_add(sum);
        if (lane_id == 0) {
            y[row] = sum;
        }
    }
}

void generate_sparse_matrix(
    std::vector<float>& values, std::vector<uint32_t>& col_idx, std::vector<uint32_t>& row_ptr, uint32_t num_rows,
    uint32_t num_cols, uint32_t max_nnz_per_row)
{
    std::mt19937 gen(42);
    std::uniform_int_distribution<uint32_t> nnz_dist(1, max_nnz_per_row);
    // Use integer distribution to generate integer-valued floats, avoiding floating-point
    // associativity issues where different addition orders produce different results.
    std::uniform_int_distribution<int32_t> val_dist(-10, 10);
    std::uniform_int_distribution<uint32_t> col_dist(0, num_cols - 1);

    row_ptr.resize(num_rows + 1);
    row_ptr[0] = 0;
    for (uint32_t i = 0; i < num_rows; i++) {
        uint32_t nnz = nnz_dist(gen);
        std::vector<uint32_t> cols;
        std::set<uint32_t> col_set;
        while (cols.size() < nnz) {
            uint32_t c = col_dist(gen);
            if (col_set.insert(c).second) {
                cols.push_back(c);
            }
        }
        std::sort(cols.begin(), cols.end());
        for (uint32_t c : cols) {
            values.push_back(static_cast<float>(val_dist(gen)));
            col_idx.push_back(c);
        }
        row_ptr[i + 1] = row_ptr[i] + nnz;
    }
}

void compute_spmv_cpu(
    const std::vector<float>& values, const std::vector<uint32_t>& col_idx, const std::vector<uint32_t>& row_ptr,
    const std::vector<float>& x, std::vector<float>& golden, uint32_t num_rows)
{
    golden.resize(num_rows);
    for (uint32_t i = 0; i < num_rows; i++) {
        float sum = 0.0f;
        for (uint32_t j = row_ptr[i]; j < row_ptr[i + 1]; j++) {
            sum += values[j] * x[col_idx[j]];
        }
        golden[i] = sum;
    }
}

std::vector<float> launch_kernel(
    std::vector<float>& values, std::vector<uint32_t>& col_idx, std::vector<uint32_t>& row_ptr, std::vector<float>& x,
    uint32_t num_rows, uint32_t num_cols, uint32_t kernel_type)
{
    uint32_t nnz = values.size();
    size_t values_bytes = nnz * sizeof(float);
    size_t col_idx_bytes = nnz * sizeof(uint32_t);
    size_t row_ptr_bytes = (num_rows + 1) * sizeof(uint32_t);
    size_t x_bytes = num_cols * sizeof(float);
    size_t y_bytes = num_rows * sizeof(float);

    uint32_t blocks_per_grid = 8;

    int32_t device_id = 0;
    aclrtStream stream = nullptr;

    uint8_t* values_host = reinterpret_cast<uint8_t*>(values.data());
    uint8_t* col_idx_host = reinterpret_cast<uint8_t*>(col_idx.data());
    uint8_t* row_ptr_host = reinterpret_cast<uint8_t*>(row_ptr.data());
    uint8_t* x_host = reinterpret_cast<uint8_t*>(x.data());
    float* values_device = nullptr;
    uint32_t* col_idx_device = nullptr;
    uint32_t* row_ptr_device = nullptr;
    float* x_device = nullptr;
    float* y_host = nullptr;
    float* y_device = nullptr;

    aclInit(nullptr);
    aclrtSetDevice(device_id);
    aclrtCreateStream(&stream);
    aclrtMallocHost((void**)&y_host, y_bytes);
    aclrtMalloc((void**)&values_device, values_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&col_idx_device, col_idx_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&row_ptr_device, row_ptr_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&x_device, x_bytes, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&y_device, y_bytes, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(values_device, values_bytes, values_host, values_bytes, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(col_idx_device, col_idx_bytes, col_idx_host, col_idx_bytes, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(row_ptr_device, row_ptr_bytes, row_ptr_host, row_ptr_bytes, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(x_device, x_bytes, x_host, x_bytes, ACL_MEMCPY_HOST_TO_DEVICE);

    if (kernel_type == USE_THREAD_PER_ROW) {
        kernel_spmv_thread<<<blocks_per_grid, THREAD_COUNT, 0, stream>>>(
            values_device, col_idx_device, row_ptr_device, x_device, y_device, num_rows);
    } else {
        kernel_spmv_warp<<<blocks_per_grid, THREAD_COUNT, 0, stream>>>(
            values_device, col_idx_device, row_ptr_device, x_device, y_device, num_rows);
    }

    aclrtSynchronizeStream(stream);

    aclrtMemcpy(y_host, y_bytes, y_device, y_bytes, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output(y_host, y_host + num_rows);

    aclrtFree(values_device);
    aclrtFree(col_idx_device);
    aclrtFree(row_ptr_device);
    aclrtFree(x_device);
    aclrtFree(y_device);
    aclrtFreeHost(y_host);

    const char* err = aclGetRecentErrMsg();
    if (err != nullptr) {
        fprintf(stderr, "%s\n", err);
    }

    aclrtDestroyStream(stream);
    aclrtResetDevice(device_id);
    aclFinalize();

    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(
            tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");
    if (std::equal(output.begin(), output.end(), golden.begin())) {
        std::cout << "[Success] Case accuracy verification passed." << std::endl;
        return 0;
    } else {
        std::cout << "[Failed] Case accuracy verification failed!" << std::endl;
        return 1;
    }
    return 0;
}

const char* get_kernel_name(int kernel_kind)
{
    switch (kernel_kind) {
        case USE_THREAD_PER_ROW:
            return "thread-per-row";
        case USE_WARP_PER_ROW:
            return "warp-per-row";
        default:
            return "unknown";
    }
}

int32_t main(int32_t argc, char* argv[])
{
    const uint32_t kernel_kind = static_cast<uint32_t>(SCENARIO_NUM);
    printf("Running case %u: %s...\n", kernel_kind, get_kernel_name(static_cast<int32_t>(kernel_kind)));

    std::vector<float> values;
    std::vector<uint32_t> col_idx;
    std::vector<uint32_t> row_ptr;
    std::vector<float> x(NUM_COLS);
    std::vector<float> golden;

    generate_sparse_matrix(values, col_idx, row_ptr, NUM_ROWS, NUM_COLS, MAX_NNZ_PER_ROW);

    // Use integer-valued floats for x as well, consistent with values.
    std::mt19937 gen(123);
    std::uniform_int_distribution<int32_t> dist(-10, 10);
    for (uint32_t i = 0; i < NUM_COLS; i++) {
        x[i] = static_cast<float>(dist(gen));
    }

    compute_spmv_cpu(values, col_idx, row_ptr, x, golden, NUM_ROWS);

    printf(
        "Sparse matrix: %u rows, %u cols, %u nnz (avg %.1f nnz/row)\n", NUM_ROWS, NUM_COLS,
        static_cast<uint32_t>(values.size()), static_cast<float>(values.size()) / NUM_ROWS);
    printf("=== Running Kernel ===\n");
    std::vector<float> output = launch_kernel(values, col_idx, row_ptr, x, NUM_ROWS, NUM_COLS, SCENARIO_NUM);

    return verify_result(output, golden);
}
