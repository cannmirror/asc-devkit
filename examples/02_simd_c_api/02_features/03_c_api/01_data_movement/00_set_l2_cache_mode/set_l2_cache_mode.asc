/* !
 * \file set_l2_cache_mode.asc
 * \brief L2 Cache mode best practices – kernel invocation and main
 *
 * 本样例通过 4 个 Case 展示 L2 Cache Mode 配置对不同数据访问模式下的性能影响：
 *   Case 1-2: GM→UB 重复搬运场景（shape=[12288,12288]）
 *   Case 3-4: 矩阵加法 + 双缓冲场景（shape=[8192,8192]）
 *
 * 优化路径：
 *   复用数据：Case 1(整块重复+L2开) vs Case 2(分片重复+L2开) → L2容量约束 + 分片策略
 *   流式数据：Case 3(双缓冲+L2开) vs Case 4(双缓冲+L2 bypass) → L2 bypass收益
 */

#include "set_l2_cache_mode.h"
#include "data_utils.h"
#include "acl/acl.h"
#include <vector>

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// ---------------------------------------------------------------------------
// 架构相关常量
// NPU_ARCH_ID 在 CMakeLists.txt 中定义：dav-2201 对应 2201，dav-3510 对应 3510
// ---------------------------------------------------------------------------
constexpr uint32_t AIV_CORE_NUM = 64;

// ====================================================================
// Case 1-2: GM→UB 重复搬运 Kernel
// 矩阵 shape 为 [12288, 12288]，half 类型
// ====================================================================

// 场景配置模板
template <uint32_t mValue, uint32_t nValue, uint32_t numBlocksValue, uint32_t tileMValue, uint32_t tileNValue>
struct ScenarioConfig {
    static constexpr uint32_t M = mValue;
    static constexpr uint32_t N = nValue;
    static constexpr uint32_t NUM_BLOCKS = numBlocksValue;
    static constexpr uint32_t SINGLE_CORE_M = M / NUM_BLOCKS;
    static constexpr uint32_t TILE_M = tileMValue;
    static constexpr uint32_t TILE_N = tileNValue;
};

// UB 重复搬运场景
// Case 1: 整块矩阵连续重复搬 4 次，L2 默认开启
// Case 2: N 方向切 4 份，每份重复搬 4 次，L2 默认开启
template <uint32_t scenario>
struct UbScenario;

template <>
struct UbScenario<1> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 1024> {};
template <>
struct UbScenario<2> : ScenarioConfig<12288, 12288, AIV_CORE_NUM, 64, 1024> {};

#if (SCENARIO_NUM <= 2)
// Case 1-2 相关常量
using CurrentScenario = UbScenario<SCENARIO_NUM>;
constexpr uint32_t REPEAT_M = CurrentScenario::M;
constexpr uint32_t REPEAT_N = CurrentScenario::N;
constexpr uint32_t REPEAT_NUM_BLOCKS = CurrentScenario::NUM_BLOCKS;
constexpr uint32_t REPEAT_SINGLE_CORE_M = CurrentScenario::SINGLE_CORE_M;
constexpr uint32_t REPEAT_TILE_M = CurrentScenario::TILE_M;
constexpr uint32_t REPEAT_TILE_N = CurrentScenario::TILE_N;

// GM→UB 重复搬运 kernel
template <
    uint32_t mValue, uint32_t nValue, uint32_t numBlocksValue, uint32_t singleCoreMValue, uint32_t tileMValue,
    uint32_t tileNValue>
__global__ __vector__ void kernel_data_copy_repeat(__gm__ uint8_t* src)
{
    asc_init();
    KernelDataCopyPadGm2Ub<mValue, nValue, numBlocksValue, singleCoreMValue, tileMValue, tileNValue> op;
    op.Init(reinterpret_cast<__gm__ half*>(src));
    // Case 1: 整块重复搬运 4 次，观察 L2 容量约束下的命中率
    // Case 2: N 方向切 4 份，每份重复搬运 4 次，观察分片策略下的 L2 命中率
    if constexpr (SCENARIO_NUM == 1) {
        op.ProcessRepeatWhole4Times();
    } else {
        op.ProcessSplitFourAndRepeat4Times();
    }
    asc_sync_pipe(PIPE_ALL);
}
#endif

// ====================================================================
// Case 3-4: 矩阵加法 Kernel
// 矩阵 shape 为 [8192, 8192]，half 类型
// ====================================================================

constexpr uint32_t ADD_LARGE_DATA_COPY_LEN = 20992;
constexpr uint32_t ADD_MULTI_CORE_M = 64;

constexpr uint32_t ADD_M = 8192;
constexpr uint32_t ADD_N = 8192;

// 矩阵加法 kernel
// Case 3: ProcessDoubleBuffer（L2 NORMAL = 0，来自 c_api add.asc 的 Case 4）
// Case 4: ProcessDoubleBufferL2Bypass（L2 DISABLE = 4，来自 c_api add.asc 的 Case 5）
template <uint32_t totalM, uint32_t totalN, uint32_t splitM, uint32_t splitN, uint32_t dataCopyLen>
__global__ __vector__ void kernel_add(__gm__ uint8_t* x, __gm__ uint8_t* y, __gm__ uint8_t* z)
{
    asc_init();
    KernelAdd<totalM, totalN, splitM, splitN, dataCopyLen> op;
    op.Init(
        reinterpret_cast<__gm__ uint8_t*>(x), reinterpret_cast<__gm__ uint8_t*>(y),
        reinterpret_cast<__gm__ uint8_t*>(z));
    // Case 3: 流式数据 + L2 NORMAL（L2 默认开启，基线场景）
    // Case 4: 流式数据 + L2 DISABLE（L2 bypass，省去不必要的 cache 写开销）
    if constexpr (scenarioNum == 3) {
        op.ProcessDoubleBuffer();
    } else {
        op.ProcessDoubleBufferL2Bypass();
    }
    asc_sync_pipe(PIPE_ALL);
}

// ====================================================================
// main 函数
// ====================================================================
int32_t main(int32_t argc, char* argv[])
{
    printf("========================================\n");
    printf("L2 Cache Mode Best Practices - Case %u\n", (uint32_t)scenarioNum);
    printf("========================================\n");

    uint32_t deviceId = 0;
    aclrtStream stream = nullptr;
    aclrtContext context;

    aclInit(nullptr);
    aclrtSetDevice(deviceId);
    aclrtCreateContext(&context, deviceId);
    aclrtCreateStream(&stream);

    // -------------------------------------------------------------------
    // Case 1-2: GM→UB 重复搬运场景
    //   单输入矩阵，无输出（纯搬运性能采集）
    // -------------------------------------------------------------------
#if (SCENARIO_NUM <= 2)
    {
        constexpr size_t FILE_SIZE = REPEAT_M * REPEAT_N * 2;
        size_t fileSize = FILE_SIZE;

        uint8_t* inputHost;
        uint8_t* inputDevice;
        aclrtMallocHost((void**)(&inputHost), fileSize);
        aclrtMalloc((void**)&inputDevice, fileSize, ACL_MEM_MALLOC_HUGE_FIRST);
        ReadFile("./input/input.bin", fileSize, inputHost, fileSize);
        aclrtMemcpy(inputDevice, fileSize, inputHost, fileSize, ACL_MEMCPY_HOST_TO_DEVICE);

        kernel_data_copy_repeat<
            REPEAT_M, REPEAT_N, REPEAT_NUM_BLOCKS, REPEAT_SINGLE_CORE_M, REPEAT_TILE_M, REPEAT_TILE_N>
            <<<REPEAT_NUM_BLOCKS, nullptr, stream>>>(inputDevice);

        aclrtSynchronizeStream(stream);

        aclrtFree(inputDevice);
        aclrtFreeHost(inputHost);
    }
    // -------------------------------------------------------------------
    // Case 3-4: 矩阵加法场景
    //   两个输入矩阵 + 一个输出矩阵
    // -------------------------------------------------------------------
#else
    {
        constexpr uint32_t dataLen = ADD_M * ADD_N;
        size_t inputByteSize = dataLen * sizeof(uint16_t);
        size_t outputByteSize = dataLen * sizeof(uint16_t);

        std::vector<uint8_t*> inputHost(2);
        std::vector<uint8_t*> inputDevice(2);
        std::vector<uint8_t*> outputHost(1);
        std::vector<uint8_t*> outputDevice(1);

        for (uint32_t i = 0; i < 2; i++) {
            aclrtMallocHost((void**)(&inputHost[i]), inputByteSize);
            aclrtMalloc((void**)(&inputDevice[i]), inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        }
        for (uint32_t i = 0; i < 1; i++) {
            aclrtMallocHost((void**)(&outputHost[i]), outputByteSize);
            aclrtMalloc((void**)(&outputDevice[i]), outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
        }

        // 读取输入数据
        const char* inputFiles[] = {"./input/input_x.bin", "./input/input_y.bin"};
        for (uint32_t i = 0; i < 2; i++) {
            size_t fileSize = 0;
            ReadFile(inputFiles[i], fileSize, inputHost[i], inputByteSize);
            aclrtMemcpy(inputDevice[i], inputByteSize, inputHost[i], inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
        }

        constexpr uint32_t splitM = ADD_MULTI_CORE_M;
        constexpr uint32_t splitN = 1;
        constexpr uint32_t numBlocks = splitM * splitN;
        kernel_add<ADD_M, ADD_N, splitM, splitN, ADD_LARGE_DATA_COPY_LEN>
            <<<numBlocks, nullptr, stream>>>(inputDevice[0], inputDevice[1], outputDevice[0]);
        aclrtSynchronizeStream(stream);

        // 写出输出结果
        for (uint32_t i = 0; i < 1; i++) {
            aclrtMemcpy(outputHost[i], outputByteSize, outputDevice[i], outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
            WriteFile("./output/output.bin", outputHost[i], outputByteSize);
            aclrtFree(outputDevice[i]);
            aclrtFreeHost(outputHost[i]);
        }

        for (uint32_t i = 0; i < 2; i++) {
            aclrtFree(inputDevice[i]);
            aclrtFreeHost(inputHost[i]);
        }
    }
#endif

    aclrtDestroyStream(stream);
    aclrtDestroyContext(context);
    aclrtResetDevice(deviceId);
    aclFinalize();

    printf("Case %u completed.\n", (uint32_t)scenarioNum);
    printf("test pass!\n");
    return 0;
}
